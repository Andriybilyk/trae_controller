    callback wifi_open_picker();
    callback wifi_disconnect();
    callback wifi_qr_toggle();

    callback kb_key(string);
    callback kb_open(string, int, string);

    // Touch debug dot (shows where the touch is detected)



    Rectangle {



        width: 6px * root.density;



        height: 6px * root.density;



        x: (min(max(root.touch_debug_x - 3, 0), root.board_display_w - 6)) * 1px;



        y: (min(max(root.touch_debug_y - 3, 0), root.board_display_h - 6)) * 1px;



        background: #FF3B30;



        border-radius: 3px * root.density;



        visible: root.touch_debug_pressed;



        z: 999;



    }



    // Header bar
    if (root.show_header) : Rectangle {
        x: 0px * root.density; y: 0px * root.density;
        width: parent.width;
        height: root.top_bar_h;
        background: root.c_panel;
        border-color: root.c_border;
        border-width: 1px * root.density;
        z: 100;

        Text {
            x: root.edge_gap; y: -1px * root.density;
            width: 210px * root.density; height: parent.height;
            text: "KILN PRO";
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 18px * root.density;
            font-weight: 700;
            letter-spacing: 1.4px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Rectangle {
            x: ((root.screen_w - self.width) / 2) + (34px * root.density); y: 0px * root.density;
            width: 220px * root.density; height: parent.height;
            background: #00000000;
            Text {
                x: 0px * root.density; y: -1px * root.density; width: parent.width; height: parent.height;
                text: root.current_time + "  " + root.current_date;
                color: root.c_muted;
                font-family: "PT Sans";
                font-size: 14px * root.density;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    if (!root.header_wifi_ok) {
                        root.settings_page = "clock";
                        root.view = View.Settings;
                    }
                }
            }
        }

        Rectangle {
            x: root.screen_w - root.edge_gap - (32px * root.density) - (32px * root.density) - (38px * root.density) - (20px * root.density);
            y: 8px * root.density;
            width: 38px * root.density; height: 24px * root.density;
            background: #27272A;
            border-radius: 6px * root.density;
            Text {
                x: 0px * root.density; y: 0px * root.density; width: parent.width; height: parent.height;
                text: root.is_ua ? "UA" : "EN";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 12px * root.density;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_language(); } }
        }

        Rectangle {
            x: root.screen_w - root.edge_gap - (32px * root.density) - (32px * root.density) - (10px * root.density);
            y: 0px * root.density;
            width: 32px * root.density; height: parent.height;
            background: #00000000;
            WifiIcon {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 26px * root.density; height: 26px * root.density;
                color: root.header_wifi_ok ? root.c_accent : #52525B;
            }
            TouchArea {
                x: -6px * root.density; y: -6px * root.density;
                width: parent.width + 12px;
                height: parent.height + 12px;
                clicked => { root.settings_page = "wifi"; root.view = View.Settings; }
            }
        }

        Rectangle {
            x: root.screen_w - root.edge_gap - (32px * root.density);
            y: 0px * root.density;
            width: 32px * root.density; height: parent.height;
            background: #00000000;
            SettingsIcon {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 26px * root.density; height: 26px * root.density;
                color: root.c_muted;
            }
            TouchArea {
                x: -6px * root.density; y: -6px * root.density;
                width: parent.width + 12px;
                height: parent.height + 12px;
                clicked => { root.settings_page = "all"; root.view = View.Settings; }
            }
        }
    }



    if (root.fault_active && !root.fault_popup_hidden) : Rectangle {
        x: (root.screen_w - (420px * root.density)) / 2;
        y: 108px * root.density;
        width: 420px * root.density; height: 84px * root.density;
        background: #7F1D1D;
        border-color: #DC2626;
        border-width: 2px * root.density;
        border-radius: 10px * root.density;
        z: 1200;
        Text {
            x: 16px * root.density; y: 14px * root.density;
            width: parent.width - 64px;
            text: root.fault_reason == ""
                ? (root.is_ua ? "\u{041F}\u{041E}\u{041C}\u{0418}\u{041B}\u{041A}\u{0410}" : "FAULT")
                : ((root.is_ua ? "\u{041F}\u{041E}\u{041C}\u{0418}\u{041B}\u{041A}\u{0410}: " : "FAULT: ") + root.fault_reason);
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 14px * root.density;
            horizontal-alignment: center;
            overflow: elide;
        }
        Rectangle {
            x: parent.width - (46px * root.density);
            y: 8px * root.density;
            width: 34px * root.density;
            height: 34px * root.density;
            border-radius: 17px * root.density;
            background: #991B1B;
            border-color: #DC2626;
            border-width: 1px * root.density;
            Text {
                text: "X";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 24px * root.density;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.fault_popup_hidden = true; }
            }
        }
    }

    if (root.command_feedback_visible) : Rectangle {
        x: 0px * root.density;
        y: 40px * root.density;
        width: root.screen_w;
        height: 24px * root.density;
        background: root.command_feedback_ok ? #064E3B : #7F1D1D;
        border-color: root.command_feedback_ok ? #10B981 : #DC2626;
        border-width: 1px * root.density;
        Text {
            x: 10px * root.density;
            y: 5px * root.density;
            width: parent.width - 20px;
            text: root.command_feedback;
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 12px * root.density;
            overflow: elide;
        }
    }

    if (root.fault_log_detail_visible) : Rectangle {
        x: 0px * root.density; y: 0px * root.density;
        width: root.screen_w; height: root.screen_h;
        background: #000000AA;
        z: 1400;
        TouchArea {
            x: 0px * root.density; y: 0px * root.density;
            width: parent.width; height: parent.height;
            clicked => { root.close_fault_log_detail(); }
        }
        Rectangle {
            x: 22px * root.density; y: 46px * root.density;
            width: 436px * root.density; height: 228px * root.density;
            background: #111827;
            border-color: #334155;
            border-width: 1px * root.density;
            border-radius: 12px * root.density;

            Text {
                x: 14px * root.density; y: 10px * root.density;
                width: parent.width - 70px; height: 24px * root.density;
                text: root.fault_log_detail_title;
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 15px * root.density;
                font-weight: 700;
                overflow: elide;
            }

            Rectangle {
                x: parent.width - (46px * root.density); y: 8px * root.density;
                width: 32px * root.density; height: 32px * root.density;
                border-radius: 16px * root.density;
                background: #1F2937;
                border-color: #374151;
                border-width: 1px * root.density;
                Text {
                    text: "X";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px * root.density;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.close_fault_log_detail(); } }
            }

            if (root.fault_log_detail_status != "") : Rectangle {
                x: 14px * root.density; y: 40px * root.density; width: 84px * root.density; height: 22px * root.density;
                background: root.fault_log_detail_status == "OK" ? #14532D : #7F1D1D;
                border-radius: 7px * root.density;
                Text {
                    text: root.fault_log_detail_status;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 11px * root.density;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            ScrollView {
                x: 12px * root.density; y: 70px * root.density;
                width: parent.width - 24px; height: parent.height - 82px;
                horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                Text {
                    width: parent.width; height: max(parent.height, self.preferred-height);
                    text: root.fault_log_detail_text;
                    color: #CBD5E1;
                    font-family: "PT Sans";
                    font-size: 12px * root.density;
                    wrap: word-wrap;
                }
            }
        }
    }

    // Main content



    Rectangle {
        x: 0px * root.density; y: (root.show_header ? root.top_bar_h : 0px);
        width: root.screen_w; height: root.page_content_h;



        background: root.c_bg;



        



// Dashboard View



        if (root.view == View.Dashboard) : ScrollView {
            x: 0px * root.density; y: 0px * root.density;
            width: root.screen_w; height: root.page_content_h;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            mouse-drag-pan-enabled: true;

            Rectangle {
                width: root.screen_w; height: root.page_content_h;
                background: root.c_bg;



            // Left column



            Rectangle {



                x: 0px * root.density; y: 0px * root.density;



                width: root.screen_w / 2; height: root.page_content_h;



                background: root.c_bg;



                border-color: root.c_border;



                border-width: 1px * root.density;



                Text {



                    x: 16px * root.density; y: 12px * root.density;



                    text: root.is_ua ? "\u{041F}\u{041E}\u{0422}\u{041E}\u{0427}\u{041D}\u{0410}\n\u{0422}\u{0415}\u{041C}\u{041F}\u{0415}\u{0420}\u{0410}\u{0422}\u{0423}\u{0420}\u{0410}" : "CURRENT\nTEMPERATURE";



                    color: root.c_muted;



                    font-family: "PT Sans";



                    font-size: 12px * root.density;



                    letter-spacing: 0.5px;



                }



                Rectangle {
                    x: parent.width - self.width - (8px * root.density);
                    y: 12px * root.density;
                    width: root.is_ua
                        ? (root.status_label == "IDLE" ? 150px * root.density
                           : root.status_label == "COOL" ? 150px * root.density
                           : root.status_label == "COMPLETE" ? 138px * root.density
                           : root.status_label == "ERROR" ? 118px * root.density
                           : 118px * root.density)
                        : (root.status_label == "ERROR" ? 108px * root.density : 98px * root.density);
                    height: 26px * root.density;
                    background: root.status_bg;
                    border-color: root.status_fg;
                    border-width: root.status_label == "ERROR" ? 2px : 1px;
                    border-radius: 13px * root.density;
                    clip: true;

                    Text {
                        text: root.status_text;
                        color: root.status_fg;
                        font-family: "PT Sans";
                        font-size: root.is_ua ? 12px * root.density : 14px * root.density;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }



                Text {



                    x: 16px * root.density; y: (root.board_profile_id == 1 ? 50px : 56px) * root.density;
                    width: parent.width - (104px * root.density);
                    height: (root.board_profile_id == 1 ? 214px : 150px) * root.density;



                    text: root.temp_label;



                    color: #FFFFFF;



                    font-family: "PT Sans";



                    font-size: root.board_profile_id == 1 ? 102px : 148px;



                    font-weight: 700;



                }



                Text {



                    x: (parent.width - 88px * root.density); y: (root.board_profile_id == 1 ? 58px : 64px) * root.density;
                    width: 76px * root.density;



                    text: root.temp_unit_label;


                    color: root.c_text;



                    font-family: "PT Sans";



                    font-size: root.board_profile_id == 1 ? 32px : 40px * root.density;
                    horizontal-alignment: right;
                    vertical-alignment: center;



                }

                Text {
                    x: 16px * root.density; y: (root.board_profile_id == 1 ? 136px : 128px) * root.density;
                    text: root.temp_hint != ""
                        ? root.temp_hint
                        : ((root.display_target_value > 0)
                            ? (root.display_target_value + root.temp_unit_label)
                            : "");
                    color: root.temp_hint != "" ? root.c_danger : #10B981;
                    font-family: "PT Sans";
                    font-size: 22px * root.density;
                    overflow: elide;
                }



                Rectangle {



                    x: root.dash_pad_x;
                    y: root.dash_btn_row_y + root.dash_btn_row_h - (92px * root.density) + (root.board_profile_id == 1 ? 12px * root.density : 0px);



                    width: root.dash_card_w; height: 92px * root.density;



                    background: root.c_card;



                    border-color: root.c_border;



                    border-width: 1px * root.density;



                    border-radius: 14px * root.density;



                    Text {
                        x: 12px * root.density; y: 10px * root.density;
                        text: root.is_ua ? "\u{0415}\u{043B}\u{0435}\u{043A}\u{0442}\u{0440}\u{0438}\u{043A}\u{0430}" : "Power";



                        color: root.c_muted;



                        font-family: "PT Sans";



                        font-size: 14px * root.density;



                    }



                    Text {
                        x: 12px * root.density; y: 32px * root.density;
                        width: (parent.width - 24px) / 2; height: 16px * root.density;
                        text: root.pzem_power_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px * root.density;
                        vertical-alignment: center;
                    }

                    Text {
                        x: 12px * root.density; y: 50px * root.density;
                        width: (parent.width - 24px) / 2; height: 16px * root.density;
                        text: root.pzem_current_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px * root.density;
                        vertical-alignment: center;
                    }

                    Text {
                        x: parent.width / 2 + 2px; y: 32px * root.density;
                        width: (parent.width - 24px) / 2; height: 16px * root.density;
                        text: root.pzem_voltage_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px * root.density;
                        vertical-alignment: center;
                    }

                    Text {
                        x: parent.width / 2 + 2px; y: 50px * root.density;
                        width: (parent.width - 24px) / 2; height: 16px * root.density;
                        text: root.pzem_phase_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px * root.density;
                        vertical-alignment: center;
                    }



                    Rectangle {



                        x: 12px * root.density; y: 88px * root.density;



                        width: parent.width - 24px; height: 4px * root.density;



                        background: root.c_border;



                        border-radius: 2px * root.density;



                        Rectangle {



                            width: root.display_target_value > 0 ? min((root.temp / root.display_target_value) * (parent.width), parent.width) : 0px;



                            height: 4px * root.density;



                            background: root.status_fg;



                            border-radius: 2px * root.density;



                        }



                    }



                }



            }



            // Right column



            Rectangle {



                x: root.screen_w / 2; y: 0px * root.density;



                width: root.screen_w / 2; height: root.page_content_h;



                background: root.c_bg;



                Rectangle {



                    x: root.dash_pad_x; y: root.dash_pad_y;



                    width: root.dash_card_w; height: root.dash_card_h;



                    background: root.c_card;



                    border-color: root.c_border;



                    border-width: 1px * root.density;



                    border-radius: 16px * root.density;



                    Rectangle {
                        visible: root.is_idle && root.selected_schedule_name == "";
                        x: 0px * root.density; y: 44px * root.density;
                        width: parent.width; height: 84px * root.density;
                        background: #00000000;



                        ActivityIcon {



                            x: (parent.width - self.width) / 2;



                            y: 50px * root.density;



                            color: #3F3F46;



                            width: 32px * root.density; height: 32px * root.density;



                        }



                        Text {



                            x: 0px * root.density; y: 92px * root.density;



                            width: parent.width;



                            text: root.is_ua ? "\u{0412}\u{0438}\u{0431}\u{0435}\u{0440}\u{0456}\u{0442}\u{044C} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0443}" : "Select Schedule";



                            color: root.c_muted;



                            font-family: "PT Sans";



                            font-size: 18px * root.density;


                            horizontal-alignment: center;



                        }



                    }



                    Rectangle {
                        visible: root.is_idle && root.selected_schedule_name != "";
                        x: 0px * root.density; y: 18px * root.density;
                        width: parent.width; height: 70px * root.density;
                        background: #00000000;



                        Text {
                            x: 0px * root.density; y: 18px * root.density;
                            width: parent.width;
                            text: root.is_ua ? "\u{0412}\u{0438}\u{0431}\u{0440}\u{0430}\u{043D}\u{0430} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0430}" : "Selected Program";
                            color: root.c_accent;
                            font-family: "PT Sans";
                            font-size: 16px * root.density;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            x: 0px * root.density; y: 44px * root.density;
                            width: parent.width;
                            text: root.selected_schedule_name;
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 20px * root.density;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            x: 0px * root.density; y: 68px * root.density;
                            width: parent.width;
                            text: root.selected_steps_count + " " + (root.is_ua ? "\u{043A}\u{0440}\u{043E}\u{043A}\u{0456}\u{0432}" : "segments");
                            color: root.c_subtle;
                            font-size: 16px * root.density;
                            horizontal-alignment: center;
                        }





                    }

                    Rectangle {
                        visible: !root.is_idle;
                        x: 0px * root.density; y: 6px * root.density;
                        width: parent.width; height: 146px * root.density;
                        background: #00000000;



                        Rectangle {
                            x: 10px * root.density; y: 6px * root.density;
                            width: parent.width - 20px; height: 102px * root.density;
                            border-radius: 12px * root.density;
                            background: #18181B;
                            border-color: #27272A;
                            border-width: 1px * root.density;
                        }

                        Text {



                            x: 0px * root.density; y: 14px * root.density;



                            width: parent.width;



                            text: root.is_ua ? "\u{041A}\u{0440}\u{043E}\u{043A}" : "Step";



                            color: root.c_muted;



                            font-size: 14px * root.density;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px * root.density; y: 36px * root.density;



                            width: parent.width;



                            text: root.step_index + " / " + root.total_steps;



                            color: #FFFFFF;



                            font-family: "PT Sans";



                            font-size: 28px * root.density;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px * root.density; y: 66px * root.density;



                            width: parent.width;



                            text: root.is_ua
                                ? ("\u{0414}\u{043E} \u{043A}\u{0456}\u{043D}\u{0446}\u{044F} \u{043A}\u{0440}\u{043E}\u{043A}\u{0443}: " + root.step_time_remaining)
                                : ("Step left: " + root.step_time_remaining);



                            color: #71717A;



                            font-size: 14px * root.density;



                            horizontal-alignment: center;



                        }

                        Text {
                            x: 0px * root.density; y: 84px * root.density;
                            width: parent.width;
                            text: root.is_ua
                                ? ("\u{0414}\u{043E} \u{043A}\u{0456}\u{043D}\u{0446}\u{044F} \u{0432}\u{0438}\u{043F}\u{0430}\u{043B}\u{0443}: " + root.firing_time_remaining)
                                : ("Firing left: " + root.firing_time_remaining);
                            color: #71717A;
                            font-size: 14px * root.density;
                            horizontal-alignment: center;
                        }

                        Rectangle {
                            x: 10px * root.density; y: 116px * root.density;
                            width: parent.width - 20px; height: 30px * root.density;
                            border-radius: 10px * root.density;
                            background: root.c_danger;
                            Text {
                                text: root.is_ua ? "\u{041F}\u{0440}\u{043E}\u{043F}\u{0443}\u{0441}\u{0442}\u{0438}\u{0442}\u{0438} \u{043A}\u{0440}\u{043E}\u{043A}" : "Skip Step";
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 13px * root.density;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_step(); } }
                        }



                    }

                // Bottom action buttons



                Rectangle {



                    x: (root.board_profile_id == 1 ? (root.dash_pad_x - 8px * root.density) : root.dash_pad_x); y: root.dash_btn_row_y;



                    width: root.dash_card_w; height: root.dash_btn_row_h;

                    // Big STOP button (shown while firing)
                    Rectangle {
                        visible: !root.is_idle;
                        x: 0px * root.density; y: 0px * root.density;
                        width: root.dash_btn_w; height: root.dash_btn_row_h;
                        background: root.c_danger;
                        border-radius: 16px * root.density;

                        StopIcon { x: (parent.width - self.width) / 2; y: 20px * root.density; color: #FFFFFF; width: 18px * root.density; height: 18px * root.density; }

                        Text {
                            x: 0px * root.density; y: 50px * root.density;
                            width: parent.width;
                            text: root.is_ua ? "\u{0417}\u{0443}\u{043F}\u{0438}\u{043D}\u{0438}\u{0442}\u{0438}" : "Stop";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px * root.density;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea { width: parent.width; height: parent.height; clicked => { root.stop_firing(); } }
                    }


                    background: #00000000;



                    Rectangle {



                        x: 0px * root.density; y: 0px * root.density;



                        visible: root.is_idle;

                        width: root.dash_btn_w; height: root.dash_btn_row_h;


                        background: root.fault_active ? #4A1111 : (root.selected_schedule_name == "" ? root.c_border : root.c_accent);



                        border-radius: 16px * root.density;



                        PlayIcon {



                            x: (parent.width - self.width) / 2;



                            y: 18px * root.density;



                            color: (root.selected_schedule_name == "" || root.fault_active) ? root.c_muted : #000000;



                            width: 26px * root.density; height: 26px * root.density;



                        }



                        if (root.selected_schedule_name == "") : Rectangle {



                            width: parent.width; height: parent.height;



                            background: #00000000;



                            Text {



                                x: 0px * root.density; y: 42px * root.density;



                                width: parent.width;



                                text: root.is_ua ? "\u{0412}\u{0438}\u{0431}\u{0435}\u{0440}\u{0456}\u{0442}\u{044C}" : "Select";



                                color: root.c_muted;



                                font-family: "PT Sans";



                                font-size: 15px * root.density;



                                horizontal-alignment: center;



                            }



                            Text {



                                x: 0px * root.density; y: 58px * root.density;



                                width: parent.width;



                                text: root.is_ua ? "\u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0443}" : "Schedule";



                                color: root.c_muted;



                                font-family: "PT Sans";



                                font-size: 15px * root.density;



                                horizontal-alignment: center;



                            }



                        }



                        if (root.selected_schedule_name != "") : Rectangle {



                            width: parent.width; height: parent.height;



                            background: #00000000;



                            Text {



                                x: 0px * root.density; y: 42px * root.density;



                                width: parent.width;



                                text: root.is_ua ? "\u{041F}\u{043E}\u{0447}\u{0430}\u{0442}\u{0438}" : "Start";



                                color: root.fault_active ? #FFFFFF : #000000;



                                font-family: "PT Sans";



                                font-size: 15px * root.density;



                                horizontal-alignment: center;



                            }



                            Text {



                                x: 0px * root.density; y: 58px * root.density;



                                width: parent.width;



                                text: root.is_ua ? "\u{0412}\u{0438}\u{043F}\u{0430}\u{043B}" : "Firing";



                                color: root.fault_active ? #FFFFFF : #000000;



                                font-family: "PT Sans";



                                font-size: 15px * root.density;



                                horizontal-alignment: center;



                            }



                        }



                        TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.start_firing(); }
            }


                    }



                    Rectangle {



                        x: root.dash_btn_w + root.dash_btn_gap; y: 0px * root.density; visible: true;


                        width: root.dash_btn_w; height: root.dash_btn_row_h;



                        background: root.c_border;



                        border-radius: 16px * root.density;



                        ThermometerIcon {



                            x: (parent.width - self.width) / 2;



                            y: 18px * root.density;



                            color: root.c_text;



                            width: 18px * root.density; height: 18px * root.density;



                        }



                        Text {



                            x: 0px * root.density; y: 46px * root.density;



                            width: parent.width;



                            text: !root.is_idle ? (root.is_ua ? "\u{0420}\u{0435}\u{0434}\u{0430}\u{0433}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Edit") : (root.is_ua ? "\u{041F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0438}" : "Programs");



                            color: root.c_text;



                            font-family: "PT Sans";



                            font-size: 15px * root.density;



                            horizontal-alignment: center;



                            vertical-alignment: center;



                        }



                        TouchArea {



                width: parent.width; height: parent.height; clicked => {
                    if (!root.is_idle) {
                        root.open_running_editor();
                    } else {
                        root.open_library();
                    }
                } }



                    }



                }



            }



            }
        }
        }


        // (touch debug bar removed)



// Schedules View



        if (root.view == View.Schedules) : Rectangle {
                x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                background: #0B1220;




                Rectangle {
                    x: 0px * root.density; y: root.settings_title_y;
                    width: root.screen_w; height: root.settings_header_h;
                    background: #00000000;

                    ThermometerIcon {
                        x: root.settings_side_gap;
                        y: (parent.height - root.settings_icon_size) / 2;
                        width: root.settings_icon_size; height: root.settings_icon_size;
                        color: #10B981;
                    }

                    Text {
                        x: root.settings_title_x;
                        y: 0px * root.density;
                        width: 300px * root.density; height: parent.height;
                        text: root.is_ua ? "\u{0411}\u{0456}\u{0431}\u{043B}\u{0456}\u{043E}\u{0442}\u{0435}\u{043A}\u{0430}" : "Library";
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px * root.density;
                        vertical-alignment: center;
                    }
                }



                Rectangle {
                    x: root.screen_w - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    border-radius: root.settings_action_btn_radius;
                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.view = View.Dashboard; } }
                }



                ScrollView { // schedules-list
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.screen_w - root.settings_side_gap * 2;
                    height: parent.height - root.settings_content_y - root.settings_side_gap;
                    viewport-width: self.width;
                    viewport-height: (root.schedules.length + 1) * (root.settings_list_row_h + 12px) + root.schedules.length * root.settings_grid_gap;
                    viewport-x: 0px * root.density;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;
                    VerticalBox {
                        width: root.screen_w - root.settings_side_gap * 2;
                        spacing: root.settings_grid_gap;
                        for schedule[i] in root.schedules : Rectangle {
                            width: root.screen_w - root.settings_side_gap * 4; height: root.settings_list_row_h + (12px * root.density);


                            background: schedule.selected ? #1F2937 : #0F0F0F;



                            border-color: schedule.selected ? #10B981 : #27272A;



                            border-width: 1px * root.density;



                            border-radius: 12px * root.density;



                            Text {
                                x: root.settings_inner_pad; y: root.settings_label_y;
                                width: parent.width - (root.settings_inner_pad * 2 + root.settings_action_btn_h * 3 + root.settings_grid_gap * 2);
                                height: 22px * root.density;
                                text: schedule.name;
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 18px * root.density;
                                font-weight: 700;
                                overflow: elide;
                            }

                            Text {
                                x: root.settings_inner_pad; y: root.settings_label_y + 24px * root.density;
                                width: parent.width - (root.settings_inner_pad * 2 + root.settings_action_btn_h * 3 + root.settings_grid_gap * 2);
                                height: 18px * root.density;
                                text: root.is_ua ? "\u{041A}\u{043E}\u{0440}\u{0438}\u{0441}\u{0442}\u{0443}\u{0432}\u{0430}\u{0446}\u{044C}\u{043A}\u{0430}" : "Custom";
                                color: #A1A1AA;
                                font-size: 14px * root.density;
                                horizontal-alignment: left;
                                overflow: elide;
                            }

                            Text {
                                x: root.settings_inner_pad; y: root.settings_label_y + 46px * root.density;
                                width: parent.width - (root.settings_inner_pad * 2 + root.settings_action_btn_h * 3 + root.settings_grid_gap * 2);
                                height: 18px * root.density;
                                text: schedule.steps_count + " " + (root.is_ua ? "\u{043A}\u{0440}\u{043E}\u{043A}\u{0456}\u{0432}" : "segments");
                                color: #A1A1AA;
                                font-size: 14px * root.density;
                                overflow: elide;
                            }



                            Rectangle {
                                z: 2;
                                x: parent.width - root.settings_inner_pad - (root.settings_action_btn_h * 3 + root.settings_grid_gap * 2);
                                y: (parent.height - self.height) / 2;
                                width: root.settings_action_btn_h; height: root.settings_action_btn_h;
                                background: #10B981;
                                border-radius: root.settings_action_btn_h / 2;

                                Rectangle { x: 14px * root.density; y: 32px * root.density; width: 24px * root.density; height: 2px * root.density; background: #000000; border-radius: 1px * root.density; }
                                Rectangle { x: 16px * root.density; y: 28px * root.density; width: 4px * root.density; height: 4px * root.density; background: #000000; border-radius: 2px * root.density; }
                                Rectangle { x: 24px * root.density; y: 24px * root.density; width: 4px * root.density; height: 4px * root.density; background: #000000; border-radius: 2px * root.density; }
                                Rectangle { x: 32px * root.density; y: 18px * root.density; width: 4px * root.density; height: 4px * root.density; background: #000000; border-radius: 2px * root.density; }
                                Rectangle { x: 20px * root.density; y: 26px * root.density; width: 6px * root.density; height: 2px * root.density; background: #000000; border-radius: 1px * root.density; }
                                Rectangle { x: 28px * root.density; y: 22px * root.density; width: 6px * root.density; height: 2px * root.density; background: #000000; border-radius: 1px * root.density; }

                                TouchArea {
                    width: parent.width; height: parent.height; clicked => { root.open_schedule_graph(i); } }
                            }

                            Rectangle {
                                z: 2;
                                x: parent.width - root.settings_inner_pad - (root.settings_action_btn_h * 2 + root.settings_grid_gap);
                                y: (parent.height - self.height) / 2;
                                width: root.settings_action_btn_h; height: root.settings_action_btn_h;
                                background: #DC2626;
                                border-radius: root.settings_action_btn_h / 2;

                                Text {
                                    x: 0px * root.density; y: 0px * root.density;
                                    width: parent.width; height: parent.height;
                                    text: "\u{E872}";
                                    color: #FFFFFF;
                                    font-family: "Material Icons";
                                    font-size: 24px * root.density;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                    width: parent.width; height: parent.height; clicked => { root.delete_confirm_index = i; root.delete_confirm_visible = true; } }
                            }

                            Rectangle {
                                z: 2;
                                x: parent.width - root.settings_inner_pad - root.settings_action_btn_h;
                                y: (parent.height - self.height) / 2;
                                width: root.settings_action_btn_h; height: root.settings_action_btn_h;


                                background: schedule.selected ? #10B981 : #27272A;



                                border-radius: root.settings_action_btn_h / 2;


                                PlayIcon {



                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;


                                    width: 28px * root.density; height: 28px * root.density;


                                    color: schedule.selected ? #000000 : #FFFFFF;



                                }



                                TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.select_schedule(i); } }



                            }



                            TouchArea {
                                width: parent.width - (root.settings_inner_pad + root.settings_action_btn_h * 3 + root.settings_grid_gap * 2);
                                height: parent.height;


                                x: 0px * root.density; y: 0px * root.density;
                                z: 1;
                                clicked => { root.edit_schedule(i); }
                            }


                        }



                        Rectangle {
                            width: root.screen_w - root.settings_side_gap * 4; height: root.settings_list_row_h + (12px * root.density);


                            background: #000000;



                            border-color: #3F3F46;



                            border-width: 1px * root.density;



                            border-radius: 12px * root.density;



                            Text { text: root.is_ua ? "\u{041D}\u{043E}\u{0432}\u{0430} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0430}" : "New Program"; color: #A1A1AA; font-family: "PT Sans"; font-size: 16px * root.density; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }


                            TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.new_schedule(); } }



                        }



                    }
                }



        }


        if (root.view == View.ScheduleGraph) : Rectangle {
                x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                background: #000000;
                clip: true;

                Text {
                    x: root.settings_side_gap;
                    y: root.settings_title_y;
                    width: root.schedule_graph_back_to_history
                        ? (root.screen_w - root.settings_side_gap * 2 - (root.settings_nav_btn_w * 2 + root.settings_nav_gap + (108px * root.density)))
                        : (root.screen_w - root.settings_side_gap * 2 - (root.settings_nav_btn_w * 2 + root.settings_nav_gap));
                    height: root.settings_header_h;
                    text: root.selected_schedule_name == ""
                        ? (root.is_ua ? "\u{0413}\u{0440}\u{0430}\u{0444}\u{0456}\u{043A} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0438}" : "Program Graph")
                        : root.selected_schedule_name;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px * root.density;
                    vertical-alignment: center;
                    overflow: elide;
                }

                UiButton {
                    x: root.screen_w - root.settings_side_gap - root.settings_nav_btn_w * 2 - root.settings_nav_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #1F2937;
                    radius: root.settings_action_btn_radius;
                    label: "<";
                    text_size: 16px;
                    tapped => { root.view = root.schedule_graph_back_to_history ? View.Settings : View.Schedules; }
                }

                UiButton {
                    x: root.screen_w - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    radius: root.settings_action_btn_radius;
                    label: "X";
                    text_size: 16px;
                    tapped => { root.view = View.Dashboard; }
                }

                Rectangle {
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.settings_content_width; height: root.settings_content_height;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px * root.density;
                    border-radius: 12px * root.density;
                    clip: true;
                    Rectangle {
                        x: root.schedule_graph_plot_x; y: 8px * root.density; width: root.schedule_graph_plot_w; height: root.schedule_graph_plot_h;
                        background: #0B0B10;
                        border-color: #1F2937;
                        border-width: 1px * root.density;
                        border-radius: 10px * root.density;
                        clip: false;

                        Text {
                            x: -44px * root.density; y: 8px * root.density; width: 40px * root.density; height: 14px * root.density;
                            text: root.schedule_graph_peak_temp + "" + root.temp_unit_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px * root.density;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }

                        Text {
                            x: -44px * root.density; y: parent.height / 2 - 7px; width: 40px * root.density; height: 14px * root.density;
                            text: root.schedule_graph_mid_temp + "" + root.temp_unit_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px * root.density;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }

                        Text {
                            x: -44px * root.density; y: parent.height - 18px; width: 40px * root.density; height: 14px * root.density;
                            text: "0";
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px * root.density;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }

                        for marker in root.schedule_graph_markers : Text {
                            visible: root.schedule_graph_markers.length > 0;
                            x: marker.x * 1px >= parent.width - (24px * root.density)
                                ? marker.x * 1px + (4px * root.density)
                                : marker.x * 1px - (30px * root.density);
                            y: marker.y * 1px;
                            width: 60px * root.density; height: 14px * root.density;
                            text: marker.label;
                            color: marker.color;
                            font-family: "PT Sans";
                            font-size: 10px * root.density;
                            horizontal-alignment: marker.x * 1px >= parent.width - (24px * root.density) ? TextHorizontalAlignment.left : TextHorizontalAlignment.center;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        if (root.schedule_graph_markers.length == 0) : Text {
                            x: 0px * root.density; y: parent.height + 2px; width: 92px * root.density; height: 14px * root.density;
                            text: root.schedule_graph_half_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px * root.density;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        if (root.schedule_graph_markers.length == 0) : Text {
                            x: parent.width - (92px * root.density); y: parent.height + 2px; width: 92px * root.density; height: 14px * root.density;
                            text: root.schedule_graph_total_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px * root.density;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Rectangle {
                            x: 0px * root.density; y: 0px * root.density; width: parent.width; height: parent.height;
                            background: #00000000;
                            clip: true;
                            // Plot area geometry aligned with Rust mapping:
                            // left 19, right 6, top 8, bottom 24.
                            Rectangle { x: 19px * root.density; y: 8px * root.density; width: 1px * root.density; height: parent.height - 32px; background: #27272A; }
                            Rectangle { x: 19px * root.density; y: parent.height - 24px; width: parent.width - 25px; height: 1px * root.density; background: #27272A; }
                            Rectangle { x: 19px * root.density + (parent.width - 25px) / 6; y: 8px * root.density; width: 1px * root.density; height: parent.height - 32px; background: #16161E; }
                            Rectangle { x: 19px * root.density + (parent.width - 25px) * 2 / 6; y: 8px * root.density; width: 1px * root.density; height: parent.height - 32px; background: #16161E; }
                            Rectangle { x: 19px * root.density + (parent.width - 25px) * 3 / 6; y: 8px * root.density; width: 1px * root.density; height: parent.height - 32px; background: #16161E; }
                            Rectangle { x: 19px * root.density + (parent.width - 25px) * 4 / 6; y: 8px * root.density; width: 1px * root.density; height: parent.height - 32px; background: #16161E; }
                            Rectangle { x: 19px * root.density + (parent.width - 25px) * 5 / 6; y: 8px * root.density; width: 1px * root.density; height: parent.height - 32px; background: #16161E; }
                            Rectangle { x: 19px * root.density; y: 8px * root.density + (parent.height - 32px) / 5; width: parent.width - 25px; height: 1px * root.density; background: #16161E; }
                            Rectangle { x: 19px * root.density; y: 8px * root.density + (parent.height - 32px) * 2 / 5; width: parent.width - 25px; height: 1px * root.density; background: #16161E; }
                            Rectangle { x: 19px * root.density; y: 8px * root.density + (parent.height - 32px) * 3 / 5; width: parent.width - 25px; height: 1px * root.density; background: #16161E; }
                            Rectangle { x: 19px * root.density; y: 8px * root.density + (parent.height - 32px) * 4 / 5; width: parent.width - 25px; height: 1px * root.density; background: #16161E; }
                            Rectangle { x: 19px * root.density; y: 8px * root.density + (parent.height - 32px) / 2; width: parent.width - 25px; height: 1px * root.density; background: #1F2937; }

                            for rect in root.schedule_graph_rects : Rectangle {
                                x: rect.x * 1px;
                                y: rect.y * 1px;
                                width: rect.width * 1px;
                                height: rect.height * 1px;
                                background: rect.color;
                                border-radius: 1px * root.density;
                            }

                            TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => { root.schedule_graph_point_tapped(-1); }
                            }

                            for point[i] in root.schedule_graph_points : Rectangle {
                                x: point.x * 1px - 5px;
                                y: point.y * 1px - 5px;
                                width: 10px * root.density;
                                height: 10px * root.density;
                                background: point.color;
                                border-radius: 5px * root.density;
                                border-width: 2px * root.density;
                                border-color: #0F1115;
                                TouchArea {
                                    width: 18px * root.density;
                                    height: 18px * root.density;
                                    x: -4px * root.density;
                                    y: -4px * root.density;
                                    clicked => { root.schedule_graph_point_tapped(i); }
                                }
                            }

                            if (root.schedule_graph_tip_visible) : Rectangle {
                                x: root.schedule_graph_tip_x_px * 1px;
                                y: root.schedule_graph_tip_y_px * 1px;
                                width: root.schedule_graph_tip_w_px * 1px;
                                height: root.schedule_graph_tip_h_px * 1px;
                                background: #111827;
                                border-color: #334155;
                                border-width: 1px * root.density;
                                border-radius: 8px * root.density;
                                clip: true;

                                Text {
                                    x: 8px * root.density; y: 4px * root.density; width: parent.width - 16px; height: (parent.height / 2) - 6px;
                                    text: root.schedule_graph_tip_temp;
                                    color: #E2E8F0;
                                    font-family: "PT Sans";
                                    font-size: 12px * root.density;
                                    font-weight: 700;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                    wrap: word-wrap;
                                }

                                Text {
                                    x: 8px * root.density; y: (parent.height / 2) - 2px; width: parent.width - 16px; height: (parent.height / 2) - 2px;
                                    text: root.schedule_graph_tip_time;
                                    color: #94A3B8;
                                    font-family: "PT Sans";
                                    font-size: 11px * root.density;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        if (root.schedule_graph_rects.length == 0) : Text {
                            x: 0px * root.density; y: 0px * root.density; width: parent.width; height: parent.height;
                            text: root.schedule_graph_back_to_history ? "No firing data available for this graph" : "This program has no steps to plot yet";
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 13px * root.density;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

        }


        if (root.view == View.HistoryDetail) : Rectangle {
                x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                background: #000000;
                clip: true;

                Text {
                    x: root.settings_side_gap;
                    y: root.settings_title_y;
                    width: root.screen_w - root.settings_side_gap * 2 - (root.settings_nav_btn_w * 2 + root.settings_nav_gap);
                    height: root.settings_header_h;
                    text: root.history_detail_title == ""
                        ? (root.is_ua ? "\u{0414}\u{0435}\u{0442}\u{0430}\u{043B}\u{0456} \u{0432}\u{0438}\u{043F}\u{0430}\u{043B}\u{0443}" : "Firing Details")
                        : root.history_detail_title;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px * root.density;
                    vertical-alignment: center;
                    overflow: elide;
                }

                UiButton {
                    x: root.screen_w - root.settings_side_gap - root.settings_nav_btn_w * 2 - root.settings_nav_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #1F2937;
                    radius: root.settings_action_btn_radius;
                    label: "<";
                    text_size: 16px;
                    tapped => { root.view = View.Settings; root.settings_page = "history"; }
                }

                UiButton {
                    x: root.screen_w - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    radius: root.settings_action_btn_radius;
                    label: "X";
                    text_size: 16px;
                    tapped => { root.view = View.Dashboard; }
                }

                ScrollView {
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.settings_content_width; height: root.settings_content_height;
                    viewport-width: self.width;
                    viewport-height: 500px * root.density;
                    viewport-x: 0px * root.density;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;

                    Rectangle {
                        x: 0px * root.density; y: 0px * root.density; width: root.settings_content_width; height: 500px * root.density; background: #00000000;

                        Rectangle {
                            x: 0px * root.density; y: 0px * root.density; width: parent.width; height: 158px * root.density;
                            background: #111118; border-color: #27272A; border-width: 1px * root.density; border-radius: 12px * root.density;
                            Text { x: 12px * root.density; y: 8px * root.density; width: parent.width - 24px; height: 24px * root.density; text: root.is_ua ? "\u{041F}\u{0430}\u{0441}\u{043F}\u{043E}\u{0440}\u{0442} \u{0432}\u{0438}\u{043F}\u{0430}\u{043B}\u{0443}" : "Firing Passport"; color: #FFFFFF; font-size: 22px * root.density; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 38px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{041D}\u{0430}\u{0437}\u{0432}\u{0430} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0438}" : "Program name"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 38px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_program_name == "" ? (root.is_ua ? "\u{0420}\u{045C}/\u{0420}\"" : "N/A") : root.history_detail_program_name; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 60px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{041F}\u{043E}\u{0447}\u{0430}\u{0442}\u{043E}\u{043A}" : "Start"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 60px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_start_time == "" ? (root.is_ua ? "\u{0420}\u{045C}/\u{0420}\"" : "N/A") : root.history_detail_start_time; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 82px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{0417}\u{0430}\u{0432}\u{0435}\u{0440}\u{0448}\u{0435}\u{043D}\u{043D}\u{044F}" : "End"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 82px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_end_time == "" ? (root.is_ua ? "\u{0420}\u{045C}/\u{0420}\"" : "N/A") : root.history_detail_end_time; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 104px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{0422}\u{0440}\u{0438}\u{0432}\u{0430}\u{043B}\u{0456}\u{0441}\u{0442}\u{044C}" : "Duration"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 104px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_duration == "" ? "--" : root.history_detail_duration; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 126px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{0421}\u{0442}\u{0430}\u{0442}\u{0443}\u{0441} \u{0437}\u{0430}\u{0432}\u{0435}\u{0440}\u{0448}\u{0435}\u{043D}\u{043D}\u{044F}" : "Completion"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 126px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_status_verbose == "" ? "--" : root.history_detail_status_verbose; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                        }

                        Rectangle {
                            x: 0px * root.density; y: 166px * root.density; width: parent.width; height: 116px * root.density;
                            background: #111118; border-color: #27272A; border-width: 1px * root.density; border-radius: 12px * root.density;
                            Text { x: 12px * root.density; y: 8px * root.density; width: parent.width - 24px; height: 24px * root.density; text: root.is_ua ? "\u{0415}\u{043D}\u{0435}\u{0440}\u{0433}\u{043E}\u{0441}\u{043F}\u{043E}\u{0436}\u{0438}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Energy"; color: #FFFFFF; font-size: 22px * root.density; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 38px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{0412}\u{0438}\u{0442}\u{0440}\u{0430}\u{0447}\u{0435}\u{043D}\u{043E} \u{043A}\u{0412}\u{0442}\u{00B7}\u{0433}\u{043E}\u{0434}" : "Consumed kWh"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 38px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_energy == "" ? "--" : root.history_detail_energy; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 60px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{0412}\u{0430}\u{0440}\u{0442}\u{0456}\u{0441}\u{0442}\u{044C} \u{0432}\u{0438}\u{043F}\u{0430}\u{043B}\u{0443}" : "Cycle cost"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 60px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_energy_cost == "" ? "--" : root.history_detail_energy_cost; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 82px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{041C}\u{0430}\u{043A}\u{0441}. \u{043D}\u{0430}\u{0432}\u{0430}\u{043D}\u{0442}\u{0430}\u{0436}\u{0435}\u{043D}\u{043D}\u{044F}" : "Peak load"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 82px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_max_load == "" ? "--" : root.history_detail_max_load; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                        }

                        Rectangle {
                            x: 0px * root.density; y: 290px * root.density; width: parent.width; height: 94px * root.density;
                            background: #111118; border-color: #27272A; border-width: 1px * root.density; border-radius: 12px * root.density;
                            Text { x: 12px * root.density; y: 8px * root.density; width: parent.width - 24px; height: 24px * root.density; text: root.is_ua ? "\u{0422}\u{0435}\u{0445}\u{043D}\u{043E}\u{043B}\u{043E}\u{0433}\u{0456}\u{0447}\u{043D}\u{0456} \u{043F}\u{043E}\u{043A}\u{0430}\u{0437}\u{043D}\u{0438}\u{043A}\u{0438}" : "Quality Metrics"; color: #FFFFFF; font-size: 22px * root.density; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 38px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{041C}\u{0430}\u{043A}\u{0441}. \u{0442}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0430}" : "Peak temperature"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 38px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_peak_temp == "" ? "--" : root.history_detail_peak_temp; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 60px * root.density; width: 132px * root.density; height: 18px * root.density; text: root.is_ua ? "\u{0421}\u{0442}\u{0430}\u{0431}\u{0456}\u{043B}\u{044C}\u{043D}\u{0456}\u{0441}\u{0442}\u{044C} \u{043D}\u{0430}\u{043F}\u{0440}\u{0443}\u{0433}\u{0438}" : "Voltage stability"; color: #A1A1AA; font-size: 15px * root.density; }
                            Text { x: 148px * root.density; y: 60px * root.density; width: parent.width - 160px; height: 18px * root.density; text: root.history_detail_voltage_stability == "" ? "--" : root.history_detail_voltage_stability; color: #FFFFFF; font-size: 15px * root.density; horizontal-alignment: right; vertical-alignment: center; }
                        }

                        Rectangle {
                            x: 0px * root.density; y: 392px * root.density; width: parent.width; height: 108px * root.density;
                            background: #111118; border-color: #27272A; border-width: 1px * root.density; border-radius: 12px * root.density;
                            Text { x: 12px * root.density; y: 8px * root.density; width: parent.width - 24px; height: 24px * root.density; text: root.is_ua ? "\u{041A}\u{0440}\u{043E}\u{043A}\u{0438} (\u{043F}\u{043B}\u{0430}\u{043D}/\u{0444}\u{0430}\u{043A}\u{0442})" : "Steps (plan/actual)"; color: #FFFFFF; font-size: 22px * root.density; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px * root.density; y: 34px * root.density; width: parent.width - 24px; height: 70px * root.density; text: root.history_detail_step_plan_actual; color: #FFFFFF; font-size: 15px * root.density; vertical-alignment: top; overflow: elide; }
                        }
                    }
                }
        }

        if (root.view == View.RunningEditor) : Rectangle {
                x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                background: #000000;

                HorizontalBox {
                    x: root.settings_side_gap; y: root.settings_title_y;
                    spacing: 6px;
                    ThermometerIcon { color: #10B981; }
                    Text {
                        text: root.is_ua ? "\u{0420}\u{0435}\u{0434}\u{0430}\u{0433}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F} \u{0432}\u{0438}\u{043F}\u{0430}\u{043B}\u{0443}" : "Firing Edit";
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px * root.density;
                        width: 260px * root.density;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle {
                    x: 420px * root.density; y: 8px * root.density; width: 40px * root.density; height: 28px * root.density;
                    background: #27272A;
                    border-radius: 10px * root.density;
                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_back(); } }
                }

                Rectangle {
                    x: 14px * root.density; y: 46px * root.density; width: 452px * root.density; height: 58px * root.density;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px * root.density;
                    border-radius: 12px * root.density;
                    Text { x: 14px * root.density; y: 8px * root.density; text: root.is_ua ? ("\u{0428}\u{0432}\u{0438}\u{0434}\u{043A}\u{0456}\u{0441}\u{0442}\u{044C} \u{043D}\u{0430}\u{0433}\u{0440}\u{0456}\u{0432}\u{0443} (" + root.rate_unit_label_min + ")") : ("Ramp rate (" + root.rate_unit_label_min + ")"); color: #A1A1AA; font-size: 13px * root.density; }
                    Text { x: 14px * root.density; y: 28px * root.density; text: root.running_edit_rate; color: #FFFFFF; font-size: 18px * root.density; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_rate", -1, root.running_edit_rate); } }
                }

                Rectangle {
                    x: 14px * root.density; y: 112px * root.density; width: 452px * root.density; height: 58px * root.density;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px * root.density;
                    border-radius: 12px * root.density;
                    Text { x: 14px * root.density; y: 8px * root.density; text: root.is_ua ? ("\u{0414}\u{043E}\u{0434}\u{0430}\u{0442}\u{0438} \u{0442}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0443} (" + root.temp_unit_label + ")") : ("Add temperature (" + root.temp_unit_label + ")"); color: #A1A1AA; font-size: 13px * root.density; }
                    Text { x: 14px * root.density; y: 28px * root.density; text: root.running_edit_add_temp; color: #FFFFFF; font-size: 18px * root.density; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_temp", -1, root.running_edit_add_temp); } }
                }

                Rectangle {
                    x: 14px * root.density; y: 178px * root.density; width: 452px * root.density; height: 58px * root.density;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px * root.density;
                    border-radius: 12px * root.density;
                    Text { x: 14px * root.density; y: 8px * root.density; text: root.is_ua ? "\u{0414}\u{043E}\u{0434}\u{0430}\u{0442}\u{0438} \u{0447}\u{0430}\u{0441} (\u{0445}\u{0432})" : "Add hold time (min)"; color: #A1A1AA; font-size: 13px * root.density; }
                    Text { x: 14px * root.density; y: 28px * root.density; text: root.running_edit_add_time; color: #FFFFFF; font-size: 18px * root.density; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_time", -1, root.running_edit_add_time); } }
                }

                Rectangle {
                    x: 304px * root.density; y: 242px * root.density; width: 162px * root.density; height: 28px * root.density;
                    background: #10B981;
                    border-radius: 10px * root.density;
                    Text { text: root.is_ua ? "\u{0417}\u{0431}\u{0435}\u{0440}\u{0435}\u{0433}\u{0442}\u{0438}" : "Apply"; color: #000000; font-family: "PT Sans"; font-size: 14px * root.density; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_apply(); } }
                }
        }

        

        // Settings View
        if (root.view == View.Settings) : Rectangle {
                x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                background: root.c_bg;
                clip: true;

                if (root.settings_page == "wifi") : WifiIcon {
                    x: root.settings_side_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_icon_size) / 2;
                    width: root.settings_icon_size;
                    height: root.settings_icon_size;
                    color: root.wifi_ok ? #10B981 : #52525B;
                }

                if (root.settings_page != "wifi") : SettingsIcon {
                    x: root.settings_side_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_icon_size) / 2;
                    width: root.settings_icon_size;
                    height: root.settings_icon_size;
                    color: #A1A1AA;
                }

                Text {
                    x: root.settings_title_x;
                    y: root.settings_title_y;
                    width: root.settings_title_width;
                    height: root.settings_header_h;
                    text: root.settings_page == "wifi" ? "Wi-Fi"
                        : root.settings_page == "clock" ? (root.is_ua ? "\u{0427}\u{0430}\u{0441} \u{0456} \u{0434}\u{0430}\u{0442}\u{0430}" : "Time & Date")
                        : root.settings_page == "controller_info" ? (root.is_ua ? "\u{0406}\u{043D}\u{0444}\u{043E} \u{043A}\u{043E}\u{043D}\u{0442}\u{0440}\u{043E}\u{043B}\u{043B}\u{0435}\u{0440}\u{0430}" : "Controller Info")
                        : root.settings_page == "display" ? (root.is_ua ? "\u{0420}\u{0435}\u{0436}\u{0438}\u{043C} \u{0432}\u{0456}\u{0434}\u{043E}\u{0431}\u{0440}\u{0430}\u{0436}\u{0435}\u{043D}\u{043D}\u{044F}" : "Display mode")
                        : root.settings_page == "display_hw" ? (root.is_ua ? "\u{0414}\u{0438}\u{0441}\u{043F}\u{043B}\u{0435}\u{0439}" : "Display")
                        : root.settings_page == "fan" ? (root.is_ua ? "\u{0412}\u{0435}\u{043D}\u{0442}\u{0438}\u{043B}\u{044F}\u{0442}\u{043E}\u{0440}" : "Fan")
                        : root.settings_page == "autotune" ? (root.is_ua ? "\u{041D}\u{0430}\u{043B}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Settings")
                        : root.settings_page == "fault" ? (root.is_ua ? "\u{041F}\u{043E}\u{043C}\u{0438}\u{043B}\u{043A}\u{0438}" : "Faults")
                        : root.settings_page == "history" ? (root.is_ua ? "\u{0406}\u{0441}\u{0442}\u{043E}\u{0440}\u{0456}\u{044F}" : "History")
                        : root.settings_page == "fault_logs" ? (root.is_ua ? "\u{041B}\u{043E}\u{0433}\u{0438} \u{043F}\u{043E}\u{043C}\u{0438}\u{043B}\u{043E}\u{043A}" : "Fault Logs")
                        : root.settings_page == "touch" ? (root.is_ua ? "\u{041A}\u{0430}\u{043B}\u{0456}\u{0431}\u{0440}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F} \u{0442}\u{0430}\u{0447}" : "Touch Calibration")
                        : (root.is_ua ? "\u{041D}\u{0430}\u{043B}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Settings");
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px * root.density;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if (root.settings_page != "all" && root.settings_page != "wifi") : UiButton {
                    x: root.settings_back_btn_x;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #1F2937;
                    radius: 10px;
                    label: "<";
                    text_size: 16px;
                    tapped => { root.settings_page = "all"; }
                }

                UiButton {
                    x: root.settings_close_btn_x;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    radius: 10px;
                    label: "X";
                    text_size: 16px;
                    tapped => { root.view = View.Dashboard; }
                }

                if (root.settings_page != "display_hw") : Rectangle {
                    x: root.settings_panel_x; y: root.settings_panel_y;
                    width: root.settings_panel_w; height: root.settings_content_height;
                    background: #00000000;
                    clip: true;

                    Rectangle {
                        x: 0px * root.density;
                        width: root.settings_content_width;
                        height: 232px * root.density;
                        background: #00000000;

                        if (root.settings_page == "all") : Rectangle {
                            width: root.settings_content_width;
                            height: root.settings_card_h * 3 + root.settings_card_gap * 2;
                            background: #00000000;

                            Rectangle {
                                x: 0px * root.density; y: 0px * root.density;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{0420}\u{0435}\u{0436}\u{0438}\u{043C} \u{0432}\u{0456}\u{0434}\u{043E}\u{0431}\u{0440}\u{0430}\u{0436}\u{0435}\u{043D}\u{043D}\u{044F}" : "Display mode";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px * root.density;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "display"; } }
                            }

                            Rectangle {
                                x: root.settings_col_width + root.settings_grid_gap; y: 0px * root.density;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{041D}\u{0430}\u{043B}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Settings";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px * root.density;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "autotune"; } }
                            }

                            Rectangle {
                                x: 0px * root.density; y: root.settings_card_step;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{0414}\u{0438}\u{0441}\u{043F}\u{043B}\u{0435}\u{0439}" : "Display";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px * root.density;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "display_hw"; } }
                            }

                            Rectangle {
                                x: root.settings_col_width + root.settings_grid_gap; y: root.settings_card_step;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{041F}\u{043E}\u{043C}\u{0438}\u{043B}\u{043A}\u{0438}" : "Faults";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px * root.density;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "fault"; } }
                            }

                            Rectangle {
                                x: 0px * root.density; y: root.settings_card_step * 2;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{0406}\u{0441}\u{0442}\u{043E}\u{0440}\u{0456}\u{044F}" : "History";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px * root.density;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.open_history(); } }
                            }

                            Rectangle {
                                x: root.settings_col_width + root.settings_grid_gap; y: root.settings_card_step * 2;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{0406}\u{043D}\u{0444}\u{043E} \u{043A}\u{043E}\u{043D}\u{0442}\u{0440}\u{043E}\u{043B}\u{043B}\u{0435}\u{0440}\u{0430}" : "Controller Info";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px * root.density;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "controller_info"; } }
                            }
                        }

                        if (root.settings_page == "controller_info") : ScrollView {
                            x: 0px * root.density; y: 0px * root.density;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: root.settings_display_row_h * 9 + root.settings_vertical_gap * 8;
                            viewport-x: 0px * root.density;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                            mouse-drag-pan-enabled: true;

                            Rectangle {
                                width: root.settings_content_width;
                                height: root.settings_display_row_h * 9 + root.settings_vertical_gap * 8;
                                background: #00000000;

                                for i in [0, 1, 2, 3, 4, 5, 6, 7, 8] : Rectangle {
                                    y: i * root.settings_display_row_step;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 12px * root.density;

                                    Text {
                                        x: 12px * root.density; y: 0px * root.density; width: 186px * root.density; height: parent.height;
                                        text: i == 0 ? (root.is_ua ? "\u{0412}\u{0435}\u{0440}\u{0441}\u{0456}\u{044F} \u{043F}\u{0440}\u{043E}\u{0448}\u{0438}\u{0432}\u{043A}\u{0438}" : "Firmware")
                                            : i == 1 ? (root.is_ua ? "\u{041E}\u{0417}\u{041F} (Heap)" : "Heap")
                                            : i == 2 ? (root.is_ua ? "\u{041E}\u{0417}\u{041F} (PSRAM)" : "RAM")
                                            : i == 3 ? (root.is_ua ? "\u{0421}\u{0445}\u{043E}\u{0432}\u{0438}\u{0449}\u{0435} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}" : "Program Storage")
                                            : i == 4 ? "Device ID"
                                            : i == 5 ? (root.is_ua ? "\u{0427}\u{0430}\u{0441} \u{043D}\u{0430}\u{043F}\u{0440}\u{0430}\u{0446}\u{044E}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Uptime")
                                            : i == 6 ? (root.is_ua ? "\u{041F}\u{0440}\u{043E}\u{0431}\u{0456}\u{0433} \u{0422}\u{0415}\u{041D}\u{0456}\u{0432}" : "Heating Hours")
                                            : i == 7 ? (root.is_ua ? "\u{0422}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0430} \u{0447}\u{0456}\u{043F}\u{0430}" : "Chip Temp")
                                            : "PZEM-004T";
                                        color: #A1A1AA;
                                        font-family: "PT Sans";
                                        font-size: 14px * root.density;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        x: 208px * root.density; y: 0px * root.density; width: parent.width - (220px * root.density); height: parent.height;
                                        text: i == 0 ? root.controller_info_fw
                                            : i == 1 ? root.controller_info_heap
                                            : i == 2 ? root.controller_info_ram
                                            : i == 3 ? root.controller_info_storage
                                            : i == 4 ? root.controller_info_device_id
                                            : i == 5 ? root.controller_info_uptime
                                            : i == 6 ? root.controller_info_heating_hours
                                            : i == 7 ? root.controller_info_chip_temp
                                            : root.controller_info_pzem;
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 14px * root.density;
                                        horizontal-alignment: right;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }

                        if (root.settings_page == "clock") : Rectangle {
                            x: 0px * root.density;
                            width: root.settings_content_width;
                            height: root.settings_display_row_h * 2 + root.settings_vertical_gap;
                            background: #00000000;

                            Rectangle {
                                y: 0px * root.density;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: root.c_border;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                    text: root.is_ua ? "\u{0427}\u{0430}\u{0441}" : "Time";
                                    color: root.c_muted;
                                    font-size: 16px * root.density;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - (160px * root.density); y: root.settings_display_btn_y; width: 148px * root.density; height: root.settings_btn_height;
                                    background: #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: root.current_time; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("clock_time", -1, root.current_time); } }
                                }
                            }

                            Rectangle {
                                y: root.settings_display_row_step;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: root.c_border;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                    text: root.is_ua ? "\u{0414}\u{0430}\u{0442}\u{0430}" : "Date";
                                    color: root.c_muted;
                                    font-size: 16px * root.density;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - (200px * root.density); y: root.settings_display_btn_y; width: 188px * root.density; height: root.settings_btn_height;
                                    background: #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: root.current_date; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("clock_date", -1, root.current_date); } }
                                }
                            }
                        }

                        if (root.settings_page == "display") : Rectangle {
                            x: 0px * root.density;
                            width: root.settings_content_width;
                            height: root.settings_display_row_h * 3 + root.settings_vertical_gap * 2;
                            background: #00000000;

                            Rectangle {
                                y: 0px * root.density;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                    text: root.is_ua ? "\u{0422}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0430}" : "Temperature";
                                    color: #A1A1AA;
                                    font-size: 16px * root.density;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - (154px * root.density); y: root.settings_display_btn_y; width: 68px * root.density; height: root.settings_btn_height;
                                    background: root.temp_unit == "C" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "\u{00B0}C"; color: root.temp_unit == "C" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.temp_unit = "C"; root.set_temp_unit("C"); } }
                                }
                                Rectangle {
                                    x: parent.width - (80px * root.density); y: root.settings_display_btn_y; width: 68px * root.density; height: root.settings_btn_height;
                                    background: root.temp_unit == "F" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "\u{00B0}F"; color: root.temp_unit == "F" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.temp_unit = "F"; root.set_temp_unit("F"); } }
                                }
                            }

                            Rectangle {
                                y: root.settings_display_row_step;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                    text: root.is_ua ? "\u{0427}\u{0430}\u{0441}" : "Time";
                                    color: #A1A1AA;
                                    font-size: 16px * root.density;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - (154px * root.density); y: root.settings_display_btn_y; width: 68px * root.density; height: root.settings_btn_height;
                                    background: root.time_format == "24" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "24h"; color: root.time_format == "24" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.time_format = "24"; root.set_time_format("24"); } }
                                }
                                Rectangle {
                                    x: parent.width - (80px * root.density); y: root.settings_display_btn_y; width: 68px * root.density; height: root.settings_btn_height;
                                    background: root.time_format == "12" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "12h"; color: root.time_format == "12" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.time_format = "12"; root.set_time_format("12"); } }
                                }
                            }

                            Rectangle {
                                y: root.settings_display_row_step * 2;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 12px * root.density;
                                Text {
                                    x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                    text: root.is_ua ? "\u{0414}\u{0430}\u{0442}\u{0430}" : "Date";
                                    color: #A1A1AA;
                                    font-size: 16px * root.density;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - (216px * root.density); y: root.settings_display_btn_y; width: 64px * root.density; height: root.settings_btn_height;
                                    background: root.date_format == "DMY" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "DD.MM"; color: root.date_format == "DMY" ? #000000 : #FFFFFF; font-size: 13px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "DMY"; root.set_date_format("DMY"); } }
                                }
                                Rectangle {
                                    x: parent.width - (146px * root.density); y: root.settings_display_btn_y; width: 64px * root.density; height: root.settings_btn_height;
                                    background: root.date_format == "MDY" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "MM/DD"; color: root.date_format == "MDY" ? #000000 : #FFFFFF; font-size: 13px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "MDY"; root.set_date_format("MDY"); } }
                                }
                                Rectangle {
                                    x: parent.width - (76px * root.density); y: root.settings_display_btn_y; width: 64px * root.density; height: root.settings_btn_height;
                                    background: root.date_format == "YMD" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "YYYY"; color: root.date_format == "YMD" ? #000000 : #FFFFFF; font-size: 13px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "YMD"; root.set_date_format("YMD"); } }
                                }
                            }
                        }

                        if (root.settings_page == "fan") : Rectangle {
                        width: root.settings_content_width; height: root.settings_fan_card_h;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px * root.density;
                        border-radius: 12px * root.density;


                        Text {
                            x: root.settings_inner_pad; y: root.settings_label_y;
                            text: root.fan_manual
                                ? (root.is_ua ? "\u{0420}\u{0443}\u{0447}\u{043D}\u{0438}\u{0439} \u{0440}\u{0435}\u{0436}\u{0438}\u{043C}" : "Manual mode")
                                : (root.is_ua ? "\u{0412}\u{0438}\u{043C}\u{043A}\u{043D}\u{0435}\u{043D}\u{043E}" : "Off");
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px * root.density;
                        }

                        Rectangle {
                            x: parent.width - root.settings_inner_pad - root.settings_fan_toggle_w;
                            y: root.settings_label_y;
                            width: root.settings_fan_toggle_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #10B981 : #27272A;
                            border-radius: root.settings_btn_radius;
                            Text {
                                text: root.fan_manual ? (root.is_ua ? "\u{0412}\u{041A}\u{041B}" : "ON") : (root.is_ua ? "\u{0412}\u{0418}\u{041A}\u{041B}" : "OFF");
                                color: root.fan_manual ? #000000 : #FFFFFF;
                                font-family: "PT Sans";
                                font-size: root.settings_btn_text_size;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let new_manual = !root.fan_manual;
                                    root.fan_manual = new_manual;
                                    if (new_manual && root.fan_power == 0) { root.fan_power = 100; }
                                    if (!new_manual) { root.fan_power = 0; }
                                    root.fan_manual_changed(new_manual);
                                    root.fan_power_changed(root.fan_power);
                                }
                            }
                        }

                        Rectangle { // -
                            x: parent.width - root.settings_inner_pad - (root.settings_fan_minus_w + root.settings_fan_value_w + root.settings_fan_plus_w);
                            y: root.settings_fan_controls_y;
                            width: root.settings_fan_minus_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: "\u{0432}\u{20AC}'"; color: #FFFFFF; font-family: "PT Sans"; font-size: 26px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        root.fan_power = max(root.fan_power - 10, 0);
                                        root.fan_power_changed(root.fan_power);
                                    }
                                }
                            }
                        }

                        Rectangle { // % (tap for keypad)
                            x: parent.width - root.settings_inner_pad - (root.settings_fan_value_w + root.settings_fan_plus_w);
                            y: root.settings_fan_controls_y;
                            width: root.settings_fan_value_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.fan_power + "%"; color: #FFFFFF; font-family: "PT Sans"; font-size: 18px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        if (!(root.kb_visible && root.kb_field == "fan" && root.kb_step_index == -1)) {
                                            root.kb_open("fan", -1, root.fan_power + "");
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { // +
                            x: parent.width - root.settings_inner_pad - root.settings_fan_plus_w;
                            y: root.settings_fan_controls_y;
                            width: root.settings_fan_plus_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: "+"; color: #FFFFFF; font-family: "PT Sans"; font-size: 24px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        root.fan_power = min(root.fan_power + 10, 100);
                                        root.fan_power_changed(root.fan_power);
                                    }
                                }
                            }
                        }
                    }

                        if (root.settings_page == "autotune") : ScrollView {
                            x: 0px * root.density; y: 0px * root.density;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: root.settings_display_row_step * 4 + root.settings_autotune_action_h + 8px;
                            viewport-x: 0px * root.density;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                            mouse-drag-pan-enabled: true;

                            Rectangle {
                                x: 0px * root.density; y: 0px * root.density;
                                width: root.settings_content_width;
                                height: root.settings_display_row_step * 4 + root.settings_autotune_action_h + 8px;
                                background: #00000000;

                                Rectangle {
                                    y: 0px * root.density;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 12px * root.density;
                                    Text {
                                        x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                        text: root.is_ua ? "\u{0417}\u{043C}\u{0456}\u{0449}\u{0435}\u{043D}\u{043D}\u{044F} \u{0442}\u{0435}\u{0440}\u{043C}\u{043E}\u{043F}\u{0430}\u{0440}\u{0438}" : "Thermocouple offset";
                                        color: #A1A1AA;
                                        font-size: 16px * root.density;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - (156px * root.density); y: root.settings_display_btn_y; width: 144px * root.density; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.thermocouple_offset + root.temp_unit_label; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("thermocouple_offset", -1, root.thermocouple_offset + ""); } }
                                    }
                                }

                                Rectangle {
                                    y: root.settings_display_row_step;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 12px * root.density;
                                    Text {
                                        x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                        text: root.is_ua ? "\u{041F}\u{043E}\u{0442}\u{0443}\u{0436}\u{043D}\u{0456}\u{0441}\u{0442}\u{044C} \u{043F}\u{0435}\u{0447}\u{0456}" : "Kiln power";
                                        color: #A1A1AA;
                                        font-size: 16px * root.density;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - (156px * root.density); y: root.settings_display_btn_y; width: 144px * root.density; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.kiln_wattage + " W"; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("kiln_wattage", -1, root.kiln_wattage + ""); } }
                                    }
                                }

                                Rectangle {
                                    y: root.settings_display_row_step * 2;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 12px * root.density;
                                    Text {
                                        x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                        text: root.is_ua ? "\u{041C}\u{0430}\u{043A}\u{0441}. \u{0442}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0430}" : "Max temperature";
                                        color: #A1A1AA;
                                        font-size: 16px * root.density;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - (156px * root.density); y: root.settings_display_btn_y; width: 144px * root.density; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.schedule_target_max_c + root.temp_unit_label; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("max_temp", -1, root.schedule_target_max_c + ""); } }
                                    }
                                }

                                Rectangle {
                                    y: root.settings_display_row_step * 3;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 12px * root.density;
                                    Text {
                                        x: 12px * root.density; y: 0px * root.density; width: 220px * root.density; height: parent.height;
                                        text: root.is_ua ? "\u{0426}\u{0456}\u{043B}\u{044C} \u{0430}\u{0432}\u{0442}\u{043E}\u{043D}\u{0430}\u{043B}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Autotune target";
                                        color: #A1A1AA;
                                        font-size: 16px * root.density;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - (156px * root.density); y: root.settings_display_btn_y; width: 144px * root.density; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.autotune_target_c + root.temp_unit_label; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "autotune" && root.kb_step_index == -1)) {
                                                    root.kb_open("autotune", -1, root.autotune_target_c + "");
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    x: root.settings_inner_pad;
                                    y: root.settings_display_row_step * 4;
                                    width: root.settings_content_width - root.settings_inner_pad * 2;
                                    height: root.settings_autotune_action_h;
                                    background: root.status_label == "TUNING" ? #7F1D1D : (root.fault_active ? #18181B : #14532D);
                                    border-radius: root.settings_btn_radius;
                                    Text {
                                        text: root.status_label == "TUNING"
                                            ? (root.is_ua ? "\u{0417}\u{0443}\u{043F}\u{0438}\u{043D}\u{0438}\u{0442}\u{0438} \u{0430}\u{0432}\u{0442}\u{043E}\u{043D}\u{0430}\u{043B}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Stop autotune")
                                            : (root.is_ua ? "\u{0417}\u{0430}\u{043F}\u{0443}\u{0441}\u{0442}\u{0438}\u{0442}\u{0438} \u{0430}\u{0432}\u{0442}\u{043E}\u{043D}\u{0430}\u{043B}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Start autotune");
                                        color: root.status_label == "TUNING" ? #FFFFFF : (root.fault_active ? #71717A : #FFFFFF);
                                        font-family: "PT Sans";
                                        font-size: 14px * root.density;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    TouchArea {
                                        width: parent.width; height: parent.height;
                                        clicked => {
                                            if (root.status_label == "TUNING") {
                                                root.autotune_stop();
                                            } else if (!root.fault_active) {
                                                root.autotune_start(root.autotune_target_c);
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if (root.settings_page == "touch") : UiButton {
                        x: root.settings_inner_pad;
                        width: root.settings_content_width - root.settings_inner_pad * 2; height: root.settings_action_btn_h;
                        background: #27272A;
                        radius: root.settings_action_btn_radius;
                        label: root.is_ua ? "\u{041A}\u{0430}\u{043B}\u{0456}\u{0431}\u{0440}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F} \u{0442}\u{0430}\u{0447}" : "Touch Calibration";
                        text_size: root.settings_btn_text_size;
                        tapped => { root.show_touch_confirm = true; }
                        }

                        if (root.settings_page == "history") : ScrollView {
                            x: 0px * root.density; y: 0px * root.density;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: (root.history_items.length + 1) * root.settings_list_step;
                            viewport-x: 0px * root.density;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            mouse-drag-pan-enabled: true;

                            VerticalBox {
                                width: root.settings_content_width;
                                spacing: root.settings_grid_gap;
                                for item[i] in root.history_items : Rectangle {
                                    width: root.settings_content_width; height: root.settings_list_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 12px * root.density;
                                    clip: true;

                                    Text {
                                        x: 12px * root.density; y: 10px * root.density; width: parent.width - 220px; height: 24px * root.density;
                                        text: item.title;
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 16px * root.density;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    if (item.status_code != "") : Rectangle {
                                        x: parent.width - (258px * root.density); y: 8px * root.density; width: 104px * root.density; height: 28px * root.density;
                                        background: item.status_code == "COMPLETE" ? #14532D
                                            : item.status_code == "STOPPED" ? #3F3F46
                                            : #7F1D1D;
                                        border-radius: 10px * root.density;

                                        Text {
                                            x: 0px * root.density; y: 0px * root.density; width: parent.width; height: parent.height;
                                            text: item.status;
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 13px * root.density;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }

                                    if (item.id != "") : UiButton {
                                        x: parent.width - (142px * root.density); y: 8px * root.density; width: 88px * root.density; height: 28px * root.density;
                                        background: #1F2937;
                                        radius: 10px;
                                        label: root.is_ua ? "\u{0414}\u{0435}\u{0442}\u{0430}\u{043B}\u{0456}" : "Details";
                                        text_size: 12px;
                                        tapped => { root.open_history_detail(i); }
                                    }

                                    if (item.id != "") : Rectangle {
                                        x: parent.width - (46px * root.density); y: 8px * root.density;
                                        width: 28px * root.density; height: 28px * root.density;
                                        background: #10B981;
                                        border-radius: 14px * root.density;
                                        Rectangle { x: 7px * root.density; y: 18px * root.density; width: 14px * root.density; height: 1px * root.density; background: #FFFFFF; border-radius: 1px * root.density; }
                                        Rectangle { x: 7px * root.density; y: 14px * root.density; width: 3px * root.density; height: 3px * root.density; background: #FFFFFF; border-radius: 2px * root.density; }
                                        Rectangle { x: 12px * root.density; y: 11px * root.density; width: 3px * root.density; height: 3px * root.density; background: #FFFFFF; border-radius: 2px * root.density; }
                                        Rectangle { x: 17px * root.density; y: 8px * root.density; width: 3px * root.density; height: 3px * root.density; background: #FFFFFF; border-radius: 2px * root.density; }
                                        Rectangle { x: 8px * root.density; y: 13px * root.density; width: 5px * root.density; height: 1px * root.density; background: #FFFFFF; border-radius: 1px * root.density; }
                                        Rectangle { x: 13px * root.density; y: 10px * root.density; width: 5px * root.density; height: 1px * root.density; background: #FFFFFF; border-radius: 1px * root.density; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.open_history_graph(i); } }
                                    }

                                    Text {
                                        x: 12px * root.density; y: 38px * root.density; width: parent.width - 24px; height: 18px * root.density;
                                        text: item.subtitle;
                                        color: #A1A1AA;
                                        font-family: "PT Sans";
                                        font-size: 12px * root.density;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                }
                            }
                        }

                        if (root.settings_page == "fault_logs") : ScrollView {
                            x: 0px * root.density; y: 0px * root.density;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: (root.fault_log_items.length + 1) * root.settings_list_step;
                            viewport-x: 0px * root.density;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            mouse-drag-pan-enabled: true;

                            VerticalBox {
                                width: root.settings_content_width;
                                spacing: root.settings_grid_gap;
                                for item[i] in root.fault_log_items : Rectangle {
                                    width: root.settings_content_width; height: root.settings_list_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 12px * root.density;
                                    clip: true;

                                    Text {
                                        x: 12px * root.density; y: 10px * root.density; width: parent.width - 120px; height: 24px * root.density;
                                        text: item.title;
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 15px * root.density;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    if (item.status != "") : Rectangle {
                                        x: parent.width - (196px * root.density); y: 10px * root.density; width: 92px * root.density; height: 24px * root.density;
                                        background: item.status == "OK" ? #14532D : #7F1D1D;
                                        border-radius: 8px * root.density;

                                        Text {
                                            x: 0px * root.density; y: 0px * root.density; width: parent.width; height: parent.height;
                                            text: item.status;
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 12px * root.density;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }

                                    UiButton {
                                        x: parent.width - (96px * root.density); y: 10px * root.density; width: 84px * root.density; height: 24px * root.density;
                                        background: #1F2937;
                                        radius: 8px;
                                        label: root.is_ua ? "\u{0414}\u{0435}\u{0442}\u{0430}\u{043B}\u{0456}" : "Details";
                                        text_size: 11px;
                                        tapped => { root.open_fault_log_detail(i); }
                                    }

                                    Text {
                                        x: 12px * root.density; y: 38px * root.density; width: parent.width - 24px; height: 18px * root.density;
                                        text: item.subtitle;
                                        color: #A1A1AA;
                                        font-family: "PT Sans";
                                        font-size: 12px * root.density;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                        if (root.settings_page == "wifi") : Rectangle {
                            x: 0px * root.density; y: 0px * root.density;
                            width: root.settings_content_width; height: 146px * root.density;
                            background: #0F0F0F;
                            border-color: #27272A;
                            border-width: 1px * root.density;
                            border-radius: 12px * root.density;

                            Text {
                                x: 12px * root.density; y: 10px * root.density;
                                text: "Wi\u{2011}Fi";
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 16px * root.density;
                                font-weight: 700;
                            }

                            Rectangle {
                                x: parent.width - root.settings_inner_pad - 106px * root.density; y: 8px * root.density; width: 106px * root.density; height: 24px * root.density;
                                background: root.wifi_ok ? #073B2A : #2A2A2F;
                                border-radius: 8px * root.density;
                                Text {
                                    text: root.wifi_ok ? "Connected" : "Disconnected";
                                    color: root.wifi_ok ? #10B981 : #A1A1AA;
                                    font-family: "PT Sans";
                                    font-size: 13px * root.density;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Text {
                                x: 12px * root.density; y: 38px * root.density; width: parent.width - 24px;
                                text: root.wifi_selected_ssid == ""
                                    ? (root.is_ua ? "\u{041E}\u{0431}\u{0435}\u{0440}\u{0456}\u{0442}\u{044C} \u{043C}\u{0435}\u{0440}\u{0435}\u{0436}\u{0443} \u{0437}\u{0456} \u{0441}\u{043F}\u{0438}\u{0441}\u{043A}\u{0443}" : "Pick a network from list")
                                    : root.wifi_selected_ssid;
                                color: #A1A1AA;
                                font-family: "PT Sans";
                                font-size: 13px * root.density;
                                overflow: elide;
                            }

                            Rectangle {
                                x: root.settings_inner_pad; y: 58px * root.density; width: parent.width - root.settings_inner_pad * 2 - 116px * root.density; height: 36px * root.density;
                                background: #18181B;
                                border-color: #27272A;
                                border-width: 1px * root.density;
                                border-radius: 9px * root.density;
                                Text {
                                    x: 10px * root.density; y: 9px * root.density;
                                    width: parent.width - 20px;
                                    text: root.wifi_server_url;
                                    color: #60A5FA;
                                    font-family: "PT Sans";
                                    font-size: 12px * root.density;
                                    overflow: elide;
                                }
                            }

                            UiButton {
                                x: parent.width - root.settings_inner_pad - 108px * root.density; y: 56px * root.density; width: 108px * root.density; height: 40px * root.density;
                                background: #1F2937;
                                radius: 9px;
                                label: "QR";
                                bold: true;
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_qr_toggle(); }
                            }

                            UiButton {
                                x: root.settings_inner_pad; y: 104px * root.density; width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                                background: #27272A;
                                radius: 9px;
                                label: root.wifi_ok ? (root.is_ua ? "\u{0417}\u{043C}\u{0456}\u{043D}\u{0438}\u{0442}\u{0438} \u{043C}\u{0435}\u{0440}\u{0435}\u{0436}\u{0443}" : "Change network")
                                                  : (root.is_ua ? "\u{041F}\u{043E}\u{0448}\u{0443}\u{043A} \u{043C}\u{0435}\u{0440}\u{0435}\u{0436}\u{0456}" : "Search networks");
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_open_picker(); }
                            }

                            UiButton {
                                x: root.settings_inner_pad + root.settings_two_col_btn_w + root.settings_grid_gap; y: 104px * root.density; width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                                background: #7F1D1D;
                                radius: 9px;
                                label: root.is_ua ? "\u{0412}\u{0456}\u{0434}\u{043A}\u{043B}\u{044E}\u{0447}\u{0438}\u{0442}\u{0438} Wi\u{2011}Fi" : "Disconnect Wi\u{2011}Fi";
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_disconnect(); }
                            }
                        }


                    }
                }

                if (root.settings_page == "fault") : Rectangle {
                    x: root.settings_panel_x; y: root.settings_panel_y;
                    width: root.settings_panel_w; height: root.settings_display_row_h * 2 + root.settings_vertical_gap;
                    background: #00000000;

                    Rectangle {
                        y: 0px * root.density;
                        width: parent.width; height: root.settings_display_row_h;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px * root.density;
                        border-radius: 12px * root.density;

                        Text {
                            x: 12px * root.density; y: 0px * root.density; width: parent.width - 24px; height: parent.height;
                            text: root.fault_active
                                ? (root.fault_reason == "" ? (root.is_ua ? "\u{041F}\u{043E}\u{043C}\u{0438}\u{043B}\u{043A}\u{0430} \u{0431}\u{0435}\u{0437} \u{043E}\u{043F}\u{0438}\u{0441}\u{0443}" : "Fault without details") : root.fault_reason)
                                : (root.is_ua ? "\u{041D}\u{0435}\u{043C}\u{0430}\u{0454} \u{0430}\u{043A}\u{0442}\u{0438}\u{0432}\u{043D}\u{043E}\u{0457} \u{043F}\u{043E}\u{043C}\u{0438}\u{043B}\u{043A}\u{0438}" : "No active fault");
                            color: root.fault_active ? #FCA5A5 : #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px * root.density;
                            overflow: elide;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        y: root.settings_display_row_step;
                        width: parent.width; height: root.settings_display_row_h;
                        background: #00000000;

                        UiButton {
                            x: root.settings_inner_pad; y: root.settings_display_btn_y;
                            width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                            background: root.fault_active ? #7F1D1D : #18181B;
                            foreground: root.fault_active ? #FFFFFF : #71717A;
                            radius: root.settings_action_btn_radius;
                            label: root.is_ua ? "\u{0421}\u{043A}\u{0438}\u{043D}\u{0443}\u{0442}\u{0438} \u{043F}\u{043E}\u{043C}\u{0438}\u{043B}\u{043A}\u{0443}" : "Clear Fault";
                            text_size: root.settings_btn_text_size;
                            tapped => {
                                if (root.fault_active) {
                                    root.clear_fault();
                                }
                            }
                        }

                        UiButton {
                            x: root.settings_inner_pad + root.settings_two_col_btn_w + root.settings_grid_gap; y: root.settings_display_btn_y;
                            width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                            background: #1F2937;
                            radius: root.settings_action_btn_radius;
                            label: root.is_ua ? "\u{041B}\u{043E}\u{0433}\u{0438} \u{043F}\u{043E}\u{043C}\u{0438}\u{043B}\u{043E}\u{043A}" : "Fault Logs";
                            text_size: root.settings_btn_text_size;
                            tapped => { root.open_fault_logs(); }
                        }
                    }
                }

                // (scrollbar hidden)
                if (root.settings_page == "display_hw") : Rectangle {
                    x: root.settings_panel_x; y: root.settings_panel_y; width: root.settings_panel_w;
                    height: root.settings_display_hw_h;
                    background: #00000000;

                    Rectangle {
                        y: 0px * root.density;
                        width: root.settings_panel_w; height: root.settings_primary_card_h;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px * root.density;
                        border-radius: 12px * root.density;
                        Text { x: root.settings_inner_pad; y: root.settings_label_y; text: root.is_ua ? "\u{042F}\u{0441}\u{043A}\u{0440}\u{0430}\u{0432}\u{0456}\u{0441}\u{0442}\u{044C}" : "Brightness"; color: #A1A1AA; font-size: 13px * root.density; }
                        Rectangle {
                            x: root.settings_inner_pad; y: root.settings_display_hw_controls_y; width: root.settings_display_hw_step_w; height: root.settings_btn_height;
                            background: #27272A;
                            border-radius: root.settings_btn_radius;
                            Text { text: "-"; color: #FFFFFF; font-family: "PT Sans"; font-size: 22px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let v = max(root.display_brightness - 10, 50);
                                    root.display_brightness = v;
                                    root.display_brightness_changed(v);
                                }
                            }
                        }
                        Rectangle {
                            x: root.settings_inner_pad + root.settings_display_hw_step_w + root.settings_grid_gap;
                            y: root.settings_display_hw_controls_y;
                            width: root.settings_display_hw_value_w; height: root.settings_btn_height;
                            background: #1F2937;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.display_brightness + "%"; color: #FFFFFF; font-family: "PT Sans"; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Rectangle {
                            x: root.settings_inner_pad + root.settings_display_hw_step_w + root.settings_grid_gap + root.settings_display_hw_value_w + root.settings_grid_gap;
                            y: root.settings_display_hw_controls_y;
                            width: root.settings_display_hw_step_w; height: root.settings_btn_height;
                            background: #27272A;
                            border-radius: root.settings_btn_radius;
                            Text { text: "+"; color: #FFFFFF; font-family: "PT Sans"; font-size: 22px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let v = min(root.display_brightness + 10, 100);
                                    root.display_brightness = v;
                                    root.display_brightness_changed(v);
                                }
                            }
                        }
                        Rectangle {
                            x: root.settings_inner_pad + root.settings_display_hw_step_w + root.settings_grid_gap + root.settings_display_hw_value_w + root.settings_grid_gap + root.settings_display_hw_step_w + root.settings_grid_gap;
                            y: root.settings_display_hw_controls_y;
                            width: root.settings_display_hw_max_w; height: root.settings_btn_height;
                            background: #10B981;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.is_ua ? "\u{041C}\u{0430}\u{043A}\u{0441}" : "Max"; color: #000000; font-family: "PT Sans"; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    root.display_brightness = 100;
                                    root.display_brightness_changed(100);
                                }
                            }
                        }
                    }

                    UiButton {
                        y: root.settings_secondary_row_y;
                        x: 0px * root.density;
                        width: root.settings_panel_w; height: root.settings_display_hw_calib_h;
                        background: #27272A;
                        radius: root.settings_action_btn_radius;
                        label: root.is_ua ? "\u{041A}\u{0430}\u{043B}\u{0456}\u{0431}\u{0440}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F} \u{0434}\u{0438}\u{0441}\u{043F}\u{043B}\u{0435}\u{044E}" : "Display calibration";
                        text_size: root.settings_btn_text_size;
                        tapped => { root.show_touch_confirm = true; }
                    }
                }

                if (root.wifi_qr_visible) : Rectangle {
                    x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                    background: #000000D0;
                    z: 2100;

                    Rectangle {
                        x: 16px * root.density; y: 12px * root.density; width: root.screen_w - 32px * root.density; height: 252px * root.density;
                        background: #00000000;
                        border-width: 0px * root.density;
                        border-radius: 0px * root.density;

                        Image {
                            x: (parent.width - 210px * root.density) / 2; y: 24px * root.density; width: 210px * root.density; height: 210px * root.density;
                            source: root.wifi_qr_image;
                        }

                        UiButton {
                            x: parent.width - 42px * root.density; y: 8px * root.density; width: 38px * root.density; height: 28px * root.density;
                            background: #27272A;
                            radius: 8px;
                            label: "X";
                            text_size: 16px;
                            tapped => { root.wifi_qr_toggle(); }
                        }

                        Text {
                            x: 12px * root.density; y: 234px * root.density; width: parent.width - 24px * root.density; height: 16px * root.density;
                            text: root.wifi_qr_hint;
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 11px * root.density;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                    }
                }

                if (root.wifi_picker_visible) : Rectangle {
                    x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                    background: #000000CC;
                    z: 2000;

                    Rectangle {
                        x: 16px * root.density; y: 12px * root.density; width: root.screen_w - 32px * root.density; height: 252px * root.density;
                        background: #00000000;
                        border-width: 0px * root.density;
                        border-radius: 0px * root.density;

                        Text {
                            x: 12px * root.density; y: 10px * root.density;
                            text: root.is_ua ? "\u{0412}\u{0438}\u{0431}\u{0456}\u{0440} Wi\u{2011}Fi \u{043C}\u{0435}\u{0440}\u{0435}\u{0436}\u{0456}" : "Select Wi\u{2011}Fi network";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px * root.density;
                        }

                        UiButton {
                            x: parent.width - 42px * root.density; y: 8px * root.density; width: 38px * root.density; height: 28px * root.density;
                            background: #27272A;
                            radius: 8px;
                            label: "X";
                            text_size: 16px;
                            tapped => { root.wifi_picker_visible = false; }
                        }

                        if (root.wifi_scan_busy) : Text {
                            x: 12px * root.density; y: 44px * root.density;
                            text: root.is_ua ? "\u{041F}\u{043E}\u{0448}\u{0443}\u{043A} \u{043C}\u{0435}\u{0440}\u{0435}\u{0436}..." : "Scanning networks...";
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px * root.density;
                        }

                        if (!root.wifi_scan_busy && root.wifi_networks.length == 0) : Text {
                            x: 12px * root.density; y: 44px * root.density;
                            text: root.is_ua ? "\u{041C}\u{0435}\u{0440}\u{0435}\u{0436} \u{043D}\u{0435} \u{0437}\u{043D}\u{0430}\u{0439}\u{0434}\u{0435}\u{043D}\u{043E}" : "No networks found";
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px * root.density;
                        }

                        if (!root.wifi_scan_busy && root.wifi_networks.length > 0) : ScrollView {
                            x: 8px * root.density; y: 40px * root.density; width: parent.width - 16px * root.density; height: 204px * root.density;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            mouse-drag-pan-enabled: true;

                            VerticalBox {
                                spacing: 4px;
                                for net in root.wifi_networks : Rectangle {
                                    width: root.screen_w - 50px * root.density; height: 38px * root.density;
                                    background: #18181B;
                                    border-color: #27272A;
                                    border-width: 1px * root.density;
                                    border-radius: 8px * root.density;

                                    Text {
                                        x: 8px * root.density; y: 9px * root.density;
                                        text: net.ssid + " (" + net.rssi + " dBm)";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 14px * root.density;
                                    }

                                    TouchArea {
                                        width: parent.width; height: parent.height;
                                        clicked => {
                                            root.wifi_selected_ssid = net.ssid;
                                            root.wifi_password = "";
                                            root.kb_open("wifi_pass", -1, "");
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
        }

        // Editor View


        if (root.view == View.Editor) : Rectangle {
                x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.page_content_h;
                background: root.c_bg;



                Rectangle {
                    x: root.settings_side_gap; y: root.settings_title_y;
                    width: root.settings_editor_content_w;
                    height: root.settings_header_h;


                    background: #000000;



                    border-color: #27272A;



                    border-width: 1px * root.density;



                    border-radius: root.settings_btn_radius;



                    property <string> name_display: (root.kb_visible && root.kb_field == "name") ? root.kb_value : root.selected_schedule_name;

                    TextInput { visible: false;
                        x: 6px * root.density; y: 0px * root.density;
                        width: parent.width - 12px; height: parent.height;



                        text: parent.name_display;



                        color: #FFFFFF;



                        font-family: "PT Sans";



                        font-size: 18px * root.density;


                        input-type: InputType.text;



                    }

                    Text {
                        x: 6px * root.density; y: 0px * root.density;
                        width: parent.width - 12px; height: parent.height;
                        text: parent.name_display;
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px * root.density;
                        font-weight: 700;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                    }

                    if (self.name_display == "") : Text {
                        x: 8px * root.density; y: 0px * root.density;
                        height: parent.height;
                        text: root.is_ua ? "\u{041D}\u{0430}\u{0437}\u{0432}\u{0430} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0438}" : "Program Name";



                        color: #71717A;



                        font-family: "PT Sans";



                        font-size: 14px * root.density;


                    }

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            if (!(root.kb_visible && root.kb_field == "name")) {
                                root.kb_open("name", -1, root.selected_schedule_name);
                            }
                        }
                    }



                }



                Rectangle {
                    x: root.screen_w - root.settings_side_gap - root.settings_nav_btn_w - root.settings_nav_gap - (132px * root.density);
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: 132px * root.density; height: root.settings_nav_btn_h;
                    background: #10B981;
                    border-radius: root.settings_action_btn_radius;



                    Text { text: root.is_ua ? "\u{0417}\u{0431}\u{0435}\u{0440}\u{0435}\u{0433}\u{0442}\u{0438}" : "Save"; color: #000000; font-family: "PT Sans"; font-size: 16px * root.density; horizontal-alignment: center; vertical-alignment: center; }


                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.editor_save(); } }



                }



                Rectangle {
                    x: root.screen_w - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    border-radius: root.settings_action_btn_radius;



                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.editor_back(); } }



                }



                ScrollView {
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.settings_content_width;
                    height: parent.height - root.settings_content_y - root.settings_side_gap;
                    viewport-width: self.width;
                    viewport-height: root.editor_steps.length == 0
                        ? (root.settings_list_row_h + 44px + root.settings_grid_gap * 3)
                        : (root.editor_steps.length * 92px + 44px + root.editor_steps.length * root.settings_grid_gap + root.settings_grid_gap * 2);
                    viewport-x: 0px * root.density;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                    mouse-drag-pan-enabled: true;
                    VerticalBox {
                        width: root.settings_content_width;
                        spacing: root.settings_grid_gap;
                        if (root.editor_steps.length == 0) : Rectangle {
                            width: root.screen_w - root.settings_side_gap * 4; height: root.settings_list_row_h;



                            background: #000000;



                            border-color: #27272A;



                            border-width: 1px * root.density;



                            border-radius: 12px * root.density;



                            Text { text: root.is_ua ? "\u{0429}\u{0435} \u{043D}\u{0435} \u{0434}\u{043E}\u{0434}\u{0430}\u{043D}\u{043E} \u{0436}\u{043E}\u{0434}\u{043D}\u{043E}\u{0433}\u{043E} \u{043A}\u{0440}\u{043E}\u{043A}\u{0443}" : "No steps added yet"; color: #A1A1AA; horizontal-alignment: center; vertical-alignment: center; }



                        }



                        for step[i] in root.editor_steps : Rectangle {
                            width: root.screen_w - root.settings_side_gap * 4; height: 92px * root.density;


                            background: #0F0F0F;



                            border-color: #27272A;



                            border-width: 1px * root.density;



                            border-radius: 10px * root.density;



                            property <length> segment_pad_left: 6px;
                            property <length> segment_index_w: 28px;
                            property <length> segment_delete_w: 30px;
                            property <length> segment_right_pad: 8px;
                            property <length> segment_fields_x: segment_pad_left + segment_index_w + 8px;
                            property <length> segment_field_w: (parent.width - segment_fields_x - segment_delete_w - segment_right_pad - root.settings_grid_gap * 2) / 3;

                            Rectangle {
                                x: segment_pad_left;
                                y: (parent.height - segment_index_w) / 2;
                                width: segment_index_w; height: segment_index_w;
                                background: (!root.is_idle && i == root.step_index) ? #10B981 : #27272A;
                                border-radius: segment_index_w / 2;
                                Text { text: (i + 1); color: (!root.is_idle && i == root.step_index) ? #000000 : #A1A1AA; font-size: 12px * root.density; horizontal-alignment: center; vertical-alignment: center; }
                            }



                            // Center the labels+values as a single block inside the segment row.
                            HorizontalBox {
                                x: segment_fields_x;
                                spacing: root.settings_grid_gap;



                                VerticalBox {



                                    width: segment_field_w;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? ("\u{0428}\u{0432}\u{0438}\u{0434}. (" + root.rate_unit_label + ")") : ("Rate (" + root.rate_unit_label + ")"); color: #71717A; font-size: 14px * root.density; }


                                    Rectangle {
                                        width: segment_field_w; height: 42px * root.density;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px * root.density;



                                        border-radius: 8px * root.density;


                                        TextInput { visible: false;
                                            x: 6px * root.density; y: 4px * root.density;


                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.rate + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px * root.density;



                                            input-type: InputType.number;



                                            edited => { root.editor_rate_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.rate + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px * root.density;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "rate" && root.kb_step_index == i)) {
                                                    root.kb_open("rate", i, step.rate + "");
                                                }
                                            }
                                        }


                                    }



                                }



                                VerticalBox {



                                    width: segment_field_w;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? ("\u{0422}\u{0435}\u{043C}\u{043F}. (" + root.temp_unit_label + ")") : ("Target (" + root.temp_unit_label + ")"); color: #71717A; font-size: 14px * root.density; }


                                    Rectangle {
                                        width: segment_field_w; height: 42px * root.density;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px * root.density;



                                        border-radius: 8px * root.density;


                                        TextInput { visible: false;


                                            x: 6px * root.density; y: 4px * root.density;



                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.target + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px * root.density;



                                            input-type: InputType.number;



                                            edited => { root.editor_target_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.target + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px * root.density;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "target" && root.kb_step_index == i)) {
                                                    root.kb_open("target", i, step.target + "");
                                                }
                                            }
                                        }


                                    }



                                }



                                VerticalBox {



                                    width: segment_field_w;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? "\u{0412}\u{0438}\u{0442}\u{0440}. (\u{0445}\u{0432})" : "Hold (min)"; color: #71717A; font-size: 14px * root.density; }


                                    Rectangle {
                                        width: segment_field_w; height: 42px * root.density;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px * root.density;



                                        border-radius: 8px * root.density;


                                        TextInput { visible: false;


                                            x: 6px * root.density; y: 4px * root.density;



                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.hold + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px * root.density;



                                            input-type: InputType.number;



                                            edited => { root.editor_hold_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.hold + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px * root.density;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "hold" && root.kb_step_index == i)) {
                                                    root.kb_open("hold", i, step.hold + "");
                                                }
                                            }
                                        }


                                    }



                                }



                            }



                            Rectangle {



                                x: parent.width - segment_delete_w - segment_right_pad;
                                y: 6px * root.density;
                                width: segment_delete_w; height: segment_delete_w;


                                background: #27272A;



                                border-radius: 8px * root.density;


                                Text { text: "X"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }



                                TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.editor_remove(i); } }



                            }



                        }



                        Rectangle {
                        width: root.screen_w - root.settings_side_gap * 4; height: 44px * root.density;



                            background: #0F0F0F;



                            border-color: #27272A;



                            border-width: 1px * root.density;



                            border-radius: 10px * root.density;



                        Text { text: root.is_ua ? "+ \u{0414}\u{043E}\u{0434}\u{0430}\u{0442}\u{0438} \u{043A}\u{0440}\u{043E}\u{043A}" : "+ Add Step"; color: #A1A1AA; font-size: 18px * root.density; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }



                            TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.editor_add_step(); } }



                        }



                    }
                }



            }



        }


    // Stop modal



    // Full-screen text keyboard (program name)
    if (root.kb_visible && ((root.kb_field == "name" && root.kb_mode == "alpha") || (root.kb_field == "wifi_pass" && root.kb_mode == "alpha"))) : Rectangle {
        x: 0px * root.density;
        y: 0px * root.density;
        width: root.screen_w;
        height: root.screen_h;
        z: 5000;

        background: #000000;

        property <[string]> ua_r1_uc: ["\u{0419}","\u{0426}","\u{0423}","\u{041A}","\u{0415}","\u{041D}","\u{0413}","\u{0428}","\u{0429}","\u{0417}","\u{0425}","\u{0407}"];
        property <[string]> ua_r2_uc: ["\u{0424}","\u{0406}","\u{0412}","\u{0410}","\u{041F}","\u{0420}","\u{041E}","\u{041B}","\u{0414}","\u{0416}","\u{0404}"];
        property <[string]> ua_r3_uc: ["\u{042F}","\u{0427}","\u{0421}","\u{041C}","\u{0418}","\u{0422}","\u{042C}","\u{0411}","\u{042E}","\u{0490}"];
        property <[string]> ua_r1_lc: ["\u{0439}","\u{0446}","\u{0443}","\u{043A}","\u{0435}","\u{043D}","\u{0433}","\u{0448}","\u{0449}","\u{0437}","\u{0445}","\u{0457}"];
        property <[string]> ua_r2_lc: ["\u{0444}","\u{0456}","\u{0432}","\u{0430}","\u{043F}","\u{0440}","\u{043E}","\u{043B}","\u{0434}","\u{0436}","\u{0454}"];
        property <[string]> ua_r3_lc: ["\u{044F}","\u{0447}","\u{0441}","\u{043C}","\u{0438}","\u{0442}","\u{044C}","\u{0431}","\u{044E}","\u{0491}"];

        property <[string]> en_r1_uc: ["Q","W","E","R","T","Y","U","I","O","P"];
        property <[string]> en_r2_uc: ["A","S","D","F","G","H","J","K","L"];
        property <[string]> en_r3_uc: ["Z","X","C","V","B","N","M"];
        property <[string]> en_r1_lc: ["q","w","e","r","t","y","u","i","o","p"];
        property <[string]> en_r2_lc: ["a","s","d","f","g","h","j","k","l"];
        property <[string]> en_r3_lc: ["z","x","c","v","b","n","m"];

        Rectangle {
            x: 0px * root.density; y: 0px * root.density; width: parent.width; height: 70px * root.density;
            background: #111118;
            border-color: #27272A;
            border-width: 1px * root.density;

            KbKeyButton { x: 10px * root.density; y: 13px * root.density; width: 72px * root.density; height: 44px * root.density; background: #7F1D1D; label: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; font_size: 14px;
                pressed(v) => { root.kb_key("CANCEL"); }
            }
            KbKeyButton { x: parent.width - 82px * root.density; y: 13px * root.density; width: 72px * root.density; height: 44px * root.density; background: #10B981; text_color: #000000; label: "OK"; font_size: 18px;
                pressed(v) => { root.kb_key("OK"); }
            }

            Rectangle {
                x: 90px * root.density; y: 10px * root.density; width: parent.width - 180px * root.density; height: 50px * root.density;
                background: #0B0B0B;
                border-color: #27272A;
                border-width: 1px * root.density;
                border-radius: 10px * root.density;
                clip: true;

                Text {
                    x: 10px * root.density; y: 6px * root.density;
                    text: root.kb_field == "name"
                        ? (root.is_ua ? "\u{041D}\u{0430}\u{0437}\u{0432}\u{0430} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0438}" : "Program Name")
                        : (root.is_ua ? "\u{041F}\u{0430}\u{0440}\u{043E}\u{043B}\u{044C} Wi\u{2011}Fi" : "Wi\u{2011}Fi Password");
                    color: #A1A1AA;
                    font-family: "PT Sans";
                    font-size: 12px * root.density;
                }

                Text {
                    x: 10px * root.density; y: 22px * root.density;
                    width: parent.width - 20px;
                    text: root.kb_value;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px * root.density;
                    font-weight: 700;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    wrap: no-wrap;
                }
            }
        }

        KbKeyRow {
            row_y: -78px * root.density;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r1_uc : parent.ua_r1_lc)
                : (root.kb_caps ? parent.en_r1_uc : parent.en_r1_lc);
            key_width: (root.is_ua ? 38px : 46px) * root.density;
            key_height: 44px * root.density;
            gap: 2px * root.density;
            start_x: -238px * root.density;
            font_size: 20px * root.density;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyRow {
            row_y: -30px * root.density;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r2_uc : parent.ua_r2_lc)
                : (root.kb_caps ? parent.en_r2_uc : parent.en_r2_lc);
            key_width: (root.is_ua ? 40px : 48px) * root.density;
            key_height: 44px * root.density;
            gap: 2px * root.density;
            start_x: (root.is_ua ? -230px : -222px) * root.density;
            font_size: 20px * root.density;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyRow {
            row_y: 18px * root.density;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r3_uc : parent.ua_r3_lc)
                : (root.kb_caps ? parent.en_r3_uc : parent.en_r3_lc);
            key_width: (root.is_ua ? 46px : 66px) * root.density;
            key_height: 44px * root.density;
            gap: 2px * root.density;
            start_x: -238px * root.density;
            font_size: 20px * root.density;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyButton { x: 10px * root.density; y: 238px * root.density; width: 60px * root.density; height: 60px * root.density; background: #3F3F46; label: "123"; font_size: 16px;
            pressed(v) => { root.kb_mode = "num"; }
        }
        KbKeyButton { x: 72px * root.density; y: 238px * root.density; width: 50px * root.density; height: 60px * root.density; background: #3F3F46; label: root.is_ua ? "UA" : "EN"; font_size: 14px;
            pressed(v) => { root.is_ua = !root.is_ua; }
        }
        KbKeyButton { x: 124px * root.density; y: 238px * root.density; width: 50px * root.density; height: 60px * root.density; background: root.kb_caps ? #10B981 : #3F3F46; label: "\u{21E7}"; font_size: 20px;
            pressed(v) => { root.kb_caps = !root.kb_caps; }
        }
        KbKeyButton { x: 176px * root.density; y: 238px * root.density; width: 134px * root.density; height: 60px * root.density; background: #27272A; label: root.is_ua ? "\u{041F}\u{0440}\u{043E}\u{0431}\u{0456}\u{043B}" : "Space"; font_size: 18px;
            pressed(v) => { root.kb_key("SPACE"); }
        }
        KbKeyButton { x: 318px * root.density; y: 238px * root.density; width: 72px * root.density; height: 60px * root.density; background: #3F3F46; label: "\u{2190}"; font_size: 22px;
            pressed(v) => { root.kb_key("BS"); }
        }
        KbKeyButton { x: 398px * root.density; y: 238px * root.density; width: 72px * root.density; height: 60px * root.density; background: #3F3F46; label: root.is_ua ? "\u{041E}\u{0447}\u{0438}\u{0441}\u{0442}." : "Clear"; font_size: 14px;
            pressed(v) => { root.kb_key("CLR"); }
        }
    }

    // Bottom numeric keyboard overlay (Editor)
    if (root.kb_visible && ((root.kb_field == "name" && (root.kb_mode == "num" || root.kb_mode == "sym")) || (root.kb_field == "wifi_pass" && (root.kb_mode == "num" || root.kb_mode == "sym")) || (root.kb_field != "name" && root.kb_field != "wifi_pass"))) : Rectangle {
        x: 0px * root.density;
        y: 0px * root.density;
        width: root.screen_w;
        height: root.screen_h;
        z: 5000;

        background: #000000;

        property <length> kb_header_right_reserved: (root.kb_field == "wifi_pass" || root.kb_field == "name") ? (188px * root.density) : (0px * root.density);
        Rectangle {
            x: 12px * root.density; y: 8px * root.density;
            width: parent.width - 24px * root.density - parent.kb_header_right_reserved;
            height: 56px * root.density;
            background: #0B0B0B;
            border-color: #27272A;
            border-width: 1px * root.density;
            border-radius: 10px * root.density;
            clip: true;

            Text {
                x: 10px * root.density; y: 6px * root.density;
                text: root.kb_field == "rate"
                    ? (root.is_ua ? "\u{0428}\u{0432}\u{0438}\u{0434}\u{043A}\u{0456}\u{0441}\u{0442}\u{044C}" : "Rate")
                    : root.kb_field == "target"
                        ? (root.is_ua ? "\u{0422}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0430}" : "Target")
                        : root.kb_field == "hold"
                            ? (root.is_ua ? "\u{0412}\u{0438}\u{0442}\u{0440}\u{0438}\u{043C}\u{043A}\u{0430}" : "Hold")
                            : root.kb_field == "fan"
                                ? (root.is_ua ? "\u{0412}\u{0435}\u{043D}\u{0442}\u{0438}\u{043B}\u{044F}\u{0442}\u{043E}\u{0440} %" : "Fan %")
                                : root.kb_field == "autotune"
                                    ? (root.is_ua ? "\u{0410}\u{0432}\u{0442}\u{043E}\u{043D}\u{0430}\u{043B}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}" : "Autotune")
                                    : root.kb_field == "run_rate"
                                        ? (root.is_ua ? "\u{041D}\u{043E}\u{0432}\u{0430} \u{0448}\u{0432}\u{0438}\u{0434}\u{043A}\u{0456}\u{0441}\u{0442}\u{044C}" : "New rate")
                                        : root.kb_field == "run_temp"
                                            ? (root.is_ua ? ("\u{0414}\u{043E}\u{0434}\u{0430}\u{0442}\u{0438} \u{0442}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0443} (" + root.temp_unit_label + ")") : ("Add temperature (" + root.temp_unit_label + ")"))
                                            : root.kb_field == "run_time"
                                                ? (root.is_ua ? "\u{0414}\u{043E}\u{0434}\u{0430}\u{0442}\u{0438} \u{0447}\u{0430}\u{0441}" : "Add time")
                                    : root.kb_field == "name"
                                        ? (root.is_ua ? "\u{041D}\u{0430}\u{0437}\u{0432}\u{0430} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0438}" : "Program name")
                                        : root.kb_field == "wifi_pass"
                                            ? (root.is_ua ? "\u{041F}\u{0430}\u{0440}\u{043E}\u{043B}\u{044C} Wi\u{2011}Fi" : "Wi-Fi password")
                                            : "";
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 12px * root.density;
                vertical-alignment: center;
            }

            Text {
                x: 10px * root.density; y: 24px * root.density;
                width: parent.width - 20px * root.density;
                text: root.kb_value;
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 24px * root.density;
                font-weight: 700;
                wrap: no-wrap;
                overflow: elide;
                vertical-alignment: center;
            }
        }

        if (root.kb_field == "wifi_pass" || root.kb_field == "name") : KbKeyButton { x: parent.width - 92px * root.density; y: 10px * root.density; width: 80px * root.density; height: 32px * root.density; background: #27272A; label: "ABC"; font_size: 12px;
            pressed(v) => { root.kb_mode = "alpha"; }
        }
        if (root.kb_field == "wifi_pass" || root.kb_field == "name") : KbKeyButton { x: parent.width - 184px * root.density; y: 10px * root.density; width: 80px * root.density; height: 32px * root.density; background: #27272A; label: root.kb_mode == "sym" ? "123" : "SYM"; font_size: 12px;
            pressed(v) => { root.kb_mode = root.kb_mode == "sym" ? "num" : "sym"; }
        }

        property <float> k_scale: 1.0;
        property <length> kg: 10px * root.density;
        property <length> kw_unclamped: ((root.screen_w - 50px * root.density) - (kg * 2)) / 3;
        property <length> kw: (kw_unclamped > 180px * root.density) ? (180px * root.density) : kw_unclamped;
        property <length> kx: (root.screen_w - ((kw * 3) + (kg * 2))) / 2;
        property <length> ky: 78px * root.density;
        property <length> kh: 42px * root.density * k_scale;
        property <length> krow_gap: 6px * root.density;

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "!" : "1"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "!" : "1"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "@" : "2"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "@" : "2"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "#" : "3"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "#" : "3"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "$" : "4"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "$" : "4"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "%" : "5"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "%" : "5"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "&" : "6"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "&" : "6"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "*" : "7"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "*" : "7"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "-" : "8"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "-" : "8"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "_" : "9"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "_" : "9"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; background: #3F3F46; label: root.is_ua ? "\u{041E}\u{0447}\u{0438}\u{0441}\u{0442}." : "Clear"; font_size: root.kb_field == "wifi_pass" ? 16px : 14px; pressed(v) => { root.kb_key("CLR"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "." : "0"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "." : "0"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; background: #3F3F46; label: "\u{2190}"; font_size: root.kb_field == "wifi_pass" ? 26px : 22px; pressed(v) => { root.kb_key("BS"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 4 * (parent.kh + parent.krow_gap); width: parent.kw; height: parent.kh; background: #7F1D1D; label: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; font_size: root.kb_field == "wifi_pass" ? 16px : 14px; pressed(v) => { root.kb_key("CANCEL"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 4 * (parent.kh + parent.krow_gap); width: parent.kw + parent.kg + parent.kw; height: parent.kh; background: #10B981; text_color: #000000; label: "OK"; font_size: root.kb_field == "wifi_pass" ? 24px : 20px; pressed(v) => { root.kb_key("OK"); } }
    }

    if (root.show_touch_confirm) : Rectangle {
        x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
        background: #000000B3;
        z: 5090;
        Rectangle {
            x: (root.screen_w - self.width) / 2; y: (root.screen_h - self.height) / 2; width: 360px * root.density; height: 164px * root.density;
            background: #0B0B0B;
            border-color: #3F3F46;
            border-width: 1px * root.density;
            border-radius: 16px * root.density;
            Text {
                x: 20px * root.density; y: 20px * root.density; width: parent.width - 40px; height: 48px * root.density;
                text: root.is_ua ? "\u{041F}\u{043E}\u{0447}\u{0430}\u{0442}\u{0438} \u{043A}\u{0430}\u{043B}\u{0456}\u{0431}\u{0440}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F} \u{0435}\u{043A}\u{0440}\u{0430}\u{043D}\u{0430}-" : "Start screen calibration-";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 20px * root.density;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: word-wrap;
            }
            Text {
                x: 20px * root.density; y: 68px * root.density; width: parent.width - 40px; height: 32px * root.density;
                text: root.is_ua ? "\u{041F}\u{0456}\u{0441}\u{043B}\u{044F} \u{043F}\u{0456}\u{0434}\u{0442}\u{0432}\u{0435}\u{0440}\u{0434}\u{0436}\u{0435}\u{043D}\u{043D}\u{044F} \u{0432}\u{0456}\u{0434}\u{043A}\u{0440}\u{0438}\u{0454}\u{0442}\u{044C}\u{0441}\u{044F} \u{0440}\u{0435}\u{0436}\u{0438}\u{043C} \u{043A}\u{0430}\u{043B}\u{0456}\u{0431}\u{0440}\u{0443}\u{0432}\u{0430}\u{043D}\u{043D}\u{044F}." : "Calibration mode will open after confirmation.";
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 14px * root.density;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: word-wrap;
            }
            Rectangle {
                x: 24px * root.density; y: 112px * root.density; width: 150px * root.density; height: 40px * root.density;
                background: #27272A; border-radius: 10px * root.density;
                Text { text: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.show_touch_confirm = false; } }
            }
            Rectangle {
                x: 186px * root.density; y: 112px * root.density; width: 150px * root.density; height: 40px * root.density;
                background: #10B981; border-radius: 10px * root.density;
                Text { text: root.is_ua ? "\u{041F}\u{043E}\u{0447}\u{0430}\u{0442}\u{0438}" : "Start"; color: #000000; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea {
                    width: parent.width; height: parent.height;
                    clicked => {
                        root.show_touch_confirm = false;
                        root.view = View.Calibration;
                        root.start_touch_calibration();
                    }
                }
            }
        }
    }

    if (root.delete_confirm_visible) : Rectangle {
        x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
        background: #000000B3;
        z: 5100;
        Rectangle {
            x: (root.screen_w - self.width) / 2; y: (root.screen_h - self.height) / 2; width: 360px * root.density; height: 180px * root.density;
            background: #0B0B0B;
            border-color: #3F3F46;
            border-width: 1px * root.density;
            border-radius: 16px * root.density;
            Text {
                x: 0px * root.density; y: 22px * root.density; width: parent.width;
                text: root.is_ua ? "\u{0412}\u{0438}\u{0434}\u{0430}\u{043B}\u{0438}\u{0442}\u{0438} \u{043F}\u{0440}\u{043E}\u{0433}\u{0440}\u{0430}\u{043C}\u{0443}-" : "Delete program-";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 20px * root.density;
                horizontal-alignment: center;
            }
            Text {
                x: 20px * root.density; y: 60px * root.density; width: parent.width - 40px;
                text: root.is_ua ? "\u{0426}\u{044E} \u{0434}\u{0456}\u{044E} \u{043D}\u{0435}\u{043C}\u{043E}\u{0436}\u{043B}\u{0438}\u{0432}\u{043E} \u{0441}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}." : "This action cannot be undone.";
                color: #A1A1AA;
                font-size: 12px * root.density;
                horizontal-alignment: center;
            }
            Rectangle {
                x: 24px * root.density; y: 120px * root.density; width: 150px * root.density; height: 44px * root.density;
                background: #27272A; border-radius: 10px * root.density;
                Text { text: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.delete_confirm_visible = false; } }
            }
            Rectangle {
                x: 186px * root.density; y: 120px * root.density; width: 150px * root.density; height: 44px * root.density;
                background: #7F1D1D; border-radius: 10px * root.density;
                Text { text: root.is_ua ? "\u{0412}\u{0438}\u{0434}\u{0430}\u{043B}\u{0438}\u{0442}\u{0438}" : "Delete"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea {
                    width: parent.width; height: parent.height;
                    clicked => {
                        if (root.delete_confirm_index >= 0) { root.delete_schedule(root.delete_confirm_index); }
                        root.delete_confirm_visible = false;
                    }
                }
            }
        }
    }

    if (root.show_skip_confirm) : Rectangle {
            x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
            background: #000000B3;
            z: 5100;
            Rectangle {
                x: (root.screen_w - self.width) / 2; y: (root.screen_h - self.height) / 2; width: 336px * root.density; height: 168px * root.density;
                background: #0B0B0B;
                border-color: #3F3F46;
                border-width: 1px * root.density;
                border-radius: 16px * root.density;
                Text {
                    x: 0px * root.density; y: 24px * root.density; width: parent.width;
                    text: root.is_ua ? "\u{041F}\u{0440}\u{043E}\u{043F}\u{0443}\u{0441}\u{0442}\u{0438}\u{0442}\u{0438} \u{043A}\u{0440}\u{043E}\u{043A}" : "Skip step";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px * root.density;
                    horizontal-alignment: center;
                }
                Rectangle {
                    x: 18px * root.density; y: 104px * root.density; width: 140px * root.density; height: 44px * root.density;
                    background: #27272A; border-radius: 10px * root.density;
                    Text { text: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; color: #FFFFFF; font-size: 18px * root.density; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_cancel(); } }
                }
                Rectangle {
                    x: 178px * root.density; y: 104px * root.density; width: 140px * root.density; height: 44px * root.density;
                    background: root.c_danger; border-radius: 10px * root.density;
                    Text { text: root.is_ua ? "\u{041F}\u{0456}\u{0434}\u{0442}\u{0432}\u{0435}\u{0440}\u{0434}\u{0438}\u{0442}\u{0438}" : "Confirm"; color: #FFFFFF; font-size: 18px * root.density; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_confirm(); } }
                }
            }
    }

    if (root.show_running_edit_confirm) : Rectangle {
            x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
            background: #000000B3;
            z: 5100;
            Rectangle {
                x: (root.screen_w - self.width) / 2; y: (root.screen_h - self.height) / 2; width: 364px * root.density; height: 212px * root.density;
                background: #0B0B0B;
                border-color: #3F3F46;
                border-width: 1px * root.density;
                border-radius: 16px * root.density;
                Text {
                    x: 0px * root.density; y: 24px * root.density; width: parent.width;
                    text: root.is_ua ? "\u{0417}\u{0430}\u{0441}\u{0442}\u{043E}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438} \u{0437}\u{043C}\u{0456}\u{043D}\u{0438}-" : "Apply changes-";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px * root.density;
                    horizontal-alignment: center;
                }
                VerticalBox {
                    x: 18px * root.density; y: 58px * root.density; width: parent.width - 36px;
                    spacing: 4px;
                    alignment: start;
                    Text {
                        text: root.is_ua
                            ? ("\u{0428}\u{0432}\u{0438}\u{0434}\u{043A}\u{0456}\u{0441}\u{0442}\u{044C}: " + root.running_edit_rate + " " + root.rate_unit_label_min)
                            : ("Rate: " + root.running_edit_rate + " " + root.rate_unit_label_min);
                        color: #A1A1AA;
                        font-size: 12px * root.density;
                        horizontal-alignment: left;
                    }
                    if (root.running_edit_add_temp != 0) : Text {
                        text: root.is_ua
                            ? ("\u{0414}\u{043E}\u{0434}\u{0430}\u{0442}\u{0438} \u{0442}\u{0435}\u{043C}\u{043F}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0443}: " + root.running_edit_add_temp + root.temp_unit_label)
                            : ("Add temperature: " + root.running_edit_add_temp + root.temp_unit_label);
                        color: #A1A1AA;
                        font-size: 12px * root.density;
                        horizontal-alignment: left;
                    }
                    if (root.running_edit_add_time != 0) : Text {
                        text: root.is_ua
                            ? ("\u{0414}\u{043E}\u{0434}\u{0430}\u{0442}\u{0438} \u{0447}\u{0430}\u{0441}: " + root.running_edit_add_time + " \u{0421}\u{2026}\u{0420}\u{0406}")
                            : ("Add time: " + root.running_edit_add_time + " min");
                        color: #A1A1AA;
                        font-size: 12px * root.density;
                        horizontal-alignment: left;
                    }
                }
                Rectangle {
                    x: 22px * root.density; y: 156px * root.density; width: 152px * root.density; height: 44px * root.density;
                    background: #27272A; border-radius: 10px * root.density;
                    Text { text: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_cancel(); } }
                }
                Rectangle {
                    x: 190px * root.density; y: 156px * root.density; width: 152px * root.density; height: 44px * root.density;
                    background: #10B981; border-radius: 10px * root.density;
                    Text { text: root.is_ua ? "\u{0417}\u{0431}\u{0435}\u{0440}\u{0435}\u{0433}\u{0442}\u{0438}" : "Save"; color: #000000; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_confirm(); } }
                }
            }
    }

    if (root.standby_visible && !root.boot_splash_visible) : Rectangle {
            x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
            background: #05070B;
            z: 5150;

            Rectangle {
                x: 0px * root.density; y: 12px * root.density; width: root.screen_w; height: 52px * root.density;
                background: #00000000;
                Text {
                    x: 0px * root.density; y: 1px * root.density; width: parent.width; height: 50px * root.density;
                    text: "KILN PRO";
                    color: Theme.color_accent;
                    opacity: 0.28;
                    font-family: "PT Sans";
                    font-size: 38px * root.density;
                    font-weight: 700;
                    letter-spacing: 2.0px * root.density;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Text {
                    x: 0px * root.density; y: 0px * root.density; width: parent.width; height: 50px * root.density;
                    text: "KILN PRO";
                    color: Theme.color_text;
                    font-family: "PT Sans";
                    font-size: 36px * root.density;
                    font-weight: 700;
                    letter-spacing: 2.0px * root.density;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 0px * root.density; y: 72px * root.density; width: root.screen_w; height: 170px * root.density;
                text: root.temp_label + root.temp_unit_label;
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: root.board_profile_id == 1 ? 168px : 124px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 0px * root.density; y: 204px * root.density; width: root.screen_w; height: 28px * root.density;
                text: root.temp_hint != ""
                    ? root.temp_hint
                    : (root.display_target_value > 0 ? (root.display_target_value + root.temp_unit_label) : "");
                color: root.temp_hint != "" ? #F87171 : #A1A1AA;
                font-family: "PT Sans";
                font-size: 22px * root.density;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }

            Text {
                x: 0px * root.density; y: 236px * root.density; width: root.screen_w; height: 24px * root.density;
                text: root.pzem_phase_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px * root.density;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 18px * root.density; y: 278px * root.density; width: 146px * root.density; height: 24px * root.density;
                text: root.pzem_power_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px * root.density;
                font-weight: 700;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            Text {
                x: 168px * root.density; y: 278px * root.density; width: 144px * root.density; height: 24px * root.density;
                text: root.pzem_current_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px * root.density;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 318px * root.density; y: 278px * root.density; width: 146px * root.density; height: 24px * root.density;
                text: root.pzem_voltage_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px * root.density;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            Rectangle {
                x: (root.screen_w - self.width) / 2;
                y: 272px * root.density;
                width: root.is_ua
                    ? (root.status_label == "IDLE" ? 128px * root.density
                       : root.status_label == "COOL" ? 128px * root.density
                       : root.status_label == "COMPLETE" ? 120px * root.density
                       : root.status_label == "ERROR" ? 108px * root.density
                       : 104px * root.density)
                    : (root.status_label == "ERROR" ? 98px * root.density : 90px * root.density);
                height: 34px * root.density;
                background: root.status_bg;
                border-color: root.status_fg;
                border-width: root.status_label == "ERROR" ? 2px : 1px;
                border-radius: 17px * root.density;

                Text {
                    text: root.status_text;
                    color: root.status_fg;
                    font-family: "PT Sans";
                    font-size: root.is_ua ? 14px * root.density : 16px * root.density;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 314px * root.density; y: 278px * root.density; width: 148px * root.density; height: 28px * root.density;
                text: root.time_remaining;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 20px * root.density;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.standby_visible = false; }
            }
    }

    if (root.boot_splash_visible) : Rectangle {
            x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
            background: #05070B;
            z: 5200;

            Rectangle {
                x: (root.screen_w - (400px * root.density)) / 2; y: 96px * root.density; width: 400px * root.density; height: 128px * root.density;
                background: #00000000;
                Text {
                    x: 0px * root.density; y: 10px * root.density; width: parent.width; height: 96px * root.density;
                    text: "KILN PRO";
                    color: Theme.color_accent;
                    opacity: 0.30;
                    font-family: "PT Sans";
                    font-size: 68px * root.density;
                    font-weight: 700;
                    letter-spacing: 2.2px * root.density;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Text {
                    x: 0px * root.density; y: 8px * root.density; width: parent.width; height: 96px * root.density;
                    text: "KILN PRO";
                    color: Theme.color_text;
                    font-family: "PT Sans";
                    font-size: 64px * root.density;
                    font-weight: 700;
                    letter-spacing: 2.2px * root.density;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
    }
    if (root.show_stop_confirm) : Rectangle {
            width: root.board_profile_id == 1 ? 420px * root.density : 360px * root.density;
            height: root.board_profile_id == 1 ? 236px * root.density : 220px * root.density;
            x: (root.screen_w - self.width) / 2;
            y: (root.show_header ? root.top_bar_h : 0px) + ((root.screen_h - (root.show_header ? root.top_bar_h : 0px)) - self.height) / 2;
            background: #0B0B0B;
            border-color: #3F3F46;
            border-width: 1px * root.density;
            border-radius: 18px * root.density;
            z: 7000;

            Rectangle {
                x: (parent.width - self.width) / 2; y: 16px * root.density; width: 64px * root.density; height: 64px * root.density;
                background: #7F1D1D;
                border-radius: 32px * root.density;
                Text { text: "!"; color: #EF4444; font-size: 28px * root.density; horizontal-alignment: center; vertical-alignment: center; }
            }

            Text {
                x: 0px * root.density; y: 86px * root.density; width: parent.width;
                text: root.is_ua ? "\u{0417}\u{0443}\u{043F}\u{0438}\u{043D}\u{0438}\u{0442}\u{0438}" : "Stop Firing";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 20px * root.density;
                horizontal-alignment: center;
            }

            Text {
                x: 0px * root.density; y: 120px * root.density; width: parent.width;
                text: root.is_ua ? "\u{0412}\u{0438} \u{0432}\u{043F}\u{0435}\u{0432}\u{043D}\u{0435}\u{043D}\u{0456}, \u{0449}\u{043E} \u{0445}\u{043E}\u{0447}\u{0435}\u{0442}\u{0435} \u{043F}\u{0435}\u{0440}\u{0435}\u{0440}\u{0432}\u{0430}\u{0442}\u{0438} \u{043F}\u{0440}\u{043E}\u{0446}\u{0435}\u{0441}" : "Are you sure you want to abort the process";
                color: #A1A1AA;
                font-size: 12px * root.density;
                horizontal-alignment: center;
            }

            Rectangle {
                x: (parent.width - (150px * root.density) * 2 - (20px * root.density)) / 2;
                y: 156px * root.density;
                width: 150px * root.density; height: 52px * root.density;
                background: #27272A;
                border-radius: 12px * root.density;
                Text { text: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; color: #FFFFFF; font-family: "PT Sans"; font-size: 18px * root.density; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.stop_cancel(); } }
            }

            Rectangle {
                x: ((parent.width - (150px * root.density) * 2 - (20px * root.density)) / 2) + (150px * root.density) + (20px * root.density);
                y: 156px * root.density;
                width: 150px * root.density; height: 52px * root.density;
                background: #DC2626;
                border-radius: 12px * root.density;
                Text { text: root.is_ua ? "\u{0417}\u{0423}\u{041F}\u{0418}\u{041D}\u{0418}\u{0422}\u{0418}" : "STOP"; color: #FFFFFF; font-family: "PT Sans"; font-size: 18px * root.density; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.stop_confirm(); } }
            }
    }












    // Software dimming overlay (avoid PWM artifacts)
    Rectangle {
        x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
        background: #000000;
        opacity: root.ui_dim;
        visible: root.ui_dim > 0.001 && root.view != View.Calibration;
        z: 900;
    }


    // Touch calibration
    if (root.view == View.Calibration) : Rectangle {
        x: 0px * root.density; y: 0px * root.density; width: root.screen_w; height: root.screen_h;
        z: 6000;
        background: #000000;

        Text {
            x: 12px * root.density; y: 300px * root.density; width: 456px * root.density;
            text: root.calib_hint;
            color: #A1A1AA;
            font-family: "PT Sans";
            font-size: 12px * root.density;
            horizontal-alignment: center;
        }

        // target dot
        Rectangle {
            x: root.calib_target_x * 1px - 14px;
            y: root.calib_target_y * 1px - 14px;
            width: 28px * root.density; height: 28px * root.density;
            background: #00000000;
            border-color: #10B981;
            border-width: 2px * root.density;
            border-radius: 14px * root.density;
        }
        Rectangle {
            x: root.calib_target_x * 1px - 1px;
            y: root.calib_target_y * 1px - 10px;
            width: 2px * root.density; height: 20px * root.density;
            background: #10B981;
        }
        Rectangle {
            x: root.calib_target_x * 1px - 10px;
            y: root.calib_target_y * 1px - 1px;
            width: 20px * root.density; height: 2px * root.density;
            background: #10B981;
        }

        Rectangle {
            x: 360px * root.density; y: 282px * root.density; width: 100px * root.density; height: 28px * root.density;
            background: #27272A;
            border-radius: 10px * root.density;
            Text { text: root.is_ua ? "\u{0421}\u{043A}\u{0430}\u{0441}\u{0443}\u{0432}\u{0430}\u{0442}\u{0438}" : "Cancel"; color: #FFFFFF; font-family: "PT Sans"; font-size: 12px * root.density; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { width: parent.width; height: parent.height; clicked => { root.cancel_touch_calibration(); } }
        }
    }

}
