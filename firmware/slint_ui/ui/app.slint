import { VerticalBox, HorizontalBox } from "std-widgets.slint";
import "../../data/fonts/sketch_260307b/FontFiles/PTSans-Regular.ttf";
import "../../data/fonts/sketch_260307b/FontFiles/PTSans-Bold.ttf";

component PlayIcon {
    in property <brush> color: #000000;
    width: 16px;
    height: 16px;
    Path {
        x: 2px; y: 2px;
        width: parent.width - 4px;
        height: parent.height - 4px;
        fill: root.color;
        commands: "M0,0 L12,6 L0,12 Z";
    }
}

component StopIcon {
    in property <brush> color: #FFFFFF;
    width: 16px;
    height: 16px;
    Rectangle {
        x: 2px; y: 2px;
        width: parent.width - 4px;
        height: parent.height - 4px;
        background: root.color;
    }
}

export enum View { Dashboard, Schedules, Editor, Calibration }

export struct ScheduleRow {
    name: string,
    steps_count: int,
    selected: bool,
}

export struct EditorStepRow {
    step_type: string,
    rate: int,
    target: int,
    hold: int,
}

export component AppWindow inherits Window {
    width: 480px;
    height: 320px;
    background: #000000;
    default-font-family: "PT Sans";

    in-out property <View> view: View.Dashboard;
    in-out property <bool> show_stop_confirm: false;
    in-out property <bool> is_ua: false;
    in-out property <string> current_time: "00:00";

    in-out property <float> temp: 24.5;
    in-out property <int> target: 0;
    in-out property <string> status_label: "IDLE";
    in-out property <bool> is_idle: true;
    in-out property <int> step_index: 0;
    in-out property <int> total_steps: 0;
    in-out property <string> time_remaining: "--:--";
    in-out property <string> selected_schedule_name: "";
    in-out property <int> selected_steps_count: 0;
    in-out property <bool> wifi_ok: true;

    in-out property <[ScheduleRow]> schedules;
    in-out property <[EditorStepRow]> editor_steps;

    in-out property <bool> fault_active: false;
    in-out property <string> fault_reason: "";

    in-out property <int> calib_step: 0;
    in-out property <string> calib_hint: "";
    in-out property <int> calib_target_x: 40;
    in-out property <int> calib_target_y: 60;

    callback toggle_language();
    callback start_firing();
    callback stop_firing();
    callback open_library();
    callback select_schedule(int);
    callback edit_schedule(int);
    callback new_schedule();
    callback editor_back();
    callback editor_save();
    callback editor_add_step();
    callback editor_rate_changed(int, string);
    callback editor_target_changed(int, string);
    callback editor_hold_changed(int, string);
    callback editor_remove(int);
    callback stop_confirm();
    callback stop_cancel();
    callback start_touch_calibration();
    callback cancel_touch_calibration();

    // Header bar
    Rectangle {
        x: 0px; y: 0px;
        width: 480px; height: 40px;
        background: #111118;
        border-color: #27272A;
        border-width: 1px;

        HorizontalBox {
            x: 10px; y: 8px;
            spacing: 6px;
            Text {
                text: "KILN PRO";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 14px;
                letter-spacing: 1px;
            }
        }

        HorizontalBox {
            x: 280px; y: 8px;
            spacing: 6px;
            Rectangle {
                width: 34px; height: 22px;
                background: #27272A;
                border-radius: 6px;
                Text {
                    text: root.is_ua ? "UA" : "EN";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 10px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea {
                    clicked => { root.toggle_language(); }
                }
            }
            Text {
                text: root.current_time;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 12px;
            }
            Rectangle {
                width: 14px; height: 14px;
                border-radius: 7px;
                background: root.wifi_ok ? #10B981 : #52525B;
                TouchArea { clicked => { root.start_touch_calibration(); } }
            }
        }
    }

    if (root.fault_active) : Rectangle {
        x: 0px; y: 40px;
        width: 480px; height: 28px;
        background: #7F1D1D;
        border-color: #DC2626;
        border-width: 1px;
        Text {
            x: 10px; y: 6px;
            text: root.fault_reason == "" ? "FAULT" : ("FAULT: " + root.fault_reason);
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 12px;
        }
    }

    // Main content
    Rectangle {
        x: 0px; y: root.fault_active ? 68px : 40px;
        width: 480px; height: 280px;
        background: #000000;

        // Dashboard View
        if (root.view == View.Dashboard) : HorizontalBox {
                x: 0px; y: 0px;
                width: 480px; height: 280px;
                spacing: 0px;

                // Left column
                Rectangle {
                    width: 240px; height: 280px;
                    background: #000000;
                    border-color: #27272A;
                    border-width: 1px;

                    Rectangle {
                        x: 170px; y: 8px; width: 60px; height: 18px;
                        background: root.status_label == "ERROR" ? #EF4444 : (root.status_label == "IDLE" ? #27272A : #10B981);
                        border-radius: 9px;
                        Text {
                            text: root.status_label;
                            color: root.status_label == "IDLE" ? #FFFFFF : (root.status_label == "ERROR" ? #FFFFFF : #000000);
                            font-family: "PT Sans";
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    VerticalBox {
                        x: 12px; y: 30px;
                        spacing: 6px;
                        Text {
                            text: root.is_ua ? "ПОТОЧНА ТЕМП" : "CURRENT TEMP";
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px;
                            letter-spacing: 1px;
                        }
                        HorizontalBox {
                            spacing: 4px;
                            Text {
                                text: root.temp;
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 46px;
                            }
                            Text {
                                text: "°C";
                                color: #52525B;
                                font-family: "PT Sans";
                                font-size: 18px;
                                y: 14px;
                            }
                        }
                    }

                    Rectangle {
                        x: 12px; y: 120px; width: 216px; height: 92px;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 14px;

                        VerticalBox {
                            x: 10px; y: 10px;
                            spacing: 6px;

                            HorizontalBox {
                                spacing: 4px;
                                Text { text: root.is_ua ? "ТЕМПЕРАТУРА" : "TEMPERATURE"; color: #A1A1AA; font-size: 10px; }
                                Text { text: root.target + "°C"; color: #FFFFFF; font-size: 20px; font-family: "PT Sans"; }
                            }

                            if (!root.is_idle) : HorizontalBox {
                                    spacing: 4px;
                                    Text { text: root.is_ua ? "ЗАЛИШИЛОСЬ ЧАСУ" : "TIME REMAINING"; color: #A1A1AA; font-size: 10px; }
                                    Text { text: root.time_remaining; color: #FFFFFF; font-size: 20px; font-family: "PT Sans"; }
                                }
                            }

                            Rectangle {
                                x: 0px; y: 0px;
                                width: 196px; height: 6px;
                                background: #27272A;
                                border-radius: 3px;
                                Rectangle {
                                    width: root.target > 0 ? min((root.temp / root.target) * 196px, 196px) : 0px;
                                    height: 6px;
                                    background: #10B981;
                                    border-radius: 3px;
                                }
                            }
                        }
                    }
                }

                // Right column
                Rectangle {
                    width: 240px; height: 280px;
                    background: #000000;

                    Rectangle {
                        x: 10px; y: 12px; width: 220px; height: 150px;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 16px;

                        if (root.is_idle) : VerticalBox {
                            x: 0px; y: 28px;
                            width: 220px;
                            spacing: 6px;

                            if (root.selected_schedule_name == "") : Text {
                                text: root.is_ua ? "ВИБЕРІТЬ ПРОГРАМУ..." : "SELECT SCHEDULE...";
                                color: #A1A1AA;
                                font-family: "PT Sans";
                                font-size: 12px;
                                horizontal-alignment: center;
                            }

                            if (root.selected_schedule_name != "") : VerticalBox {
                                spacing: 4px;
                                Text {
                                    text: root.is_ua ? "ОБРАНА ПРОГРАМА" : "SELECTED PROGRAM";
                                    color: #10B981;
                                    font-family: "PT Sans";
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.selected_schedule_name;
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 16px;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: root.selected_steps_count + " " + (root.is_ua ? "кроків" : "segments");
                                    color: #71717A;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                        if (root.is_idle) : TouchArea { clicked => { root.open_library(); } }

                        if (!root.is_idle) : VerticalBox {
                            x: 0px; y: 28px;
                            width: 220px;
                            spacing: 4px;
                            Text { text: root.is_ua ? "КРОК" : "STEP"; color: #A1A1AA; font-size: 10px; horizontal-alignment: center; }
                            Text { text: root.step_index + " / " + root.total_steps; color: #FFFFFF; font-family: "PT Sans"; font-size: 28px; horizontal-alignment: center; }
                            Text { text: root.is_ua ? "Нагрів до " + root.target + "°C" : "Ramp to " + root.target + "°C"; color: #71717A; font-size: 10px; horizontal-alignment: center; }
                        }
                    // Action buttons
                    HorizontalBox {
                        x: 10px; y: 174px;
                        width: 220px; height: 94px;
                        spacing: 8px;

                        Rectangle {
                            width: root.is_idle ? 106px : 220px; height: 94px;
                            background: root.is_idle ? (root.selected_schedule_name == "" ? #27272A : #10B981) : #DC2626;
                            border-radius: 16px;
                            Text {
                                text: root.is_idle ? (root.selected_schedule_name == "" ? (root.is_ua ? "ВИБЕРІТЬ" : "SELECT") : (root.is_ua ? "СТАРТ" : "START")) : (root.is_ua ? "СТОП" : "STOP");
                                color: root.is_idle ? (root.selected_schedule_name == "" ? #A1A1AA : #000000) : #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { clicked => { root.is_idle ? root.start_firing() : root.stop_firing(); } }
                        }

                        if (root.is_idle) : Rectangle {
                                width: 106px; height: 94px;
                                background: #27272A;
                                border-radius: 16px;
                                Text {
                                    text: root.is_ua ? "ПРОГРАМИ" : "SCHEDULES";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                TouchArea { clicked => { root.open_library(); } }
                            }
                    }
                }
            }
        // Schedules View
        if (root.view == View.Schedules) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: 280px;
                background: #000000;

                Text {
                    x: 18px; y: 12px;
                    text: root.is_ua ? "БІБЛІОТЕКА" : "LIBRARY";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px;
                }

                Rectangle {
                    x: 420px; y: 8px; width: 40px; height: 28px;
                    background: #27272A;
                    border-radius: 10px;
                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { clicked => { root.view = View.Dashboard; } }
                }

                VerticalBox {
                    x: 10px; y: 48px;
                    spacing: 6px;
                    for schedule[i] in root.schedules : Rectangle {
                        width: 460px; height: 48px;
                        background: schedule.selected ? #1F2937 : #0F0F0F;
                        border-color: schedule.selected ? #10B981 : #27272A;
                        border-width: 1px;
                        border-radius: 12px;

                        Text {
                            x: 12px; y: 6px;
                            text: schedule.name;
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 14px;
                        }
                        Text {
                            x: 12px; y: 26px;
                            text: schedule.steps_count + " " + (root.is_ua ? "кроків" : "segments");
                            color: #A1A1AA;
                            font-size: 10px;
                        }

                        Rectangle {
                            x: 410px; y: 6px; width: 36px; height: 36px;
                            background: schedule.selected ? #10B981 : #27272A;
                            border-radius: 18px;
                            Text { text: ">"; color: schedule.selected ? #000000 : #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked => { root.select_schedule(i); } }
                        }
                        TouchArea { clicked => { root.edit_schedule(i); } }
                    }

                    Rectangle {
                        width: 460px; height: 48px;
                        background: #000000;
                        border-color: #3F3F46;
                        border-width: 1px;
                        border-radius: 12px;
                        Text { text: root.is_ua ? "НОВА ПРОГРАМА" : "NEW SCHEDULE"; color: #A1A1AA; horizontal-alignment: center; vertical-alignment: center; }
                        TouchArea { clicked => { root.new_schedule(); } }
                    }
                }
        }

        // Editor View
        if (root.view == View.Editor) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: 280px;
                background: #000000;

                Rectangle {
                    x: 10px; y: 8px; width: 360px; height: 28px;
                    background: #000000;
                    border-color: #27272A;
                    border-width: 1px;
                    Text { text: root.selected_schedule_name; color: #FFFFFF; font-family: "PT Sans"; font-size: 18px; }
                }

                Rectangle {
                    x: 378px; y: 6px; width: 44px; height: 28px;
                    background: #10B981;
                    border-radius: 10px;
                    Text { text: root.is_ua ? "ЗБЕР" : "SAVE"; color: #000000; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { clicked => { root.editor_save(); } }
                }

                Rectangle {
                    x: 430px; y: 6px; width: 40px; height: 28px;
                    background: #27272A;
                    border-radius: 10px;
                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { clicked => { root.editor_back(); } }
                }

                VerticalBox {
                    x: 10px; y: 48px;
                    spacing: 6px;
                    for step[i] in root.editor_steps : Rectangle {
                        width: 460px; height: 50px;
                        background: #0F0F0F;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 10px;

                        Text { x: 10px; y: 14px; text: (i + 1); color: #A1A1AA; font-size: 12px; }
                        Rectangle {
                            x: 40px; y: 10px; width: 70px; height: 30px;
                            background: #27272A;
                            border-radius: 6px;
                            Text { text: step.is_hold ? "HOLD" : "RAMP"; color: #FFFFFF; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked => { root.editor_toggle_step(i); } }
                        }

                        Text {
                            x: 130px; y: 12px;
                            text: step.is_hold ? (step.hold + " min") : (step.target + " °C");
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px;
                        }

                        Rectangle {
                            x: 320px; y: 10px; width: 30px; height: 30px;
                            background: #27272A;
                            border-radius: 6px;
                            Text { text: "-"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked => { step.is_hold ? root.editor_hold_minus(i) : root.editor_target_minus(i); } }
                        }
                        Rectangle {
                            x: 360px; y: 10px; width: 30px; height: 30px;
                            background: #27272A;
                            border-radius: 6px;
                            Text { text: "+"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked => { step.is_hold ? root.editor_hold_plus(i) : root.editor_target_plus(i); } }
                        }
                        Rectangle {
                            x: 400px; y: 10px; width: 40px; height: 30px;
                            background: #7F1D1D;
                            border-radius: 6px;
                            Text { text: "X"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea { clicked => { root.editor_remove(i); } }
                        }
                    }

                    Rectangle {
                        width: 460px; height: 44px;
                        background: #0F0F0F;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 10px;
                        Text { text: "+ ADD STEP"; color: #A1A1AA; horizontal-alignment: center; vertical-alignment: center; }
                        TouchArea { clicked => { root.editor_add_step(); } }
                    }
                }
            }

        // Touch calibration
        if (root.view == View.Calibration) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: 280px;
                background: #000000;

                Text {
                    x: 18px; y: 12px;
                    text: root.is_ua ? "КАЛІБРУВАННЯ ТАЧ" : "TOUCH CALIBRATION";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px;
                }

                Text {
                    x: 18px; y: 38px; width: 444px;
                    text: root.calib_hint;
                    color: #A1A1AA;
                    font-family: "PT Sans";
                    font-size: 12px;
                }

                // target dot
                Rectangle {
                    x: root.calib_target_x * 1px - 14px;
                    y: root.calib_target_y * 1px - 14px;
                    width: 28px; height: 28px;
                    background: #00000000;
                    border-color: #10B981;
                    border-width: 2px;
                    border-radius: 14px;
                }
                Rectangle {
                    x: root.calib_target_x * 1px - 1px;
                    y: root.calib_target_y * 1px - 10px;
                    width: 2px; height: 20px;
                    background: #10B981;
                }
                Rectangle {
                    x: root.calib_target_x * 1px - 10px;
                    y: root.calib_target_y * 1px - 1px;
                    width: 20px; height: 2px;
                    background: #10B981;
                }

                Rectangle {
                    x: 140px; y: 210px; width: 200px; height: 52px;
                    background: #27272A;
                    border-radius: 12px;
                    Text { text: root.is_ua ? "СКАСУВАТИ" : "CANCEL"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { clicked => { root.cancel_touch_calibration(); } }
                }
        }
    }
    // Stop modal
    if (root.show_stop_confirm) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #000000B3;
            Rectangle {
                x: 60px; y: 50px; width: 360px; height: 220px;
                background: #0B0B0B;
                border-color: #3F3F46;
                border-width: 1px;
                border-radius: 18px;

                Rectangle {
                    x: 148px; y: 16px; width: 64px; height: 64px;
                    background: #7F1D1D;
                    border-radius: 32px;
                    Text { text: "!"; color: #EF4444; font-size: 28px; horizontal-alignment: center; vertical-alignment: center; }
                }

                Text {
                    x: 0px; y: 86px; width: 360px;
                    text: root.is_ua ? "Зупинити випал?" : "STOP FIRING?";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px;
                    horizontal-alignment: center;
                }

                Text {
                    x: 0px; y: 120px; width: 360px;
                    text: root.is_ua ? "Ви впевнені, що хочете зупинити процес?" : "Are you sure you want to abort the process?";
                    color: #A1A1AA;
                    font-size: 1