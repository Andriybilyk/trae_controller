    in property <length> settings_autotune_card_h: 90px;
    in property <length> settings_autotune_input_y: 32px;
    in property <length> settings_autotune_value_w: 130px;
    in property <length> settings_autotune_action_h: 44px;
    in property <length> settings_display_hw_h: 162px;
    in property <length> settings_display_hw_controls_y: 38px;
    in property <length> settings_display_hw_step_w: 64px;
    in property <length> settings_display_hw_value_w: 136px;
