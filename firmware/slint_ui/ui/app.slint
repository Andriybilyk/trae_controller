component UiButton {
    in property <string> label;
    in property <brush> background: #27272A;
    in property <brush> foreground: #FFFFFF;
    in property <length> radius: 10px;
    in property <length> text_size: 14px;
    in property <length> pad_h: 6px;
    in property <bool> bold: false;
    callback tapped();

    Rectangle {
        background: root.background;
        border-radius: root.radius;
        clip: true;
        Text {
            x: root.pad_h;
            y: 0px;
            width: parent.width - root.pad_h * 2;
            height: parent.height;
            text: root.label;
            color: root.foreground;
            font-family: "PT Sans";
            font-size: root.text_size;
            font-weight: root.bold ? 700 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.tapped(); }
        }
    }
}

component KbKeyButton {
    in property <string> label;
    in property <string> value: root.label;
    in property <brush> background: #27272A;
    in property <brush> text_color: #FFFFFF;
    in property <length> font_size: 16px;
    callback pressed(string);

    Rectangle {
        background: root.background;
        border-radius: 10px;
        Text {
            text: root.label;
            color: root.text_color;
            font-family: "PT Sans";
            font-size: root.font_size;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.pressed(root.value); }
        }
    }
}

component KbKeyRow {
    in property <[string]> keys;
    in property <length> key_width: 44px;
    in property <length> key_height: 30px;
    in property <length> gap: 2px;
    in property <length> start_x: 10px;
    in property <length> row_y: 0px;
    in property <length> font_size: 18px;
    callback key_pressed(string);

    for k[i] in root.keys : KbKeyButton {
        x: root.start_x + i * (root.key_width + root.gap);
        y: root.row_y;
        width: root.key_width;
        height: root.key_height;
        label: k;
        font_size: root.font_size;
        pressed(v) => { root.key_pressed(v); }
    }
}



export enum View { Dashboard, Schedules, ScheduleGraph, HistoryDetail, Editor, RunningEditor, Settings, Calibration }


export struct ScheduleRow {



    name: string,



    steps_count: int,



    selected: bool,



}



export struct EditorStepRow {



    step_type: string,



    rate: int,



    target: int,



    hold: int,



}

export struct ScheduleGraphRect {
    x: int,
    y: int,
    width: int,
    height: int,
    color: color,
}

export struct ScheduleGraphMarker {
    x: int,
    y: int,
    label: string,
    color: color,
}

export struct ScheduleGraphPoint {
    x: int,
    y: int,
    temp_label: string,
    time_label: string,
    color: color,
}

export struct HistoryPreviewCard {
    id: string,
    title: string,
    status: string,
    status_code: string,
    subtitle: string,
}

export struct FaultLogPreviewCard {
    title: string,
    status: string,
    subtitle: string,
    details: string,
}

export struct WifiNetworkRow {
    ssid: string,
    rssi: int,
}



export component AppWindow inherits Window {



    in-out property <int> board_profile_id: 0; // 0=legacy_s3, 1=new_p4
    in-out property <int> board_display_w: 480;
    in-out property <int> board_display_h: 320;
    width: root.board_display_w * 1px;
    height: root.board_display_h * 1px;
    background: Theme.color_bg;
    default-font-family: "PT Sans";

    // NewP4 runs at 800x480. The UI was originally designed for 480x320, so we scale layout metrics
    // and font sizes using a density multiplier (instead of Slint's HiDPI scaling) to keep touch
    // and pixel coordinates 1:1.
    property <float> density:
        root.board_profile_id == 1
            ? min((root.board_display_w * 1.0) / 480.0, (root.board_display_h * 1.0) / 320.0)
            : 1.0;

    property <color> c_bg: Theme.color_bg;
    property <color> c_panel: Theme.color_surface;
    property <color> c_card: Theme.color_surface;
    property <color> c_border: #24344F;
    property <color> c_text: Theme.color_text;
    property <color> c_muted: #9FB1C7;
    property <color> c_subtle: #7D8CA6;
    property <color> c_accent: Theme.color_accent;
    property <color> c_warn: #F59E0B;
    property <color> c_danger: #DC2626;
    property <length> edge_gap: Theme.padding_safe * root.density;
    property <length> top_bar_h: Theme.header_height * root.density;
    property <bool> show_header: !root.standby_visible && !root.boot_splash_visible;
    property <length> screen_w: root.width;
    property <length> screen_h: root.height;
    property <length> page_content_h: root.height - (root.show_header ? root.top_bar_h : 0px);

    // Dashboard layout metrics (used by the 2-column Dashboard view).
    property <length> dash_col_w: root.screen_w / 2;
    property <length> dash_pad_x: 10px * root.density;
    property <length> dash_pad_y: 12px * root.density;
    property <length> dash_gap: 12px * root.density;
    property <length> dash_card_w: root.dash_col_w - root.dash_pad_x * 2;
    property <length> dash_card_h: 150px * root.density;
    // Anchor bottom action row to the lower edge and keep safe bottom margin.
    property <length> dash_btn_row_h: (root.board_profile_id == 1 ? 92px : 94px) * root.density;
    property <length> dash_btn_row_y: root.page_content_h - root.dash_btn_row_h - (root.dash_pad_x + (root.board_profile_id == 1 ? 10px : 4px) * root.density);
    property <length> dash_btn_gap: 8px * root.density;
    property <length> dash_btn_w: (root.dash_card_w - root.dash_btn_gap) / 2;

    // Shared settings layout metrics (single source of truth for all Settings pages):
    // header row, nav buttons, content bounds, and first-block vertical rhythm.
    property <length> settings_side_gap: Theme.settings_side_gap * root.density;
    property <length> settings_right_gap: root.settings_side_gap;
    property <length> settings_content_width: root.screen_w - root.settings_side_gap - root.settings_right_gap;
    property <length> settings_grid_gap: Theme.settings_grid_gap * root.density;
    property <length> settings_vertical_gap: Theme.settings_vertical_gap * root.density;
    property <length> settings_header_h: Theme.settings_header_h * root.density;
    property <length> settings_icon_size: Theme.settings_icon_size * root.density;
    property <length> settings_title_x: root.settings_side_gap + root.settings_icon_size + 6px;
    property <length> settings_title_width: root.settings_content_width - root.settings_icon_size - (root.settings_nav_btn_w * 2 + root.settings_nav_gap) - 12px;
    property <length> settings_nav_btn_w: Theme.settings_nav_btn_w * root.density;
    property <length> settings_nav_btn_h: Theme.settings_nav_btn_h * root.density;
    property <length> settings_nav_gap: Theme.settings_nav_gap * root.density;
    property <length> settings_close_btn_x: root.settings_side_gap + root.settings_content_width - root.settings_nav_btn_w;
    property <length> settings_back_btn_x: root.settings_close_btn_x - root.settings_nav_gap - root.settings_nav_btn_w;
    property <length> settings_panel_x: root.settings_side_gap;
    property <length> settings_panel_y: root.settings_first_block_y;
    property <length> settings_panel_w: root.settings_content_width;
    property <length> settings_primary_card_h: Theme.settings_primary_card_h * root.density;
    property <length> settings_secondary_row_y: root.settings_primary_card_h + root.settings_vertical_gap;
    property <length> settings_display_row_h: Theme.settings_display_row_h * root.density;
    property <length> settings_display_row_step: root.settings_display_row_h + root.settings_vertical_gap;
    property <length> settings_display_btn_y: (root.settings_display_row_h - root.settings_btn_height) / 2;
    property <length> settings_col_width: (root.settings_content_width - root.settings_grid_gap) / 2;
    property <length> settings_inner_pad: Theme.settings_inner_pad * root.density;
    property <length> settings_two_col_btn_w: (root.settings_content_width - root.settings_inner_pad * 2 - root.settings_grid_gap - 8px) / 2;
    property <length> settings_title_y: Theme.settings_title_y * root.density;
    property <length> settings_header_gap: Theme.settings_header_gap * root.density;
    property <length> settings_content_y: root.settings_title_y + root.settings_header_h + root.settings_header_gap;
    property <length> settings_first_block_y: root.settings_content_y;
    property <length> settings_content_height: root.page_content_h - root.settings_first_block_y - root.settings_side_gap;
    property <length> settings_btn_height: Theme.settings_btn_height * root.density;
    property <length> settings_btn_radius: Theme.settings_btn_radius * root.density;
    property <length> settings_btn_text_size: Theme.settings_btn_text_size * root.density;
    property <length> settings_editor_content_w: root.screen_w - root.settings_side_gap * 2 - ((132px * root.density) + root.settings_nav_gap + root.settings_nav_btn_w + root.settings_grid_gap * 2);
    property <length> settings_card_h: Theme.settings_card_h * root.density;
    property <length> settings_card_gap: Theme.settings_card_gap * root.density;
    property <length> settings_card_step: root.settings_card_h + root.settings_card_gap;
    property <length> settings_list_row_h: Theme.settings_list_row_h * root.density;
    property <length> settings_list_gap: Theme.settings_list_gap * root.density;
    property <length> settings_list_step: root.settings_list_row_h + root.settings_list_gap;
    property <length> settings_label_y: Theme.settings_label_y * root.density;
    property <length> settings_fan_card_h: Theme.settings_fan_card_h * root.density;
    property <length> settings_fan_toggle_w: Theme.settings_fan_toggle_w * root.density;
    property <length> settings_fan_controls_y: Theme.settings_fan_controls_y * root.density;
    property <length> settings_fan_minus_w: Theme.settings_fan_minus_w * root.density;
    property <length> settings_fan_value_w: Theme.settings_fan_value_w * root.density;
    property <length> settings_fan_plus_w: Theme.settings_fan_plus_w * root.density;
    property <length> settings_autotune_card_h: Theme.settings_autotune_card_h * root.density;
    property <length> settings_autotune_input_y: Theme.settings_autotune_input_y * root.density;
    property <length> settings_autotune_value_w: Theme.settings_autotune_value_w * root.density;
    property <length> settings_autotune_action_h: Theme.settings_autotune_action_h * root.density;
    property <length> settings_display_hw_h: Theme.settings_display_hw_h * root.density;
    property <length> settings_display_hw_controls_y: Theme.settings_display_hw_controls_y * root.density;
    property <length> settings_display_hw_step_w: Theme.settings_display_hw_step_w * root.density;
    property <length> settings_display_hw_value_w: Theme.settings_display_hw_value_w * root.density;
    property <length> settings_display_hw_max_w: Theme.settings_display_hw_max_w * root.density;
    property <length> settings_display_hw_calib_h: Theme.settings_display_hw_calib_h * root.density;
    property <length> settings_action_btn_h: Theme.settings_action_btn_h * root.density;
    property <length> settings_action_btn_radius: Theme.settings_action_btn_radius * root.density;

    // Status styling (based on status_label coming from firmware: IDLE/RAMP/ERROR/...).

    // Keep RAMP green like in your reference UI; only ERROR is red.

    property <color> status_fg: root.status_label == "ERROR" ? c_danger : c_accent;

    property <color> status_bg: root.status_label == "ERROR" ? #2A0B0B : #062016;

    in-out property <View> view: View.Dashboard;

    in-out property <bool> show_stop_confirm: false;
    in-out property <bool> show_skip_confirm: false;
    in-out property <bool> show_running_edit_confirm: false;
    in-out property <bool> show_touch_confirm: false;
    in-out property <bool> boot_splash_visible: true;
    in-out property <bool> standby_visible: false;

    in-out property <bool> is_ua: false;



    in-out property <string> current_time: "00:00";
    in-out property <string> current_date: "--.--.----";



    in-out property <float> temp: 24.5;



    in-out property <string> temp_label: "24.5";
    in-out property <string> temp_hint: "";
    in-out property <string> temp_unit: "C";
    in-out property <string> temp_unit_label: "\u{00B0}C";
    in-out property <string> rate_unit_label: "\u{00B0}C/h";
    in-out property <string> rate_unit_label_min: "\u{00B0}C/min";
    in-out property <string> time_format: "24";
    in-out property <string> date_format: "DMY";
    in-out property <int> display_brightness: 80;
    in-out property <float> ui_dim: 0.0;



    in-out property <int> target: 0;
    in-out property <int> active_segment_target: 0;
    in-out property <int> standby_power_watts: 0;
    in-out property <string> pzem_power_label: "-- W";
    in-out property <string> pzem_current_label: "-- A";
    in-out property <string> pzem_voltage_label: "-- V";
    in-out property <string> pzem_phase_label: "Phase: --";
    in-out property <[HistoryPreviewCard]> history_items;
    in-out property <[FaultLogPreviewCard]> fault_log_items;



    in-out property <string> status_label: "IDLE";
    property <string> status_text: root.is_ua
        ? (root.status_label == "IDLE" ? "\u{041E}\u{0427}\u{0406}\u{041A}\u{0423}\u{0412}\u{0410}\u{041D}\u{041D}\u{042F}"
          : root.status_label == "PREHEAT" ? "\u{041F}\u{0406}\u{0414}\u{0406}\u{0413}\u{0420}\u{0406}\u{0412}"
          : root.status_label == "RAMP" ? "\u{041D}\u{0410}\u{0413}\u{0420}\u{0406}\u{0412}"
          : root.status_label == "HOLD" ? "\u{0412}\u{0418}\u{0422}\u{0420}\u{0418}\u{041C}\u{041A}\u{0410}"
          : root.status_label == "COOL" ? "\u{041E}\u{0425}\u{041E}\u{041B}\u{041E}\u{0414}\u{0416}\u{0415}\u{041D}\u{041D}\u{042F}"
          : root.status_label == "COMPLETE" ? "\u{0417}\u{0410}\u{0412}\u{0415}\u{0420}\u{0428}\u{0415}\u{041D}\u{041E}"
          : root.status_label == "ERROR" ? "\u{041F}\u{041E}\u{041C}\u{0418}\u{041B}\u{041A}\u{0410}"
          : root.status_label == "TUNING" ? "\u{0410}\u{0412}\u{0422}\u{041E}\u{041D}\u{0410}\u{041B}."
          : root.status_label)
        : root.status_label;
    property <int> display_target_value: !root.is_idle && root.active_segment_target > 0 ? root.active_segment_target : root.target;



    in-out property <bool> is_idle: true;



    in-out property <int> step_index: 0;



    in-out property <int> total_steps: 0;



    in-out property <string> time_remaining: "--:--";
    in-out property <string> step_time_remaining: "--:--";
    in-out property <string> firing_time_remaining: "--:--";



    in-out property <string> selected_schedule_name: "";



    in-out property <int> selected_steps_count: 0;



    in-out property <bool> wifi_ok: false;
    in-out property <bool> header_wifi_ok: false;



    in-out property <int> touch_x: 0;



    in-out property <int> touch_y: 0;



    in-out property <int> touch_z: 0;



    in-out property <bool> touch_pressed: false;
    in-out property <int> touch_debug_x: 0;
    in-out property <int> touch_debug_y: 0;
    in-out property <bool> touch_debug_pressed: false;



    in-out property <[ScheduleRow]> schedules;



    in-out property <[EditorStepRow]> editor_steps;



    in-out property <bool> fault_active: false;



    in-out property <string> fault_reason: "";
    in-out property <bool> fault_popup_hidden: false;



    in-out property <int> calib_step: 0;



    in-out property <string> calib_hint: "";



    in-out property <int> calib_target_x: 40;



    in-out property <int> calib_target_y: 60;

    // Bottom numeric keyboard (editor)
    in-out property <bool> kb_visible: false;
    in-out property <string> kb_value: "";
    in-out property <int> kb_step_index: -1;
    in-out property <string> kb_field: "";
    in-out property <string> kb_mode: "num";
    in-out property <bool> kb_caps: false;
    in-out property <string> settings_page: "all";
    in-out property <bool> delete_confirm_visible: false;
    in-out property <int> delete_confirm_index: -1;

    // Fan (manual override + power %)
    in-out property <bool> fan_manual: false;
    in-out property <int> fan_power: 0;
    in-out property <int> thermocouple_offset: 0;
    in-out property <int> kiln_wattage: 0;
    in-out property <int> autotune_target_c: 600;
    in-out property <int> schedule_target_max_c: 1300;
    in-out property <[WifiNetworkRow]> wifi_networks;
    in-out property <bool> wifi_picker_visible: false;
    in-out property <bool> wifi_scan_busy: false;
    in-out property <string> wifi_selected_ssid: "";
    in-out property <string> wifi_password: "";
    in-out property <string> wifi_server_url: "http://192.168.4.1";
    in-out property <bool> wifi_qr_visible: false;
    in-out property <image> wifi_qr_image;
    in-out property <string> wifi_qr_hint: "";
    in-out property <string> command_feedback: "";
    in-out property <bool> command_feedback_ok: true;
    in-out property <bool> command_feedback_visible: false;
    in-out property <int> running_edit_add_temp: 0;
    in-out property <int> running_edit_add_time: 0;
    in-out property <int> running_edit_rate: 100;
    in-out property <[ScheduleGraphRect]> schedule_graph_rects;
    in-out property <[ScheduleGraphMarker]> schedule_graph_markers;
    in-out property <[ScheduleGraphPoint]> schedule_graph_points;
    in-out property <int> schedule_graph_peak_temp: 0;
    in-out property <int> schedule_graph_mid_temp: 0;
    in-out property <string> schedule_graph_total_label: "0 min";
    in-out property <string> schedule_graph_half_label: "0 min";
    in-out property <bool> schedule_graph_tip_visible: false;
    in-out property <int> schedule_graph_tip_x_px: 0;
    in-out property <int> schedule_graph_tip_y_px: 0;
    in-out property <int> schedule_graph_tip_w_px: 156;
    in-out property <int> schedule_graph_tip_h_px: 58;
    in-out property <string> schedule_graph_tip_temp: "";
    in-out property <string> schedule_graph_tip_time: "";
    in-out property <bool> schedule_graph_back_to_history: false;
    in-out property <int> schedule_graph_zoom_level: 0;
    in-out property <int> schedule_graph_plot_x_px: root.board_profile_id == 1 ? 72 : 40;
    in-out property <int> schedule_graph_plot_w_px: root.board_profile_id == 1 ? 642 : 426;
    in-out property <int> schedule_graph_plot_h_px: root.board_profile_id == 1 ? 304 : 212;
    property <length> schedule_graph_plot_x: root.schedule_graph_plot_x_px * 1px;
    property <length> schedule_graph_plot_w: root.schedule_graph_plot_w_px * 1px;
    property <length> schedule_graph_plot_h: root.schedule_graph_plot_h_px * 1px;
    in-out property <string> history_detail_title: "";
    in-out property <string> history_detail_status: "";
    in-out property <string> history_detail_duration: "";
    in-out property <string> history_detail_steps: "";
    in-out property <string> history_detail_energy: "";
    in-out property <string> history_detail_step_durations: "";
    in-out property <string> history_detail_program_name: "--";
    in-out property <string> history_detail_start_time: "--";
    in-out property <string> history_detail_end_time: "--";
    in-out property <string> history_detail_status_verbose: "--";
    in-out property <string> history_detail_energy_cost: "--";
    in-out property <string> history_detail_max_load: "--";
    in-out property <string> history_detail_peak_temp: "--";
    in-out property <string> history_detail_voltage_stability: "--";
    in-out property <string> history_detail_step_plan_actual: "--";
    in-out property <string> controller_info_fw: "--";
    in-out property <string> controller_info_heap: "--";
    in-out property <string> controller_info_ram: "--";
    in-out property <string> controller_info_storage: "--";
    in-out property <string> controller_info_device_id: "--";
    in-out property <string> controller_info_uptime: "--";
    in-out property <string> controller_info_heating_hours: "--";
    in-out property <string> controller_info_chip_temp: "--";
    in-out property <string> controller_info_pzem: "--";
    in-out property <bool> fault_log_detail_visible: false;
    in-out property <string> fault_log_detail_title: "";
    in-out property <string> fault_log_detail_status: "";
    in-out property <string> fault_log_detail_text: "";

    callback toggle_language();
    callback display_brightness_changed(int);



    callback start_firing();



    callback stop_firing();



    callback open_library();
    callback open_selected_program();
    callback open_running_editor();
    callback open_history();
    callback open_fault_logs();
    callback open_fault_log_detail(int);
    callback close_fault_log_detail();
    callback open_schedule_graph(int);
    callback open_history_detail(int);
    callback open_history_graph(int);
    callback schedule_graph_zoom_in();
    callback schedule_graph_zoom_out();
    callback schedule_graph_zoom_reset();
    callback schedule_graph_point_tapped(int);

    callback set_temp_unit(string);
    callback set_time_format(string);
    callback set_date_format(string);



    callback select_schedule(int);



    callback edit_schedule(int);
    callback delete_schedule(int);



    callback new_schedule();



    callback editor_back();



    callback editor_save();



    callback editor_add_step();



    callback editor_rate_changed(int, string);



    callback editor_target_changed(int, string);



    callback editor_hold_changed(int, string);



