    in property <length> settings_list_row_h: 68px;
    in property <length> settings_list_gap: 8px;
    in property <length> settings_display_row_h: 64px;
    in property <length> settings_primary_card_h: 84px;
    in property <length> settings_label_y: 8px;
    in property <length> settings_fan_card_h: 82px;
    in property <length> settings_fan_toggle_w: 96px;
    in property <length> settings_fan_controls_y: 42px;
    in property <length> settings_fan_minus_w: 60px;
