import { VerticalBox, HorizontalBox, ScrollView } from "std-widgets.slint";
// UI layout tweaks for touch usability

import "../../data/fonts/sketch_260307b/FontFiles/PTSans-Regular.ttf";



import "../../data/fonts/sketch_260307b/FontFiles/PTSans-Bold.ttf";



import "fonts/MaterialIcons-Regular.ttf";



component PlayIcon {

    in property <brush> color: #000000;

    width: 18px;
    height: 16px;

    Text {

        width: parent.width; height: parent.height;

        text: "\u{e037}";

        color: root.color;

        font-family: "Material Icons";

        font-size: 20px;

        horizontal-alignment: center;

        vertical-alignment: center;

    }

}



component StopIcon {

    in property <brush> color: #FFFFFF;

    width: 16px;

    height: 16px;

    Text {

        width: parent.width; height: parent.height;

        text: "\u{e047}";

        color: root.color;

        font-family: "Material Icons";

        font-size: 20px;

        horizontal-alignment: center;

        vertical-alignment: center;

    }

}



component ActivityIcon {

    in property <brush> color: #10B981;

    width: 16px;

    height: 16px;

    Text {

        width: parent.width; height: parent.height;

        text: "\u{eaa2}";

        color: root.color;

        font-family: "Material Icons";

        font-size: 20px;

        horizontal-alignment: center;

        vertical-alignment: center;

    }

}



component WifiIcon {

    in property <brush> color: #10B981;

    width: 16px;

    height: 18px;
    Text {

        width: parent.width; height: parent.height;

        text: "\u{e63e}";

        color: root.color;

        font-family: "Material Icons";

        font-size: 20px;
        horizontal-alignment: center;

        vertical-alignment: center;

    }

}

component SettingsIcon {
    in property <color> color: #FFFFFF;
    width: 24px; height: 24px;
    Text {
        width: parent.width; height: parent.height;
        text: "\u{e8b8}";
        color: root.color;
        font-family: "Material Icons";
        font-size: 22px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}



component ThermometerIcon {

    in property <brush> color: #FFFFFF;

    width: 16px;

    height: 16px;

    Text {

        width: parent.width; height: parent.height;

        text: "\u{e1ff}";

        color: root.color;

        font-family: "Material Icons";

        font-size: 20px;

        horizontal-alignment: center;

        vertical-alignment: center;

    }

}



// Shared primitives for unified UI style.
component UiCard {
    in property <brush> background: #111118;
    in property <brush> border_color: #27272A;
    in property <length> border_w: 1px;
    in property <length> radius: 12px;

    Rectangle {
        background: root.background;
        border-color: root.border_color;
        border-width: root.border_w;
        border-radius: root.radius;
        clip: true;
    }
}

component UiButton {
    in property <string> label;
    in property <brush> background: #27272A;
    in property <brush> foreground: #FFFFFF;
    in property <length> radius: 10px;
    in property <length> text_size: 15px;
    in property <length> pad_h: 10px;
    in property <bool> bold: false;
    callback tapped();

    Rectangle {
        background: root.background;
        border-radius: root.radius;
        clip: true;
        Text {
            x: root.pad_h;
            y: 0px;
            width: parent.width - root.pad_h * 2;
            height: parent.height;
            text: root.label;
            color: root.foreground;
            font-family: "PT Sans";
            font-size: root.text_size;
            font-weight: root.bold ? 700 : 400;
            horizontal-alignment: center;
            vertical-alignment: center;
            overflow: elide;
        }
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.tapped(); }
        }
    }
}

component KbKeyButton {
    in property <string> label;
    in property <string> value: root.label;
    in property <brush> background: #27272A;
    in property <brush> text_color: #FFFFFF;
    in property <length> font_size: 16px;
    callback pressed(string);

    Rectangle {
        background: root.background;
        border-radius: 10px;
        Text {
            text: root.label;
            color: root.text_color;
            font-family: "PT Sans";
            font-size: root.font_size;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.pressed(root.value); }
        }
    }
}

component KbKeyRow {
    in property <[string]> keys;
    in property <length> key_width: 44px;
    in property <length> key_height: 30px;
    in property <length> gap: 2px;
    in property <length> start_x: 10px;
    in property <length> row_y: 0px;
    in property <length> font_size: 18px;
    callback key_pressed(string);

    for k[i] in root.keys : KbKeyButton {
        x: root.start_x + i * (root.key_width + root.gap);
        y: root.row_y;
        width: root.key_width;
        height: root.key_height;
        label: k;
        font_size: root.font_size;
        pressed(v) => { root.key_pressed(v); }
    }
}



export enum View { Dashboard, Schedules, Editor, RunningEditor, Settings, Calibration }


export struct ScheduleRow {



    name: string,



    steps_count: int,



    selected: bool,



}



export struct EditorStepRow {



    step_type: string,



    rate: int,



    target: int,



    hold: int,



}

export struct WifiNetworkRow {
    ssid: string,
    rssi: int,
}



export component AppWindow inherits Window {



    width: 480px;



    height: 320px;



    background: #000000;



    default-font-family: "PT Sans";



    // Theme (keep it explicit; easier to tweak without hunting literals).

    // Use mostly neutral greys (R=G=B) so the panel looks consistent and doesn't drift "blue/yellow".

    property <color> c_bg: #000000;

    property <color> c_panel: #000000;

    property <color> c_card: #111118;

    property <color> c_border: #27272A;

    property <color> c_text: #FFFFFF;

    property <color> c_muted: #A1A1AA;

    property <color> c_subtle: #71717A;

    property <color> c_accent: #00D084;

    property <color> c_warn: #F59E0B;

    property <color> c_danger: #DC2626;
    property <length> edge_gap: 10px;
    property <length> top_bar_h: 40px;
    property <length> page_content_h: 280px;

    // Shared settings layout metrics (keeps panels symmetric and avoids clipping).
    property <length> settings_side_gap: root.edge_gap;
    property <length> settings_content_width: 460px;
    property <length> settings_title_y: 8px;
    property <length> settings_content_y: 44px;
    property <length> settings_content_height: 214px;
    property <length> settings_btn_height: 34px;
    property <length> settings_btn_radius: 10px;
    property <length> settings_btn_text_size: 15px;

    // Status styling (based on status_label coming from firmware: IDLE/RAMP/ERROR/...).

    // Keep RAMP green like in your reference UI; only ERROR is red.

    property <color> status_fg: root.status_label == "ERROR" ? c_danger : c_accent;

    property <color> status_bg: root.status_label == "ERROR" ? #2A0B0B : #062016;

    in-out property <View> view: View.Dashboard;

    in-out property <bool> show_stop_confirm: false;
    in-out property <bool> show_skip_confirm: false;
    in-out property <bool> show_running_edit_confirm: false;
    in-out property <bool> boot_splash_visible: true;
    in-out property <bool> standby_visible: false;

    in-out property <bool> is_ua: false;



    in-out property <string> current_time: "00:00";
    in-out property <string> current_date: "--.--.----";



    in-out property <float> temp: 24.5;



    in-out property <string> temp_label: "24.5";
    in-out property <string> temp_unit: "C";
    in-out property <string> temp_unit_label: "°C";
    in-out property <string> rate_unit_label: "°C/h";
    in-out property <string> rate_unit_label_min: "°C/min";
    in-out property <string> time_format: "24";
    in-out property <string> date_format: "DMY";
    in-out property <int> display_brightness: 80;
    in-out property <float> ui_dim: 0.0;



    in-out property <int> target: 0;
    in-out property <int> active_segment_target: 0;
    in-out property <int> standby_power_watts: 0;



    in-out property <string> status_label: "IDLE";



    in-out property <bool> is_idle: true;



    in-out property <int> step_index: 0;



    in-out property <int> total_steps: 0;



    in-out property <string> time_remaining: "--:--";



    in-out property <string> selected_schedule_name: "";



    in-out property <int> selected_steps_count: 0;



    in-out property <bool> wifi_ok: true;



    in-out property <int> touch_x: 0;



    in-out property <int> touch_y: 0;



    in-out property <int> touch_z: 0;



    in-out property <bool> touch_pressed: false;
    in-out property <int> touch_debug_x: 0;
    in-out property <int> touch_debug_y: 0;
    in-out property <bool> touch_debug_pressed: false;



    in-out property <[ScheduleRow]> schedules;



    in-out property <[EditorStepRow]> editor_steps;



    in-out property <bool> fault_active: false;



    in-out property <string> fault_reason: "";
    in-out property <bool> fault_popup_hidden: false;



    in-out property <int> calib_step: 0;



    in-out property <string> calib_hint: "";



    in-out property <int> calib_target_x: 40;



    in-out property <int> calib_target_y: 60;

    // Bottom numeric keyboard (editor)
    in-out property <bool> kb_visible: false;
    in-out property <string> kb_value: "";
    in-out property <int> kb_step_index: -1;
    in-out property <string> kb_field: "";
    in-out property <string> kb_mode: "num";
    in-out property <bool> kb_caps: false;
    in-out property <string> settings_page: "all";
    in-out property <bool> delete_confirm_visible: false;
    in-out property <int> delete_confirm_index: -1;

    // Fan (manual override + power %)
    in-out property <bool> fan_manual: false;
    in-out property <int> fan_power: 0;
    in-out property <int> autotune_target_c: 600;
    in-out property <int> schedule_target_max_c: 1300;
    in-out property <[WifiNetworkRow]> wifi_networks;
    in-out property <bool> wifi_picker_visible: false;
    in-out property <bool> wifi_scan_busy: false;
    in-out property <string> wifi_selected_ssid: "";
    in-out property <string> wifi_password: "";
    in-out property <string> wifi_server_url: "http://192.168.4.1";
    in-out property <bool> wifi_qr_visible: false;
    in-out property <image> wifi_qr_image;
    in-out property <string> wifi_qr_hint: "";
    in-out property <string> command_feedback: "";
    in-out property <bool> command_feedback_ok: true;
    in-out property <bool> command_feedback_visible: false;
    in-out property <int> running_edit_add_temp: 0;
    in-out property <int> running_edit_add_time: 0;
    in-out property <int> running_edit_rate: 100;

    callback toggle_language();
    callback display_brightness_changed(int);



    callback start_firing();



    callback stop_firing();



    callback open_library();
    callback open_selected_program();
    callback open_running_editor();

    callback set_temp_unit(string);
    callback set_time_format(string);
    callback set_date_format(string);



    callback select_schedule(int);



    callback edit_schedule(int);
    callback delete_schedule(int);



    callback new_schedule();



    callback editor_back();



    callback editor_save();



    callback editor_add_step();



    callback editor_rate_changed(int, string);



    callback editor_target_changed(int, string);



    callback editor_hold_changed(int, string);



    callback editor_remove(int);



    callback stop_confirm();



    callback stop_cancel();
    callback skip_step();
    callback skip_confirm();
    callback skip_cancel();
    callback running_edit_back();
    callback running_edit_apply();
    callback running_edit_confirm();
    callback running_edit_cancel();
    callback running_edit_temp_changed(string);
    callback running_edit_time_changed(string);
    callback running_edit_rate_changed(string);



    callback start_touch_calibration();



    callback cancel_touch_calibration();

    callback fan_manual_changed(bool);



    callback fan_power_changed(int);
    callback autotune_start(int);
    callback autotune_stop();
    callback clear_fault();
    callback wifi_open_picker();
    callback wifi_disconnect();
    callback wifi_qr_toggle();

    callback kb_key(string);
    callback kb_open(string, int, string);

    // Touch debug dot (shows where the touch is detected)



    Rectangle {



        width: 6px;



        height: 6px;



        x: (min(max(root.touch_debug_x - 3, 0), 480 - 6)) * 1px;



        y: (min(max(root.touch_debug_y - 3, 0), 320 - 6)) * 1px;



        background: #FFFFFF;



        border-radius: 3px;



        visible: root.touch_debug_pressed;



        z: 999;



    }



    // Header bar
    Rectangle {
        x: 0px; y: 0px;
        width: 480px; height: 40px;
        background: #111118;
        border-color: #27272A;
        border-width: 1px;

        Text {
            x: 12px; y: 4px;
            width: 190px; height: 32px;
            text: "NOVA KILN";
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1.4px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        HorizontalBox {
            x: parent.width - self.width - 10px;
            y: 4px;
            width: 268px;
            height: 32px;
            alignment: end;
            spacing: 6px;

            Rectangle {
                width: 120px; height: parent.height;
                background: #00000000;
                Text {
                    x: 0px; y: 0px; width: parent.width; height: parent.height;
                    text: root.current_time + "  " + root.current_date;
                    color: #A1A1AA;
                    font-family: "PT Sans";
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                width: 38px; height: parent.height;
                background: #27272A;
                border-radius: 6px;
                Text {
                    text: root.is_ua ? "UA" : "EN";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_language(); } }
            }

            Rectangle {
                width: 32px; height: parent.height;
                background: #00000000;
                WifiIcon {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: 22px; height: 22px;
                    color: root.wifi_ok ? #10B981 : #52525B;
                }
                TouchArea {
                    x: -6px; y: -6px;
                    width: parent.width + 12px;
                    height: parent.height + 12px;
                    clicked => { root.settings_page = "wifi"; root.view = View.Settings; }
                }
            }

            Rectangle {
                width: 32px; height: parent.height;
                background: #00000000;
                SettingsIcon {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: 22px; height: 22px;
                    color: #A1A1AA;
                }
                TouchArea {
                    x: -6px; y: -6px;
                    width: parent.width + 12px;
                    height: parent.height + 12px;
                    clicked => { root.settings_page = "all"; root.view = View.Settings; }
                }
            }
        }
    }



    if (root.fault_active && !root.fault_popup_hidden) : Rectangle {
        x: 30px; y: 108px;
        width: 420px; height: 84px;
        background: #7F1D1D;
        border-color: #DC2626;
        border-width: 2px;
        border-radius: 10px;
        z: 1200;
        Text {
            x: 16px; y: 14px;
            width: parent.width - 64px;
            text: root.fault_reason == ""
                ? (root.is_ua ? "ПОМИЛКА" : "FAULT")
                : ((root.is_ua ? "ПОМИЛКА: " : "FAULT: ") + root.fault_reason);
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 14px;
            horizontal-alignment: center;
            overflow: elide;
        }
        Rectangle {
            x: parent.width - 46px;
            y: 8px;
            width: 34px;
            height: 34px;
            border-radius: 17px;
            background: #991B1B;
            border-color: #DC2626;
            border-width: 1px;
            Text {
                text: "×";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 24px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.fault_popup_hidden = true; }
            }
        }
    }

    if (root.command_feedback_visible) : Rectangle {
        x: 0px;
        y: 40px;
        width: 480px;
        height: 24px;
        background: root.command_feedback_ok ? #064E3B : #7F1D1D;
        border-color: root.command_feedback_ok ? #10B981 : #DC2626;
        border-width: 1px;
        Text {
            x: 10px;
            y: 5px;
            width: parent.width - 20px;
            text: root.command_feedback;
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 12px;
            overflow: elide;
        }
    }

    // Main content



    Rectangle {



        x: 0px; y: 40px;



        width: 480px; height: 280px;



        background: root.c_bg;



        



// Dashboard View



        if (root.view == View.Dashboard) : ScrollView {
            x: 0px; y: 0px;
            width: 480px; height: 280px;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            mouse-drag-pan-enabled: true;

            Rectangle {
                width: 480px; height: 280px;
                background: root.c_bg;



            // Left column



            Rectangle {



                x: 0px; y: 0px;



                width: 240px; height: 280px;



                background: root.c_bg;



                border-color: root.c_border;



                border-width: 1px;



                Text {



                    x: 16px; y: 12px;



                    text: root.is_ua ? "ПОТОЧНА\nТЕМПЕРАТУРА" : "CURRENT\nTEMPERATURE";



                    color: root.c_muted;



                    font-family: "PT Sans";



                    font-size: 12px;



                    letter-spacing: 0.5px;



                }



                Rectangle {
                    x: root.is_ua ? 120px : 148px; y: 12px;
                    width: root.is_ua
                        ? (root.status_label == "IDLE" ? 106px
                           : root.status_label == "COOL" ? 106px
                           : root.status_label == "COMPLETE" ? 98px
                           : root.status_label == "ERROR" ? 86px
                           : 82px)
                        : (root.status_label == "ERROR" ? 78px : 70px);
                    height: 26px;
                    background: root.status_bg;
                    border-color: root.status_fg;
                    border-width: root.status_label == "ERROR" ? 2px : 1px;
                    border-radius: 13px;

                    Text {
                        text: root.is_ua
                            ? (root.status_label == "IDLE" ? "ОЧІКУВАННЯ"
                              : root.status_label == "PREHEAT" ? "ПІДІГРІВ"
                              : root.status_label == "RAMP" ? "НАГРІВ"
                              : root.status_label == "HOLD" ? "ВИТРИМКА"
                              : root.status_label == "COOL" ? "ОХОЛОДЖЕННЯ"
                              : root.status_label == "COMPLETE" ? "ЗАВЕРШЕНО"
                              : root.status_label == "ERROR" ? "ПОМИЛКА"
                              : root.status_label == "TUNING" ? "АВТОНАЛ."
                              : root.status_label)
                            : root.status_label;
                        color: root.status_fg;
                        font-family: "PT Sans";
                        font-size: root.is_ua ? 12px : 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }



                Text {



                    x: 16px; y: 60px;



                    text: root.temp_label;



                    color: #FFFFFF;



                    font-family: "PT Sans";



                    font-size: 64px;



                    font-weight: 700;



                }



                Text {



                    x: 168px; y: 70px;



                    text: root.temp_unit_label;


                    color: root.c_text;



                    font-family: "PT Sans";



                    font-size: 30px;



                }



                Rectangle {



                    x: 12px; y: 176px;



                    width: 216px; height: 92px;



                    background: root.c_card;



                    border-color: root.c_border;



                    border-width: 1px;



                    border-radius: 14px;



                    Text {



                        x: 12px; y: 10px;



                        text: root.is_ua ? "Температура" : "Temperature";



                        color: root.c_muted;



                        font-family: "PT Sans";



                        font-size: 14px;



                    }



                    Text {



                        x: 140px; y: 8px;



                        text: root.target + root.temp_unit_label;


                        color: root.c_text;



                        font-family: "PT Sans";



                        font-size: 18px;



                    }



                    Rectangle {



                        x: 12px; y: 88px;



                        width: 192px; height: 4px;



                        background: root.c_border;



                        border-radius: 2px;



                        Rectangle {



                            width: root.target > 0 ? min((root.temp / root.target) * 192px, 192px) : 0px;



                            height: 4px;



                            background: root.status_fg;



                            border-radius: 2px;



                        }



                    }



                }



            }



            // Right column



            Rectangle {



                x: 240px; y: 0px;



                width: 240px; height: 280px;



                background: root.c_bg;



                Rectangle {



                    x: 10px; y: 12px;



                    width: 220px; height: 150px;



                    background: root.c_card;



                    border-color: root.c_border;



                    border-width: 1px;



                    border-radius: 16px;



                    if (root.is_idle && root.selected_schedule_name == "") : Rectangle {



                        width: 220px; height: 150px;



                        background: #00000000;



                        ActivityIcon {



                            x: (parent.width - self.width) / 2;



                            y: 50px;



                            color: #3F3F46;



                            width: 32px; height: 32px;



                        }



                        Text {



                            x: 0px; y: 92px;



                            width: 220px;



                            text: root.is_ua ? "Виберіть програму" : "Select Schedule";



                            color: root.c_muted;



                            font-family: "PT Sans";



                            font-size: 18px;


                            horizontal-alignment: center;



                        }



                    }



                    if (root.is_idle && root.selected_schedule_name != "") : Rectangle {



                        width: 220px; height: 150px;



                        background: #00000000;



                        Text {



                            x: 0px; y: 18px;



                            width: 220px;



                            text: root.is_ua ? "Вибрана програма" : "Selected Program";



                            color: root.c_accent;



                            font-family: "PT Sans";



                            font-size: 16px;
                            font-weight: 700;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px; y: 44px;



                            width: 220px;



                            text: root.selected_schedule_name;



                            color: #FFFFFF;



                            font-family: "PT Sans";



                            font-size: 20px;
                            font-weight: 700;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px; y: 68px;



                            width: 220px;



                            text: root.selected_steps_count + " " + (root.is_ua ? "кроків" : "segments");



                            color: root.c_subtle;



                            font-size: 16px;



                            horizontal-alignment: center;



                        }



                    }



                    if (!root.is_idle) : Rectangle {



                        width: 220px; height: 150px;



                        background: #00000000;



                        Rectangle {
                            x: 10px; y: 6px;
                            width: 200px; height: 102px;
                            border-radius: 12px;
                            background: #18181B;
                            border-color: #27272A;
                            border-width: 1px;
                        }

                        Text {



                            x: 0px; y: 14px;



                            width: 220px;



                            text: root.is_ua ? "Крок" : "Step";



                            color: root.c_muted;



                            font-size: 14px;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px; y: 36px;



                            width: 220px;



                            text: root.step_index + " / " + root.total_steps;



                            color: #FFFFFF;



                            font-family: "PT Sans";



                            font-size: 28px;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px; y: 66px;



                            width: 220px;



                            text: root.is_ua
                                ? ("Ціль " + root.active_segment_target + root.temp_unit_label)
                                : ("Target " + root.active_segment_target + root.temp_unit_label);



                            color: #71717A;



                            font-size: 14px;



                            horizontal-alignment: center;



                        }

                        Rectangle {
                            x: 10px; y: 116px;
                            width: 200px; height: 30px;
                            border-radius: 10px;
                            background: root.c_danger;
                            Text {
                                text: root.is_ua ? "Пропустити крок" : "Skip Step";
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_step(); } }
                        }



                    }



                    if (root.is_idle) : TouchArea {



                width: parent.width; height: parent.height; clicked => {
                    if (root.selected_schedule_name != "") {
                        root.open_selected_program();
                    } else {
                        root.open_library();
                    }
                } }



                }



                // Bottom action buttons



                Rectangle {



                    x: 10px; y: 174px;



                    width: 220px; height: 94px;

                    // Big STOP button (shown while firing)
                    Rectangle {
                        visible: !root.is_idle;
                        x: 0px; y: 0px;
                        width: 106px; height: 94px;
                        background: root.c_danger;
                        border-radius: 16px;

                        StopIcon { x: (parent.width - self.width) / 2; y: 20px; color: #FFFFFF; width: 18px; height: 18px; }

                        Text {
                            x: 0px; y: 50px;
                            width: parent.width;
                            text: root.is_ua ? "Зупинити" : "Stop";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea { width: parent.width; height: parent.height; clicked => { root.stop_firing(); } }
                    }


                    background: #00000000;



                    Rectangle {



                        x: 0px; y: 0px;



                        visible: root.is_idle;

                        width: 106px; height: 94px;


                        background: root.fault_active ? #4A1111 : (root.selected_schedule_name == "" ? root.c_border : root.c_accent);



                        border-radius: 16px;



                        PlayIcon {



                            x: (parent.width - self.width) / 2;



                            y: 18px;



                            color: (root.selected_schedule_name == "" || root.fault_active) ? root.c_muted : #000000;



                            width: 18px; height: 18px;



                        }



                        if (root.selected_schedule_name == "") : Rectangle {



                            width: parent.width; height: parent.height;



                            background: #00000000;



                            Text {



                                x: 0px; y: 42px;



                                width: parent.width;



                                text: root.is_ua ? "Виберіть" : "Select";



                                color: root.c_muted;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                            Text {



                                x: 0px; y: 58px;



                                width: parent.width;



                                text: root.is_ua ? "програму" : "Schedule";



                                color: root.c_muted;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                        }



                        if (root.selected_schedule_name != "") : Rectangle {



                            width: parent.width; height: parent.height;



                            background: #00000000;



                            Text {



                                x: 0px; y: 42px;



                                width: parent.width;



                                text: root.is_ua ? "Старт" : "Start";



                                color: root.fault_active ? #FFFFFF : #000000;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                            Text {



                                x: 0px; y: 58px;



                                width: parent.width;



                                text: root.is_ua ? "Випал" : "Firing";



                                color: root.fault_active ? #FFFFFF : #000000;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                        }



                        TouchArea {



                width: parent.width; height: parent.height; clicked => { if (!root.fault_active) { root.start_firing(); } } }


                    }



                    Rectangle {



                        x: 114px; y: 0px; visible: true;


                        width: 106px; height: 94px;



                        background: root.c_border;



                        border-radius: 16px;



                        ThermometerIcon {



                            x: (parent.width - self.width) / 2;



                            y: 18px;



                            color: root.c_text;



                            width: 18px; height: 18px;



                        }



                        Text {



                            x: 0px; y: 46px;



                            width: parent.width;



                            text: !root.is_idle ? (root.is_ua ? "Редагувати" : "Edit") : (root.is_ua ? "Програми" : "Programs");



                            color: root.c_text;



                            font-family: "PT Sans";



                            font-size: 15px;



                            horizontal-alignment: center;



                            vertical-alignment: center;



                        }



                        TouchArea {



                width: parent.width; height: parent.height; clicked => {
                    if (!root.is_idle) {
                        root.open_running_editor();
                    } else {
                        root.open_library();
                    }
                } }



                    }



                }



            }



            }
        }


        // (touch debug bar removed)



// Schedules View



        if (root.view == View.Schedules) : Rectangle {



                x: 0px; y: 0px; width: 480px; height: 280px;



                background: #000000;



                HorizontalBox {



                    x: 14px; y: 10px;



                    spacing: 6px;



                    ThermometerIcon { color: #10B981; }



                    Text {



                        text: root.is_ua ? "Бібліотека" : "Library";



                        color: #FFFFFF;



                        font-family: "PT Sans";



                        font-size: 18px;



                    }



                }



                Rectangle {



                    x: 420px; y: 8px; width: 40px; height: 28px;



                    background: #27272A;



                    border-radius: 10px;



                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.view = View.Dashboard; } }



                }



                ScrollView { // schedules-list
                    x: 10px; y: 48px; width: 460px; height: parent.height - 58px;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;
                    VerticalBox {
                        spacing: 6px;
                        for schedule[i] in root.schedules : Rectangle {



                            width: 440px; height: 80px;


                            background: schedule.selected ? #1F2937 : #0F0F0F;



                            border-color: schedule.selected ? #10B981 : #27272A;



                            border-width: 1px;



                            border-radius: 12px;



                            Text {



                                x: 12px; y: 12px;


                                text: schedule.name;


                                color: #FFFFFF;



                                font-family: "PT Sans";



                                font-size: 18px;
                                font-weight: 700;



                            }



                            Text {



                                x: 12px; y: 54px;


                                text: schedule.steps_count + " " + (root.is_ua ? "кроків" : "segments");


                                color: #A1A1AA;



                                font-size: 14px;


                            }



                            Text {



                                x: 170px; y: 54px;
                                width: parent.width - 170px - 68px - 52px - 8px;


                                text: "• " + (root.is_ua ? "Користувацька" : "Custom");


                                color: #A1A1AA;



                                font-size: 14px;


                                horizontal-alignment: right;



                            }



                            Rectangle {
                                z: 2;
                                x: parent.width - self.width - 68px;
                                y: (parent.height - self.height) / 2;
                                width: 52px; height: 52px;
                                background: #3A1C1C;
                                border-radius: 26px;

                                Text {
                                    x: 0px; y: 0px;
                                    width: parent.width; height: parent.height;
                                    text: "\u{e872}";
                                    color: #FFFFFF;
                                    font-family: "Material Icons";
                                    font-size: 24px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                    width: parent.width; height: parent.height; clicked => { root.delete_confirm_index = i; root.delete_confirm_visible = true; } }
                            }

                            Rectangle {

                                z: 2;

                                x: parent.width - self.width - 10px;
                                y: (parent.height - self.height) / 2;
                                width: 52px; height: 52px;


                                background: schedule.selected ? #10B981 : #27272A;



                                border-radius: 26px;


                                PlayIcon {



                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;


                                    width: 22px; height: 22px;


                                    color: schedule.selected ? #000000 : #FFFFFF;



                                }



                                TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.select_schedule(i); } }



                            }



                            TouchArea {



                                x: 0px; y: 0px;
                                width: parent.width - 126px; height: parent.height;
                                z: 1;
                                clicked => { root.edit_schedule(i); }
                            }


                        }



                        Rectangle {



                            width: 440px; height: 80px;


                            background: #000000;



                            border-color: #3F3F46;



                            border-width: 1px;



                            border-radius: 12px;



                            Text { text: root.is_ua ? "Нова програма" : "New Program"; color: #A1A1AA; font-family: "PT Sans"; font-size: 18px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }


                            TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.new_schedule(); } }



                        }



                    }
                }



        }


        if (root.view == View.RunningEditor) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: 280px;
                background: #000000;

                HorizontalBox {
                    x: root.settings_side_gap; y: root.settings_title_y;
                    spacing: 6px;
                    ThermometerIcon { color: #10B981; }
                    Text {
                        text: root.is_ua ? "Редагування випалу" : "Firing Edit";
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px;
                        width: 260px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle {
                    x: 420px; y: 8px; width: 40px; height: 28px;
                    background: #27272A;
                    border-radius: 10px;
                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_back(); } }
                }

                Rectangle {
                    x: 14px; y: 46px; width: 452px; height: 58px;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px;
                    border-radius: 12px;
                    Text { x: 14px; y: 8px; text: root.is_ua ? ("Швидкість нагріву (" + root.rate_unit_label_min + ")") : ("Ramp rate (" + root.rate_unit_label_min + ")"); color: #A1A1AA; font-size: 13px; }
                    Text { x: 14px; y: 28px; text: root.running_edit_rate; color: #FFFFFF; font-size: 18px; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_rate", -1, root.running_edit_rate); } }
                }

                Rectangle {
                    x: 14px; y: 112px; width: 452px; height: 58px;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px;
                    border-radius: 12px;
                    Text { x: 14px; y: 8px; text: root.is_ua ? ("Додати температуру (" + root.temp_unit_label + ")") : ("Add temperature (" + root.temp_unit_label + ")"); color: #A1A1AA; font-size: 13px; }
                    Text { x: 14px; y: 28px; text: root.running_edit_add_temp; color: #FFFFFF; font-size: 18px; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_temp", -1, root.running_edit_add_temp); } }
                }

                Rectangle {
                    x: 14px; y: 178px; width: 452px; height: 58px;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px;
                    border-radius: 12px;
                    Text { x: 14px; y: 8px; text: root.is_ua ? "Додати час (хв)" : "Add hold time (min)"; color: #A1A1AA; font-size: 13px; }
                    Text { x: 14px; y: 28px; text: root.running_edit_add_time; color: #FFFFFF; font-size: 18px; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_time", -1, root.running_edit_add_time); } }
                }

                Rectangle {
                    x: 304px; y: 242px; width: 162px; height: 28px;
                    background: #10B981;
                    border-radius: 10px;
                    Text { text: root.is_ua ? "Зберегти" : "Apply"; color: #000000; font-family: "PT Sans"; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_apply(); } }
                }
        }

        

        // Settings View
        if (root.view == View.Settings) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                background: #000000;
                clip: true;

                HorizontalBox {
                    x: root.settings_side_gap; y: root.settings_title_y;
                    width: root.settings_content_width; height: 28px;
                    alignment: start;
                    spacing: 6px;
                    if (root.settings_page == "wifi") : WifiIcon { width: 24px; height: 28px; color: root.wifi_ok ? #10B981 : #52525B; }
                    if (root.settings_page != "wifi") : SettingsIcon { width: 24px; height: 28px; color: #A1A1AA; }
                    Text {
                        text: root.settings_page == "wifi" ? "Wi‑Fi"
                            : root.settings_page == "display" ? (root.is_ua ? "Режим відображення" : "Display mode")
                            : root.settings_page == "display_hw" ? (root.is_ua ? "Дисплей" : "Display")
                            : root.settings_page == "fan" ? (root.is_ua ? "Вентилятор" : "Fan")
                            : root.settings_page == "autotune" ? (root.is_ua ? "PID Автоналаштування" : "PID Autotune")
                            : root.settings_page == "fault" ? (root.is_ua ? "Помилки" : "Faults")
                            : root.settings_page == "touch" ? (root.is_ua ? "Калібрування тач" : "Touch Calibration")
                            : (root.is_ua ? "Налаштування" : "Settings");
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px;
                        width: 270px;
                        height: 28px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                if (root.settings_page != "all" && root.settings_page != "wifi") : UiButton {
                    x: 480px - root.settings_side_gap - 90px; y: root.settings_title_y; width: 40px; height: 28px;
                    background: #1F2937;
                    radius: 10px;
                    label: "<";
                    text_size: 16px;
                    tapped => { root.settings_page = "all"; }
                }

                UiButton {
                    x: 480px - root.settings_side_gap - 40px; y: root.settings_title_y; width: 40px; height: 28px;
                    background: #27272A;
                    radius: 10px;
                    label: "X";
                    text_size: 16px;
                    tapped => { root.view = View.Dashboard; }
                }

                if (root.settings_page != "display_hw") : ScrollView {
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.settings_content_width; height: root.settings_content_height;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;

                    settings_box := VerticalBox {
                        x: 0px;
                        width: root.settings_content_width;
                        alignment: start;
                        spacing: 8px;

                        if (root.settings_page == "all") : HorizontalBox {
                            x: 0px;
                            width: root.settings_content_width;
                            alignment: start;
                            spacing: 8px;

                            VerticalBox {
                                alignment: start;
                                spacing: 8px;

                                Rectangle {
                                    width: 226px; height: 56px;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                        text: root.is_ua ? "\u{0420}\u{0435}\u{0436}\u{0438}\u{043c}\u{0020}\u{0432}\u{0456}\u{0434}\u{043e}\u{0431}\u{0440}\u{0430}\u{0436}\u{0435}\u{043d}\u{043d}\u{044f}" : "Display mode";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 18px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "display"; } }
                                }

                                Rectangle {
                                    width: 226px; height: 56px;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                        text: root.is_ua ? "\u{0414}\u{0438}\u{0441}\u{043f}\u{043b}\u{0435}\u{0439}" : "Display";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 18px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "display_hw"; } }
                                }

                                Rectangle {
                                    width: 226px; height: 56px;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                        text: root.is_ua ? "\u{0412}\u{0435}\u{043d}\u{0442}\u{0438}\u{043b}\u{044f}\u{0442}\u{043e}\u{0440}" : "Fan";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 18px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "fan"; } }
                                }
                            }

                            VerticalBox {
                                alignment: start;
                                spacing: 8px;

                                Rectangle {
                                    width: 226px; height: 56px;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                        text: root.is_ua ? "\u{0410}\u{0432}\u{0442}\u{043e}\u{043d}\u{0430}\u{043b}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043d}\u{043d}\u{044f}" : "Autotune";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 18px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "autotune"; } }
                                }

                                Rectangle {
                                    width: 226px; height: 56px;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                        text: root.is_ua ? "\u{041f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043a}\u{0438}" : "Faults";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 18px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "fault"; } }
                                }
                            }
                        }

                        if (root.settings_page == "display") : VerticalBox {
                            width: root.settings_content_width;
                            spacing: 8px;

                            Rectangle {
                                width: root.settings_content_width; height: 60px;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "\u{0422}\u{0435}\u{043c}\u{043f}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0430}" : "Temperature";
                                    color: #A1A1AA;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 154px; y: 13px; width: 68px; height: root.settings_btn_height;
                                    background: root.temp_unit == "C" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "C\u{00B0}"; color: root.temp_unit == "C" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.temp_unit = "C"; root.set_temp_unit("C"); } }
                                }
                                Rectangle {
                                    x: parent.width - 80px; y: 13px; width: 68px; height: root.settings_btn_height;
                                    background: root.temp_unit == "F" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "F\u{00B0}"; color: root.temp_unit == "F" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.temp_unit = "F"; root.set_temp_unit("F"); } }
                                }
                            }

                            Rectangle {
                                width: root.settings_content_width; height: 60px;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "\u{0427}\u{0430}\u{0441}" : "Time";
                                    color: #A1A1AA;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 154px; y: 13px; width: 68px; height: root.settings_btn_height;
                                    background: root.time_format == "24" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "24h"; color: root.time_format == "24" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.time_format = "24"; root.set_time_format("24"); } }
                                }
                                Rectangle {
                                    x: parent.width - 80px; y: 13px; width: 68px; height: root.settings_btn_height;
                                    background: root.time_format == "12" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "12h"; color: root.time_format == "12" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.time_format = "12"; root.set_time_format("12"); } }
                                }
                            }

                            Rectangle {
                                width: root.settings_content_width; height: 60px;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "\u{0414}\u{0430}\u{0442}\u{0430}" : "Date";
                                    color: #A1A1AA;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 216px; y: 13px; width: 64px; height: root.settings_btn_height;
                                    background: root.date_format == "DMY" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "DD.MM"; color: root.date_format == "DMY" ? #000000 : #FFFFFF; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "DMY"; root.set_date_format("DMY"); } }
                                }
                                Rectangle {
                                    x: parent.width - 146px; y: 13px; width: 64px; height: root.settings_btn_height;
                                    background: root.date_format == "MDY" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "MM/DD"; color: root.date_format == "MDY" ? #000000 : #FFFFFF; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "MDY"; root.set_date_format("MDY"); } }
                                }
                                Rectangle {
                                    x: parent.width - 76px; y: 13px; width: 64px; height: root.settings_btn_height;
                                    background: root.date_format == "YMD" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "YYYY"; color: root.date_format == "YMD" ? #000000 : #FFFFFF; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "YMD"; root.set_date_format("YMD"); } }
                                }
                            }
                        }

                        if (root.settings_page == "fan") : Rectangle {
                        width: root.settings_content_width; height: 86px;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 12px;

                        Text {
                            x: 12px; y: 8px;
                            text: root.is_ua ? "Вентилятор" : "Fan";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px;
                        }

                        Text {
                            x: 12px; y: 52px;
                            text: root.fan_manual
                                ? (root.is_ua ? "Ручний режим" : "Manual mode")
                                : (root.is_ua ? "Вимкнено" : "Off");
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 12px;
                        }

                        Rectangle {
                            x: parent.width - 108px; y: 6px; width: 96px; height: root.settings_btn_height;
                            background: root.fan_manual ? #10B981 : #27272A;
                            border-radius: root.settings_btn_radius;
                            Text {
                                text: root.fan_manual ? (root.is_ua ? "ВКЛ" : "ON") : (root.is_ua ? "ВИКЛ" : "OFF");
                                color: root.fan_manual ? #000000 : #FFFFFF;
                                font-family: "PT Sans";
                                font-size: root.settings_btn_text_size;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let new_manual = !root.fan_manual;
                                    root.fan_manual = new_manual;
                                    if (new_manual && root.fan_power == 0) { root.fan_power = 100; }
                                    if (!new_manual) { root.fan_power = 0; }
                                    root.fan_manual_changed(new_manual);
                                    root.fan_power_changed(root.fan_power);
                                }
                            }
                        }

                        Rectangle { // -
                            x: parent.width - 214px; y: 44px; width: 60px; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: "−"; color: #FFFFFF; font-family: "PT Sans"; font-size: 26px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        root.fan_power = max(root.fan_power - 10, 0);
                                        root.fan_power_changed(root.fan_power);
                                    }
                                }
                            }
                        }

                        Rectangle { // % (tap for keypad)
                            x: parent.width - 148px; y: 44px; width: 64px; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.fan_power + "%"; color: #FFFFFF; font-family: "PT Sans"; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        if (!(root.kb_visible && root.kb_field == "fan" && root.kb_step_index == -1)) {
                                            root.kb_open("fan", -1, root.fan_power + "");
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { // +
                            x: parent.width - 78px; y: 44px; width: 66px; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: "+"; color: #FFFFFF; font-family: "PT Sans"; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        root.fan_power = min(root.fan_power + 10, 100);
                                        root.fan_power_changed(root.fan_power);
                                    }
                                }
                            }
                        }
                    }

                        if (root.settings_page == "autotune") : Rectangle {
                        width: root.settings_content_width; height: 108px;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 12px;

                        Text {
                            x: 12px; y: 8px;
                            text: root.is_ua ? "PID Автоналаштування" : "PID Autotune";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px;
                        }

                        Text {
                            x: 12px; y: 30px;
                            text: root.is_ua
                                ? ("Цільова температура (" + root.temp_unit_label + ")")
                                : ("Target temperature (" + root.temp_unit_label + ")");
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 12px;
                        }

                        Rectangle {
                            x: 12px; y: 48px; width: 130px; height: root.settings_btn_height;
                            background: #27272A;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.autotune_target_c + root.temp_unit_label; color: #FFFFFF; font-family: "PT Sans"; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (!(root.kb_visible && root.kb_field == "autotune" && root.kb_step_index == -1)) {
                                        root.kb_open("autotune", -1, root.autotune_target_c + "");
                                    }
                                }
                            }
                        }

                        Rectangle {
                            x: 154px; y: 46px; width: 286px; height: 44px;
                            background: root.status_label == "TUNING" ? #7F1D1D : (root.fault_active ? #18181B : #14532D);
                            border-radius: root.settings_btn_radius;
                            Text {
                                text: root.status_label == "TUNING"
                                    ? (root.is_ua ? "Зупинити автоналаштування" : "Stop autotune")
                                    : (root.is_ua ? "Запустити автоналаштування" : "Start autotune");
                                color: root.status_label == "TUNING" ? #FFFFFF : (root.fault_active ? #71717A : #FFFFFF);
                                font-family: "PT Sans";
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.status_label == "TUNING") {
                                        root.autotune_stop();
                                    } else if (!root.fault_active) {
                                        root.autotune_start(root.autotune_target_c);
                                    }
                                }
                            }
                        }
                    }

                        if (root.settings_page == "fault") : Rectangle {
                        width: root.settings_content_width; height: 64px;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 12px;

                        Text {
                            x: 12px; y: 8px;
                            text: root.is_ua ? "Поточна помилка" : "Current fault";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 14px;
                        }

                        Text {
                            x: 12px; y: 28px; width: parent.width - 24px; height: 30px;
                            text: root.fault_active
                                ? (root.fault_reason == "" ? (root.is_ua ? "Помилка без опису" : "Fault without details") : root.fault_reason)
                                : (root.is_ua ? "Немає активної помилки" : "No active fault");
                            color: root.fault_active ? #FCA5A5 : #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 12px;
                            overflow: elide;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                        }

                        if (root.settings_page == "fault") : UiButton {
                        width: root.settings_content_width; height: 50px;
                        background: root.fault_active ? #7F1D1D : #18181B;
                        foreground: root.fault_active ? #FFFFFF : #71717A;
                        radius: 12px;
                        label: root.is_ua ? "Скинути помилку" : "Clear Fault";
                        text_size: root.settings_btn_text_size;
                        tapped => {
                            if (root.fault_active) {
                                root.clear_fault();
                            }
                        }
                        }

                        if (root.settings_page == "touch") : UiButton {
                        width: root.settings_content_width; height: 50px;
                        background: #27272A;
                        radius: 12px;
                        label: root.is_ua ? "Калібрування тач" : "Touch Calibration";
                        text_size: root.settings_btn_text_size;
                        tapped => { root.view = View.Calibration; root.start_touch_calibration(); }
                        }

                        if (root.settings_page == "wifi") : Rectangle {
                            width: root.settings_content_width; height: 146px;
                            background: #0F0F0F;
                            border-color: #27272A;
                            border-width: 1px;
                            border-radius: 12px;

                            Text {
                                x: 12px; y: 10px;
                                text: "Wi‑Fi";
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 16px;
                                font-weight: 700;
                            }

                            Rectangle {
                                x: parent.width - 132px; y: 8px; width: 120px; height: 24px;
                                background: root.wifi_ok ? #073B2A : #2A2A2F;
                                border-radius: 8px;
                                Text {
                                    text: root.wifi_ok ? "Connected" : "Disconnected";
                                    color: root.wifi_ok ? #10B981 : #A1A1AA;
                                    font-family: "PT Sans";
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Text {
                                x: 12px; y: 38px; width: parent.width - 24px;
                                text: root.wifi_selected_ssid == ""
                                    ? (root.is_ua ? "Оберіть мережу зі списку" : "Pick a network from list")
                                    : root.wifi_selected_ssid;
                                color: #A1A1AA;
                                font-family: "PT Sans";
                                font-size: 13px;
                                overflow: elide;
                            }

                            Rectangle {
                                x: 12px; y: 58px; width: 294px; height: 36px;
                                background: #18181B;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 9px;
                                Text {
                                    x: 10px; y: 9px;
                                    width: parent.width - 20px;
                                    text: root.wifi_server_url;
                                    color: #60A5FA;
                                    font-family: "PT Sans";
                                    font-size: 12px;
                                    overflow: elide;
                                }
                            }

                            UiButton {
                                x: parent.width - 138px; y: 56px; width: 126px; height: 40px;
                                background: #1F2937;
                                radius: 9px;
                                label: "QR";
                                bold: true;
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_qr_toggle(); }
                            }

                            UiButton {
                                x: 12px; y: 104px; width: 210px; height: root.settings_btn_height;
                                background: #27272A;
                                radius: 9px;
                                label: root.wifi_ok ? (root.is_ua ? "Змінити мережу" : "Change network")
                                                  : (root.is_ua ? "Пошук мережі" : "Search networks");
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_open_picker(); }
                            }

                            UiButton {
                                x: 230px; y: 104px; width: 210px; height: root.settings_btn_height;
                                background: #7F1D1D;
                                radius: 9px;
                                label: root.is_ua ? "Відключити Wi‑Fi" : "Disconnect Wi‑Fi";
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_disconnect(); }
                            }
                        }
                    }
                }

                // (scrollbar hidden)
                if (root.settings_page == "display_hw") : VerticalBox {
                    x: root.settings_side_gap; y: root.settings_content_y; width: root.settings_content_width;
                    alignment: start;
                    spacing: 10px;

                    Rectangle {
                        width: root.settings_content_width; height: 84px;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 12px;
                        Text { x: 12px; y: 8px; text: root.is_ua ? "Яскравість" : "Brightness"; color: #A1A1AA; font-size: 13px; }
                        Rectangle {
                            x: 12px; y: 38px; width: 64px; height: root.settings_btn_height;
                            background: #27272A;
                            border-radius: root.settings_btn_radius;
                            Text { text: "-"; color: #FFFFFF; font-family: "PT Sans"; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let v = max(root.display_brightness - 10, 50);
                                    root.display_brightness = v;
                                    root.display_brightness_changed(v);
                                }
                            }
                        }
                        Rectangle {
                            x: 84px; y: 38px; width: 136px; height: root.settings_btn_height;
                            background: #1F2937;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.display_brightness + "%"; color: #FFFFFF; font-family: "PT Sans"; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Rectangle {
                            x: 228px; y: 38px; width: 64px; height: root.settings_btn_height;
                            background: #27272A;
                            border-radius: root.settings_btn_radius;
                            Text { text: "+"; color: #FFFFFF; font-family: "PT Sans"; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let v = min(root.display_brightness + 10, 100);
                                    root.display_brightness = v;
                                    root.display_brightness_changed(v);
                                }
                            }
                        }
                        Rectangle {
                            x: 300px; y: 38px; width: 140px; height: root.settings_btn_height;
                            background: #10B981;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.is_ua ? "Макс" : "Max"; color: #000000; font-family: "PT Sans"; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    root.display_brightness = 100;
                                    root.display_brightness_changed(100);
                                }
                            }
                        }
                    }

                    UiButton {
                        width: root.settings_content_width; height: 70px;
                        background: #27272A;
                        radius: 12px;
                        label: root.is_ua ? "Калібрування дисплею" : "Display calibration";
                        text_size: 16px;
                        tapped => { root.view = View.Calibration; root.start_touch_calibration(); }
                    }
                }

                if (root.wifi_qr_visible) : Rectangle {
                    x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                    background: #000000D0;
                    z: 2100;

                    Rectangle {
                        x: 80px; y: 14px; width: 320px; height: 252px;
                        background: #00000000;
                        border-width: 0px;
                        border-radius: 0px;

                        Image {
                            x: 76px; y: 22px; width: 168px; height: 168px;
                            source: root.wifi_qr_image;
                        }
                        Text {
                            x: 16px; y: 196px; width: 288px; height: 24px;
                            text: root.wifi_qr_hint;
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        UiButton {
                            x: 100px; y: 222px; width: 120px; height: 28px;
                            background: #27272A;
                            radius: 10px;
                            label: root.is_ua ? "Закрити" : "Close";
                            text_size: 16px;
                            tapped => { root.wifi_qr_toggle(); }
                        }
                    }
                }

                if (root.wifi_picker_visible) : Rectangle {
                    x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                    background: #000000CC;
                    z: 2000;

                    Rectangle {
                        x: 16px; y: 12px; width: 448px; height: 252px;
                        background: #00000000;
                        border-width: 0px;
                        border-radius: 0px;

                        Text {
                            x: 12px; y: 10px;
                            text: root.is_ua ? "Вибір Wi‑Fi мережі" : "Select Wi‑Fi network";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px;
                        }

                        UiButton {
                            x: 398px; y: 8px; width: 38px; height: 28px;
                            background: #27272A;
                            radius: 8px;
                            label: "X";
                            text_size: 16px;
                            tapped => { root.wifi_picker_visible = false; }
                        }

                        if (root.wifi_scan_busy) : Text {
                            x: 12px; y: 44px;
                            text: root.is_ua ? "Пошук мереж..." : "Scanning networks...";
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px;
                        }

                        if (!root.wifi_scan_busy && root.wifi_networks.length == 0) : Text {
                            x: 12px; y: 44px;
                            text: root.is_ua ? "Мереж не знайдено" : "No networks found";
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px;
                        }

                        if (!root.wifi_scan_busy && root.wifi_networks.length > 0) : ScrollView {
                            x: 8px; y: 40px; width: 432px; height: 204px;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            mouse-drag-pan-enabled: true;

                            VerticalBox {
                                spacing: 4px;
                                for net in root.wifi_networks : Rectangle {
                                    width: 430px; height: 38px;
                                    background: #18181B;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 8px;

                                    Text {
                                        x: 8px; y: 9px;
                                        text: net.ssid + " (" + net.rssi + " dBm)";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 14px;
                                    }

                                    TouchArea {
                                        width: parent.width; height: parent.height;
                                        clicked => {
                                            root.wifi_selected_ssid = net.ssid;
                                            root.wifi_password = "";
                                            root.kb_open("wifi_pass", -1, "");
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
        }

        // Editor View


        if (root.view == View.Editor) : Rectangle {



                x: 0px; y: 0px; width: 480px; height: 280px;



                background: #000000;



                Rectangle {



                    x: 10px; y: 6px; width: 266px; height: 34px;


                    background: #000000;



                    border-color: #27272A;



                    border-width: 1px;



                    border-radius: 8px;



                    property <string> name_display: (root.kb_visible && root.kb_field == "name") ? root.kb_value : root.selected_schedule_name;

                    TextInput { visible: false;



                        x: 6px; y: 5px;


                        width: parent.width - 12px; height: parent.height - 8px;



                        text: parent.name_display;



                        color: #FFFFFF;



                        font-family: "PT Sans";



                        font-size: 18px;


                        input-type: InputType.text;



                    }

                    Text {
                        x: 6px; y: 5px;
                        width: parent.width - 12px; height: parent.height - 8px;
                        text: parent.name_display;
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px;
                        font-weight: 700;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                    }

                    if (self.name_display == "") : Text {



                        x: 8px; y: 10px;


                        text: root.is_ua ? "Назва програми" : "Program Name";



                        color: #71717A;



                        font-family: "PT Sans";



                        font-size: 14px;


                    }

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            if (!(root.kb_visible && root.kb_field == "name")) {
                                root.kb_open("name", -1, root.selected_schedule_name);
                            }
                        }
                    }



                }



                Rectangle {



                    x: 286px; y: 6px; width: 132px; height: 34px;


                    background: #10B981;



                    border-radius: 10px;



                    Text { text: root.is_ua ? "Зберегти" : "Save"; color: #000000; font-family: "PT Sans"; font-size: 16px; horizontal-alignment: center; vertical-alignment: center; }


                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.editor_save(); } }



                }



                Rectangle {



                    x: 426px; y: 6px; width: 44px; height: 34px;


                    background: #27272A;



                    border-radius: 10px;



                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.editor_back(); } }



                }



                ScrollView {
                    x: 10px; y: 48px; width: 460px; height: parent.height - 58px;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;
                    VerticalBox {
                        spacing: 6px;
                        if (root.editor_steps.length == 0) : Rectangle {



                            width: 440px; height: 60px;



                            background: #000000;



                            border-color: #27272A;



                            border-width: 1px;



                            border-radius: 12px;



                            Text { text: root.is_ua ? "Ще не додано жодного кроку" : "No steps added yet"; color: #A1A1AA; horizontal-alignment: center; vertical-alignment: center; }



                        }



                        for step[i] in root.editor_steps : Rectangle {



                            width: 440px; height: 92px;


                            background: #0F0F0F;



                            border-color: #27272A;



                            border-width: 1px;



                            border-radius: 10px;



                            Rectangle {



                                x: 8px;
                                y: (parent.height - self.height) / 2;
                                width: 32px; height: 32px;


                                background: (!root.is_idle && i == root.step_index) ? #10B981 : #27272A;



                                border-radius: 16px;


                                Text { text: (i + 1); color: (!root.is_idle && i == root.step_index) ? #000000 : #A1A1AA; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }


                            }



                            // Center the labels+values as a single block inside the segment row.
                            HorizontalBox {


                                x: 44px;
                                y: (parent.height - self.height) / 2 - 12px;
                                height: 58px;


                                spacing: 6px;



                                VerticalBox {



                                    width: 120px;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? ("Швидк. (" + root.rate_unit_label + ")") : ("Rate (" + root.rate_unit_label + ")"); color: #71717A; font-size: 14px; }


                                    Rectangle {



                                        width: 120px; height: 42px;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px;



                                        border-radius: 8px;


                                        TextInput { visible: false;
                                            x: 6px; y: 4px;


                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.rate + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px;



                                            input-type: InputType.number;



                                            edited => { root.editor_rate_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.rate + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "rate" && root.kb_step_index == i)) {
                                                    root.kb_open("rate", i, step.rate + "");
                                                }
                                            }
                                        }


                                    }



                                }



                                VerticalBox {



                                    width: 120px;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? ("Темп. (" + root.temp_unit_label + ")") : ("Target (" + root.temp_unit_label + ")"); color: #71717A; font-size: 14px; }


                                    Rectangle {



                                        width: 120px; height: 42px;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px;



                                        border-radius: 8px;


                                        TextInput { visible: false;


                                            x: 6px; y: 4px;



                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.target + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px;



                                            input-type: InputType.number;



                                            edited => { root.editor_target_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.target + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "target" && root.kb_step_index == i)) {
                                                    root.kb_open("target", i, step.target + "");
                                                }
                                            }
                                        }


                                    }



                                }



                                VerticalBox {



                                    width: 120px;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? "Витр. (хв)" : "Hold (min)"; color: #71717A; font-size: 14px; }


                                    Rectangle {



                                        width: 120px; height: 42px;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px;



                                        border-radius: 8px;


                                        TextInput { visible: false;


                                            x: 6px; y: 4px;



                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.hold + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px;



                                            input-type: InputType.number;



                                            edited => { root.editor_hold_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.hold + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "hold" && root.kb_step_index == i)) {
                                                    root.kb_open("hold", i, step.hold + "");
                                                }
                                            }
                                        }


                                    }



                                }



                            }



                            Rectangle {



                                x: parent.width - self.width - 8px;
                                y: 6px;
                                width: 30px; height: 30px;


                                background: #27272A;



                                border-radius: 8px;


                                Text { text: "X"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }



                                TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.editor_remove(i); } }



                            }



                        }



                        Rectangle {



                        width: 440px; height: 44px;



                            background: #0F0F0F;



                            border-color: #27272A;



                            border-width: 1px;



                            border-radius: 10px;



                        Text { text: root.is_ua ? "+ Додати крок" : "+ Add Step"; color: #A1A1AA; font-size: 18px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }



                            TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.editor_add_step(); } }



                        }



                    }
                }



            }



        }


    // Stop modal



    // Full-screen text keyboard (program name)
    if (root.kb_visible && ((root.kb_field == "name" && root.kb_mode == "alpha") || (root.kb_field == "wifi_pass" && root.kb_mode == "alpha"))) : Rectangle {
        x: 0px;
        y: 0px;
        width: 480px;
        height: 320px;
        z: 5000;

        background: #000000;

        property <[string]> ua_r1_uc: ["Й","Ц","У","К","Е","Н","Г","Ш","Щ","З","Х","Ї"];
        property <[string]> ua_r2_uc: ["Ф","І","В","А","П","Р","О","Л","Д","Ж","Є"];
        property <[string]> ua_r3_uc: ["Я","Ч","С","М","И","Т","Ь","Б","Ю","Ґ"];
        property <[string]> ua_r1_lc: ["й","ц","у","к","е","н","г","ш","щ","з","х","ї"];
        property <[string]> ua_r2_lc: ["ф","і","в","а","п","р","о","л","д","ж","є"];
        property <[string]> ua_r3_lc: ["я","ч","с","м","и","т","ь","б","ю","ґ"];

        property <[string]> en_r1_uc: ["Q","W","E","R","T","Y","U","I","O","P"];
        property <[string]> en_r2_uc: ["A","S","D","F","G","H","J","K","L"];
        property <[string]> en_r3_uc: ["Z","X","C","V","B","N","M"];
        property <[string]> en_r1_lc: ["q","w","e","r","t","y","u","i","o","p"];
        property <[string]> en_r2_lc: ["a","s","d","f","g","h","j","k","l"];
        property <[string]> en_r3_lc: ["z","x","c","v","b","n","m"];

        Rectangle {
            x: 0px; y: 0px; width: parent.width; height: 70px;
            background: #111118;
            border-color: #27272A;
            border-width: 1px;

            KbKeyButton { x: 10px; y: 13px; width: 72px; height: 44px; background: #7F1D1D; label: root.is_ua ? "Скас." : "Cancel"; font_size: 14px;
                pressed(v) => { root.kb_key("CANCEL"); }
            }
            KbKeyButton { x: 398px; y: 13px; width: 72px; height: 44px; background: #10B981; text_color: #000000; label: "OK"; font_size: 18px;
                pressed(v) => { root.kb_key("OK"); }
            }

            Rectangle {
                x: 90px; y: 10px; width: 300px; height: 50px;
                background: #0B0B0B;
                border-color: #27272A;
                border-width: 1px;
                border-radius: 10px;
                clip: true;

                Text {
                    x: 10px; y: 6px;
                    text: root.kb_field == "name"
                        ? (root.is_ua ? "Назва програми" : "Program Name")
                        : (root.is_ua ? "Пароль Wi‑Fi" : "Wi‑Fi Password");
                    color: #A1A1AA;
                    font-family: "PT Sans";
                    font-size: 12px;
                }

                Text {
                    x: 10px; y: 22px;
                    width: parent.width - 20px;
                    text: root.kb_value;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px;
                    font-weight: 700;
                    wrap: no-wrap;
                    vertical-alignment: center;
                }
            }
        }

        KbKeyRow {
            row_y: -78px;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r1_uc : parent.ua_r1_lc)
                : (root.kb_caps ? parent.en_r1_uc : parent.en_r1_lc);
            key_width: root.is_ua ? 38px : 46px;
            key_height: 44px;
            gap: 2px;
            start_x: -238px;
            font_size: 20px;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyRow {
            row_y: -30px;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r2_uc : parent.ua_r2_lc)
                : (root.kb_caps ? parent.en_r2_uc : parent.en_r2_lc);
            key_width: root.is_ua ? 40px : 48px;
            key_height: 44px;
            gap: 2px;
            start_x: root.is_ua ? -230px : -222px;
            font_size: 20px;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyRow {
            row_y: 18px;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r3_uc : parent.ua_r3_lc)
                : (root.kb_caps ? parent.en_r3_uc : parent.en_r3_lc);
            key_width: root.is_ua ? 46px : 66px;
            key_height: 44px;
            gap: 2px;
            start_x: -238px;
            font_size: 20px;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyButton { x: 10px; y: 238px; width: 60px; height: 60px; background: #3F3F46; label: "123"; font_size: 16px;
            pressed(v) => { root.kb_mode = "num"; }
        }
        KbKeyButton { x: 72px; y: 238px; width: 50px; height: 60px; background: #3F3F46; label: root.is_ua ? "UA" : "EN"; font_size: 14px;
            pressed(v) => { root.is_ua = !root.is_ua; }
        }
        KbKeyButton { x: 124px; y: 238px; width: 50px; height: 60px; background: root.kb_caps ? #10B981 : #3F3F46; label: "⇧"; font_size: 20px;
            pressed(v) => { root.kb_caps = !root.kb_caps; }
        }
        KbKeyButton { x: 176px; y: 238px; width: 134px; height: 60px; background: #27272A; label: root.is_ua ? "Пробіл" : "Space"; font_size: 18px;
            pressed(v) => { root.kb_key("SPACE"); }
        }
        KbKeyButton { x: 318px; y: 238px; width: 72px; height: 60px; background: #3F3F46; label: "←"; font_size: 22px;
            pressed(v) => { root.kb_key("BS"); }
        }
        KbKeyButton { x: 398px; y: 238px; width: 72px; height: 60px; background: #3F3F46; label: root.is_ua ? "Очист." : "Clear"; font_size: 14px;
            pressed(v) => { root.kb_key("CLR"); }
        }
    }

    // Bottom numeric keyboard overlay (Editor)
    if (root.kb_visible && ((root.kb_field == "name" && (root.kb_mode == "num" || root.kb_mode == "sym")) || (root.kb_field == "wifi_pass" && (root.kb_mode == "num" || root.kb_mode == "sym")) || (root.kb_field != "name" && root.kb_field != "wifi_pass"))) : Rectangle {
        x: 0px;
        y: 0px;
        width: 480px;
        height: 320px;
        z: 5000;

        background: #000000;

        Text {
            x: 12px; y: 14px;
            text: root.kb_field == "rate"
                ? (root.is_ua ? "Швидкість" : "Rate")
                : root.kb_field == "target"
                    ? (root.is_ua ? "Температура" : "Target")
                    : root.kb_field == "hold"
                        ? (root.is_ua ? "Витримка" : "Hold")
                        : root.kb_field == "fan"
                            ? (root.is_ua ? "Вентилятор %" : "Fan %")
                            : root.kb_field == "autotune"
                                ? (root.is_ua ? "Автоналаштування" : "Autotune")
                                : root.kb_field == "run_rate"
                                    ? (root.is_ua ? "Нова швидкість" : "New rate")
                                    : root.kb_field == "run_temp"
                                        ? (root.is_ua ? ("Додати температуру (" + root.temp_unit_label + ")") : ("Add temperature (" + root.temp_unit_label + ")"))
                                        : root.kb_field == "run_time"
                                            ? (root.is_ua ? "Додати час" : "Add time")
                                : root.kb_field == "name"
                                    ? (root.is_ua ? "Назва програми" : "Program name")
                                    : root.kb_field == "wifi_pass"
                                        ? (root.is_ua ? "Пароль Wi‑Fi" : "Wi-Fi password")
                                        : "";
            color: #A1A1AA;
            font-family: "PT Sans";
            font-size: 14px;
        }

        Text {
            x: 12px; y: 38px;
            text: root.kb_value;
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 30px;
            font-weight: 700;
        }

        if (root.kb_field == "wifi_pass" || root.kb_field == "name") : KbKeyButton { x: 388px; y: 8px; width: 80px; height: 32px; background: #27272A; label: "ABC"; font_size: 12px;
            pressed(v) => { root.kb_mode = "alpha"; }
        }
        if (root.kb_field == "wifi_pass" || root.kb_field == "name") : KbKeyButton { x: 300px; y: 8px; width: 80px; height: 32px; background: #27272A; label: root.kb_mode == "sym" ? "123" : "SYM"; font_size: 12px;
            pressed(v) => { root.kb_mode = root.kb_mode == "sym" ? "num" : "sym"; }
        }

        property <length> kx: 25px;
    property <length> ky: 76px;
        property <length> kw: 140px;
        property <length> kh: 42px;
        property <length> kg: 10px;

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "!" : "1"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "!" : "1"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "@" : "2"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "@" : "2"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "#" : "3"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "#" : "3"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "$" : "4"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "$" : "4"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "%" : "5"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "%" : "5"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "&" : "6"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "&" : "6"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "*" : "7"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "*" : "7"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "-" : "8"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "-" : "8"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "_" : "9"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "_" : "9"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + 6px); width: parent.kw; height: parent.kh; background: #3F3F46; label: root.is_ua ? "Очист." : "Clear"; font_size: 14px; pressed(v) => { root.kb_key("CLR"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "." : "0"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "." : "0"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + 6px); width: parent.kw; height: parent.kh; background: #3F3F46; label: "←"; font_size: 22px; pressed(v) => { root.kb_key("BS"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 4 * (parent.kh + 6px); width: parent.kw; height: parent.kh; background: #7F1D1D; label: root.is_ua ? "Скас." : "Cancel"; font_size: 14px; pressed(v) => { root.kb_key("CANCEL"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 4 * (parent.kh + 6px); width: parent.kw + parent.kg + parent.kw; height: parent.kh; background: #10B981; text_color: #000000; label: "OK"; font_size: 20px; pressed(v) => { root.kb_key("OK"); } }
    }

    if (root.delete_confirm_visible) : Rectangle {
        x: 0px; y: 0px; width: 480px; height: 320px;
        background: #000000B3;
        z: 5100;
        Rectangle {
            x: 60px; y: 70px; width: 360px; height: 180px;
            background: #0B0B0B;
            border-color: #3F3F46;
            border-width: 1px;
            border-radius: 16px;
            Text {
                x: 0px; y: 22px; width: parent.width;
                text: root.is_ua ? "Видалити програму?" : "Delete program?";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 20px;
                horizontal-alignment: center;
            }
            Text {
                x: 20px; y: 60px; width: parent.width - 40px;
                text: root.is_ua ? "Цю дію неможливо скасувати." : "This action cannot be undone.";
                color: #A1A1AA;
                font-size: 12px;
                horizontal-alignment: center;
            }
            Rectangle {
                x: 24px; y: 120px; width: 150px; height: 44px;
                background: #27272A; border-radius: 10px;
                Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.delete_confirm_visible = false; } }
            }
            Rectangle {
                x: 186px; y: 120px; width: 150px; height: 44px;
                background: #7F1D1D; border-radius: 10px;
                Text { text: root.is_ua ? "Видалити" : "Delete"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea {
                    width: parent.width; height: parent.height;
                    clicked => {
                        if (root.delete_confirm_index >= 0) { root.delete_schedule(root.delete_confirm_index); }
                        root.delete_confirm_visible = false;
                    }
                }
            }
        }
    }

    if (root.show_skip_confirm) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #000000B3;
            z: 5100;
            Rectangle {
                x: 72px; y: 72px; width: 336px; height: 168px;
                background: #0B0B0B;
                border-color: #3F3F46;
                border-width: 1px;
                border-radius: 16px;
                Text {
                    x: 0px; y: 24px; width: parent.width;
                    text: root.is_ua ? "Пропустити крок?" : "Skip step?";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px;
                    horizontal-alignment: center;
                }
                Rectangle {
                    x: 18px; y: 104px; width: 140px; height: 44px;
                    background: #27272A; border-radius: 10px;
                    Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_cancel(); } }
                }
                Rectangle {
                    x: 178px; y: 104px; width: 140px; height: 44px;
                    background: root.c_danger; border-radius: 10px;
                    Text { text: root.is_ua ? "Підтвердити" : "Confirm"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_confirm(); } }
                }
            }
    }

    if (root.show_running_edit_confirm) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #000000B3;
            z: 5100;
            Rectangle {
                x: 58px; y: 64px; width: 364px; height: 186px;
                background: #0B0B0B;
                border-color: #3F3F46;
                border-width: 1px;
                border-radius: 16px;
                Text {
                    x: 0px; y: 24px; width: parent.width;
                    text: root.is_ua ? "Застосувати зміни?" : "Apply changes?";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px;
                    horizontal-alignment: center;
                }
                Text {
                    x: 18px; y: 60px; width: parent.width - 36px;
                    text: root.is_ua ? "Температура, швидкість і час буде змінено для поточного випалу." : "Temperature, rate and hold time will be updated for current firing.";
                    color: #A1A1AA;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
                Rectangle {
                    x: 22px; y: 124px; width: 152px; height: 44px;
                    background: #27272A; border-radius: 10px;
                    Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_cancel(); } }
                }
                Rectangle {
                    x: 190px; y: 124px; width: 152px; height: 44px;
                    background: #10B981; border-radius: 10px;
                    Text { text: root.is_ua ? "Зберегти" : "Save"; color: #000000; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_confirm(); } }
                }
            }
    }

    if (root.standby_visible && !root.boot_splash_visible) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #05070B;
            z: 5150;

            Rectangle {
                x: 0px; y: 12px; width: 480px; height: 52px;
                background: #00000000;
                Text {
                    x: 0px; y: 1px; width: parent.width; height: 50px;
                    text: "NOVAKILN";
                    color: #00D084;
                    opacity: 0.26;
                    font-family: "PT Sans";
                    font-size: 36px;
                    font-weight: 700;
                    letter-spacing: 2.0px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Text {
                    x: 0px; y: 0px; width: parent.width; height: 50px;
                    text: "NOVAKILN";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 34px;
                    font-weight: 700;
                    letter-spacing: 2.0px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 0px; y: 88px; width: 480px; height: 126px;
                text: root.temp_label + root.temp_unit_label;
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 104px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 18px; y: 278px; width: 146px; height: 28px;
                text: root.standby_power_watts + " W";
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 20px;
                font-weight: 700;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            Rectangle {
                x: root.is_ua
                    ? (root.status_label == "IDLE" ? 187px
                       : root.status_label == "COOL" ? 187px
                       : root.status_label == "COMPLETE" ? 191px
                       : root.status_label == "ERROR" ? 197px
                       : 199px)
                    : (root.status_label == "ERROR" ? 201px : 205px);
                y: 278px;
                width: root.is_ua
                    ? (root.status_label == "IDLE" ? 106px
                       : root.status_label == "COOL" ? 106px
                       : root.status_label == "COMPLETE" ? 98px
                       : root.status_label == "ERROR" ? 86px
                       : 82px)
                    : (root.status_label == "ERROR" ? 78px : 70px);
                height: 26px;
                background: root.status_bg;
                border-color: root.status_fg;
                border-width: root.status_label == "ERROR" ? 2px : 1px;
                border-radius: 13px;

                Text {
                    text: root.is_ua
                        ? (root.status_label == "IDLE" ? "ОЧІКУВАННЯ"
                          : root.status_label == "PREHEAT" ? "ПІДІГРІВ"
                          : root.status_label == "RAMP" ? "НАГРІВ"
                          : root.status_label == "HOLD" ? "ВИТРИМКА"
                          : root.status_label == "COOL" ? "ОХОЛОДЖЕННЯ"
                          : root.status_label == "COMPLETE" ? "ЗАВЕРШЕНО"
                          : root.status_label == "ERROR" ? "ПОМИЛКА"
                          : root.status_label == "TUNING" ? "АВТОНАЛ."
                          : root.status_label)
                        : root.status_label;
                    color: root.status_fg;
                    font-family: "PT Sans";
                    font-size: root.is_ua ? 12px : 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 314px; y: 278px; width: 148px; height: 28px;
                text: root.target + root.temp_unit_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 20px;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.standby_visible = false; }
            }
    }

    if (root.boot_splash_visible) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #05070B;
            z: 5200;

            Rectangle {
                x: 54px; y: 116px; width: 372px; height: 88px;
                background: #00000000;
                Text {
                    x: 0px; y: 8px; width: parent.width; height: 72px;
                    text: "NOVAKILN";
                    color: #00D084;
                    opacity: 0.30;
                    font-family: "PT Sans";
                    font-size: 54px;
                    font-weight: 700;
                    letter-spacing: 2.2px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Text {
                    x: 0px; y: 7px; width: parent.width; height: 72px;
                    text: "NOVAKILN";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 50px;
                    font-weight: 700;
                    letter-spacing: 2.2px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
    }
    if (root.show_stop_confirm) : Rectangle {


            x: 0px; y: 0px; width: 480px; height: 320px;



            background: #000000B3;



            Rectangle {



                x: 60px; y: 50px; width: 360px; height: 220px;



                background: #0B0B0B;



                border-color: #3F3F46;



                border-width: 1px;



                border-radius: 18px;



                Rectangle {



                    x: 148px; y: 16px; width: 64px; height: 64px;



                    background: #7F1D1D;



                    border-radius: 32px;



                    Text { text: "!"; color: #EF4444; font-size: 28px; horizontal-alignment: center; vertical-alignment: center; }



                }



                Text {



                    x: 0px; y: 86px; width: 360px;



                    text: root.is_ua ? "Зупинити?" : "Stop Firing?";



                    color: #FFFFFF;



                    font-family: "PT Sans";



                    font-size: 20px;



                    horizontal-alignment: center;



                }



                Text {



                    x: 0px; y: 120px; width: 360px;



                    text: root.is_ua ? "Ви впевнені, що хочете перервати процес?" : "Are you sure you want to abort the process?";



                    color: #A1A1AA;



                    font-size: 12px;



                    horizontal-alignment: center;



                }



                Rectangle {



                    x: 20px; y: 156px; width: 150px; height: 52px;



                    background: #27272A;



                    border-radius: 12px;



                    Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.stop_cancel(); } }



                }



                Rectangle {



                    x: 190px; y: 156px; width: 150px; height: 52px;



                    background: #DC2626;



                    border-radius: 12px;



                    Text { text: root.is_ua ? "ЗУПИНИТИ" : "STOP"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.stop_confirm(); } }



                }



            }












    }












    // Software dimming overlay (avoid PWM artifacts)
    Rectangle {
        x: 0px; y: 0px; width: 480px; height: 320px;
        background: #000000;
        opacity: root.ui_dim;
        visible: root.ui_dim > 0.001 && root.view != View.Calibration;
        z: 900;
    }

    // Touch calibration
    if (root.view == View.Calibration) : Rectangle {
        x: 0px; y: 0px; width: 480px; height: 320px;
        z: 6000;
        background: #000000;

        Text {
            x: 12px; y: 300px; width: 456px;
            text: root.calib_hint;
            color: #A1A1AA;
            font-family: "PT Sans";
            font-size: 12px;
            horizontal-alignment: center;
        }

        // target dot
        Rectangle {
            x: root.calib_target_x * 1px - 14px;
            y: root.calib_target_y * 1px - 14px;
            width: 28px; height: 28px;
            background: #00000000;
            border-color: #10B981;
            border-width: 2px;
            border-radius: 14px;
        }
        Rectangle {
            x: root.calib_target_x * 1px - 1px;
            y: root.calib_target_y * 1px - 10px;
            width: 2px; height: 20px;
            background: #10B981;
        }
        Rectangle {
            x: root.calib_target_x * 1px - 10px;
            y: root.calib_target_y * 1px - 1px;
            width: 20px; height: 2px;
            background: #10B981;
        }

        Rectangle {
            x: 360px; y: 282px; width: 100px; height: 28px;
            background: #27272A;
            border-radius: 10px;
            Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; font-family: "PT Sans"; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { width: parent.width; height: parent.height; clicked => { root.cancel_touch_calibration(); } }
        }
    }

}
