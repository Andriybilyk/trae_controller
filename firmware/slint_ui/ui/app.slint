    // Touch debug dot (shows where the touch is detected)



    Rectangle {



        width: 6px;



        height: 6px;



        x: (min(max(root.touch_debug_x - 3, 0), 480 - 6)) * 1px;



        y: (min(max(root.touch_debug_y - 3, 0), 320 - 6)) * 1px;



        background: #FFFFFF;



        border-radius: 3px;



        visible: root.touch_debug_pressed;



        z: 999;



    }



    // Header bar
    Rectangle {
        x: 0px; y: 0px;
        width: parent.width;
        height: root.top_bar_h;
        background: root.c_panel;
        border-color: root.c_border;
        border-width: 1px;
        z: 100;

        Text {
            x: 12px; y: -1px;
            width: 190px; height: parent.height;
            text: "KILN PRO";
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 1.4px;
            horizontal-alignment: left;
            vertical-alignment: center;
        }

        Rectangle {
            x: 210px; y: 0px;
            width: 120px; height: parent.height;
            background: #00000000;
            Text {
                x: 0px; y: -1px; width: parent.width; height: parent.height;
                text: root.current_time + "  " + root.current_date;
                color: root.c_muted;
                font-family: "PT Sans";
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    if (!root.wifi_ok) {
                        root.settings_page = "clock";
                        root.view = View.Settings;
                    }
                }
            }
        }

        Rectangle {
            x: 342px; y: 8px;
            width: 38px; height: 24px;
            background: #27272A;
            border-radius: 6px;
            Text {
                x: 0px; y: 0px; width: parent.width; height: parent.height;
                text: root.is_ua ? "UA" : "EN";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_language(); } }
        }

        Rectangle {
            x: 392px; y: 0px;
            width: 32px; height: parent.height;
            background: #00000000;
            WifiIcon {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 22px; height: 22px;
                color: root.wifi_ok ? root.c_accent : #52525B;
            }
            TouchArea {
                x: -6px; y: -6px;
                width: parent.width + 12px;
                height: parent.height + 12px;
                clicked => { root.settings_page = "wifi"; root.view = View.Settings; }
            }
        }

        Rectangle {
            x: 436px; y: 0px;
            width: 32px; height: parent.height;
            background: #00000000;
            SettingsIcon {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 22px; height: 22px;
                color: root.c_muted;
            }
            TouchArea {
                x: -6px; y: -6px;
                width: parent.width + 12px;
                height: parent.height + 12px;
                clicked => { root.settings_page = "all"; root.view = View.Settings; }
            }
        }
    }



    if (root.fault_active && !root.fault_popup_hidden) : Rectangle {
        x: 30px; y: 108px;
        width: 420px; height: 84px;
        background: #7F1D1D;
        border-color: #DC2626;
        border-width: 2px;
        border-radius: 10px;
        z: 1200;
        Text {
            x: 16px; y: 14px;
            width: parent.width - 64px;
            text: root.fault_reason == ""
                ? (root.is_ua ? "ПОМИЛКА" : "FAULT")
                : ((root.is_ua ? "ПОМИЛКА: " : "FAULT: ") + root.fault_reason);
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 14px;
            horizontal-alignment: center;
            overflow: elide;
        }
        Rectangle {
            x: parent.width - 46px;
            y: 8px;
            width: 34px;
            height: 34px;
            border-radius: 17px;
            background: #991B1B;
            border-color: #DC2626;
            border-width: 1px;
            Text {
                text: "×";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 24px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.fault_popup_hidden = true; }
            }
        }
    }

    if (root.command_feedback_visible) : Rectangle {
        x: 0px;
        y: 40px;
        width: 480px;
        height: 24px;
        background: root.command_feedback_ok ? #064E3B : #7F1D1D;
        border-color: root.command_feedback_ok ? #10B981 : #DC2626;
        border-width: 1px;
        Text {
            x: 10px;
            y: 5px;
            width: parent.width - 20px;
            text: root.command_feedback;
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 12px;
            overflow: elide;
        }
    }

    // Main content



    Rectangle {
        x: 0px; y: root.top_bar_h;
        width: 480px; height: root.page_content_h;



        background: root.c_bg;



        



// Dashboard View



        if (root.view == View.Dashboard) : ScrollView {
            x: 0px; y: 0px;
            width: 480px; height: 280px;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
            mouse-drag-pan-enabled: true;

            Rectangle {
                width: 480px; height: 280px;
                background: root.c_bg;



            // Left column



            Rectangle {



                x: 0px; y: 0px;



                width: 240px; height: 280px;



                background: root.c_bg;



                border-color: root.c_border;



                border-width: 1px;



                Text {



                    x: 16px; y: 12px;



                    text: root.is_ua ? "ПОТОЧНА\nТЕМПЕРАТУРА" : "CURRENT\nTEMPERATURE";



                    color: root.c_muted;



                    font-family: "PT Sans";



                    font-size: 12px;



                    letter-spacing: 0.5px;



                }



                Rectangle {
                    x: root.is_ua ? 120px : 148px; y: 12px;
                    width: root.is_ua
                        ? (root.status_label == "IDLE" ? 106px
                           : root.status_label == "COOL" ? 106px
                           : root.status_label == "COMPLETE" ? 98px
                           : root.status_label == "ERROR" ? 86px
                           : 82px)
                        : (root.status_label == "ERROR" ? 78px : 70px);
                    height: 26px;
                    background: root.status_bg;
                    border-color: root.status_fg;
                    border-width: root.status_label == "ERROR" ? 2px : 1px;
                    border-radius: 13px;

                    Text {
                        text: root.status_text;
                        color: root.status_fg;
                        font-family: "PT Sans";
                        font-size: root.is_ua ? 12px : 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }



                Text {



                    x: 16px; y: 60px;



                    text: root.temp_label;



                    color: #FFFFFF;



                    font-family: "PT Sans";



                    font-size: 64px;



                    font-weight: 700;



                }



                Text {



                    x: 168px; y: 70px;



                    text: root.temp_unit_label;


                    color: root.c_text;



                    font-family: "PT Sans";



                    font-size: 30px;



                }

                Text {
                    x: 16px; y: 128px;
                    text: root.is_ua
                        ? ("Ціль: " + (root.display_target_value > 0 ? (root.display_target_value + root.temp_unit_label) : "--"))
                        : ("Target: " + (root.display_target_value > 0 ? (root.display_target_value + root.temp_unit_label) : "--"));
                    color: root.c_muted;
                    font-family: "PT Sans";
                    font-size: 18px;
                }



                Rectangle {



                    x: 12px; y: 176px;



                    width: 216px; height: 92px;



                    background: root.c_card;



                    border-color: root.c_border;



                    border-width: 1px;



                    border-radius: 14px;



                    Text {
                        x: 12px; y: 10px;
                        text: root.is_ua ? "Електрика" : "Power";



                        color: root.c_muted;



                        font-family: "PT Sans";



                        font-size: 14px;



                    }



                    Text {
                        x: 12px; y: 32px;
                        width: 92px; height: 16px;
                        text: root.pzem_power_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: 12px; y: 50px;
                        width: 92px; height: 16px;
                        text: root.pzem_current_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: 110px; y: 32px;
                        width: 92px; height: 16px;
                        text: root.pzem_voltage_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    Text {
                        x: 110px; y: 50px;
                        width: 92px; height: 16px;
                        text: root.pzem_phase_label;
                        color: root.c_text;
                        font-family: "PT Sans";
                        font-size: 12px;
                        vertical-alignment: center;
                    }



                    Rectangle {



                        x: 12px; y: 88px;



                        width: 192px; height: 4px;



                        background: root.c_border;



                        border-radius: 2px;



                        Rectangle {



                            width: root.display_target_value > 0 ? min((root.temp / root.display_target_value) * 192px, 192px) : 0px;



                            height: 4px;



                            background: root.status_fg;



                            border-radius: 2px;



                        }



                    }



                }



            }



            // Right column



            Rectangle {



                x: 240px; y: 0px;



                width: 240px; height: 280px;



                background: root.c_bg;



                Rectangle {



                    x: 10px; y: 12px;



                    width: 220px; height: 150px;



                    background: root.c_card;



                    border-color: root.c_border;



                    border-width: 1px;



                    border-radius: 16px;



                    if (root.is_idle && root.selected_schedule_name == "") : Rectangle {



                        width: 220px; height: 150px;



                        background: #00000000;



                        ActivityIcon {



                            x: (parent.width - self.width) / 2;



                            y: 50px;



                            color: #3F3F46;



                            width: 32px; height: 32px;



                        }



                        Text {



                            x: 0px; y: 92px;



                            width: 220px;



                            text: root.is_ua ? "Виберіть програму" : "Select Schedule";



                            color: root.c_muted;



                            font-family: "PT Sans";



                            font-size: 18px;


                            horizontal-alignment: center;



                        }



                    }



                    if (root.is_idle && root.selected_schedule_name != "") : Rectangle {



                        width: 220px; height: 150px;



                        background: #00000000;



                        Text {
                            x: 0px; y: 18px;
                            width: 220px;
                            text: root.is_ua ? "Вибрана програма" : "Selected Program";
                            color: root.c_accent;
                            font-family: "PT Sans";
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            x: 0px; y: 44px;
                            width: 220px;
                            text: root.selected_schedule_name;
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 20px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }

                        Text {
                            x: 0px; y: 68px;
                            width: 220px;
                            text: root.selected_steps_count + " " + (root.is_ua ? "кроків" : "segments");
                            color: root.c_subtle;
                            font-size: 16px;
                            horizontal-alignment: center;
                        }





                    }

                    if (!root.is_idle) : Rectangle {



                        width: 220px; height: 150px;



                        background: #00000000;



                        Rectangle {
                            x: 10px; y: 6px;
                            width: 200px; height: 102px;
                            border-radius: 12px;
                            background: #18181B;
                            border-color: #27272A;
                            border-width: 1px;
                        }

                        Text {



                            x: 0px; y: 14px;



                            width: 220px;



                            text: root.is_ua ? "Крок" : "Step";



                            color: root.c_muted;



                            font-size: 14px;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px; y: 36px;



                            width: 220px;



                            text: root.step_index + " / " + root.total_steps;



                            color: #FFFFFF;



                            font-family: "PT Sans";



                            font-size: 28px;



                            horizontal-alignment: center;



                        }



                        Text {



                            x: 0px; y: 66px;



                            width: 220px;



                            text: root.is_ua
                                ? ("Ціль " + root.active_segment_target + root.temp_unit_label)
                                : ("Target " + root.active_segment_target + root.temp_unit_label);



                            color: #71717A;



                            font-size: 14px;



                            horizontal-alignment: center;



                        }

                        Rectangle {
                            x: 10px; y: 116px;
                            width: 200px; height: 30px;
                            border-radius: 10px;
                            background: root.c_danger;
                            Text {
                                text: root.is_ua ? "Пропустити крок" : "Skip Step";
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_step(); } }
                        }



                    }



                    if (root.is_idle) : TouchArea {



                width: parent.width; height: parent.height; clicked => {
                    if (root.selected_schedule_name != "") {
                        root.open_selected_program();
                    } else {
                        root.open_library();
                    }
                } }



                }



                // Bottom action buttons



                Rectangle {



                    x: 10px; y: 174px;



                    width: 220px; height: 94px;

                    // Big STOP button (shown while firing)
                    Rectangle {
                        visible: !root.is_idle;
                        x: 0px; y: 0px;
                        width: 106px; height: 94px;
                        background: root.c_danger;
                        border-radius: 16px;

                        StopIcon { x: (parent.width - self.width) / 2; y: 20px; color: #FFFFFF; width: 18px; height: 18px; }

                        Text {
                            x: 0px; y: 50px;
                            width: parent.width;
                            text: root.is_ua ? "Зупинити" : "Stop";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea { width: parent.width; height: parent.height; clicked => { root.stop_firing(); } }
                    }


                    background: #00000000;



                    Rectangle {



                        x: 0px; y: 0px;



                        visible: root.is_idle;

                        width: 106px; height: 94px;


                        background: root.fault_active ? #4A1111 : (root.selected_schedule_name == "" ? root.c_border : root.c_accent);



                        border-radius: 16px;



                        PlayIcon {



                            x: (parent.width - self.width) / 2;



                            y: 18px;



                            color: (root.selected_schedule_name == "" || root.fault_active) ? root.c_muted : #000000;



                            width: 18px; height: 18px;



                        }



                        if (root.selected_schedule_name == "") : Rectangle {



                            width: parent.width; height: parent.height;



                            background: #00000000;



                            Text {



                                x: 0px; y: 42px;



                                width: parent.width;



                                text: root.is_ua ? "Виберіть" : "Select";



                                color: root.c_muted;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                            Text {



                                x: 0px; y: 58px;



                                width: parent.width;



                                text: root.is_ua ? "програму" : "Schedule";



                                color: root.c_muted;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                        }



                        if (root.selected_schedule_name != "") : Rectangle {



                            width: parent.width; height: parent.height;



                            background: #00000000;



                            Text {



                                x: 0px; y: 42px;



                                width: parent.width;



                                text: root.is_ua ? "Старт" : "Start";



                                color: root.fault_active ? #FFFFFF : #000000;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                            Text {



                                x: 0px; y: 58px;



                                width: parent.width;



                                text: root.is_ua ? "Випал" : "Firing";



                                color: root.fault_active ? #FFFFFF : #000000;



                                font-family: "PT Sans";



                                font-size: 15px;



                                horizontal-alignment: center;



                            }



                        }



                        TouchArea {



                width: parent.width; height: parent.height; clicked => { if (!root.fault_active) { root.start_firing(); } } }


                    }



                    Rectangle {



                        x: 114px; y: 0px; visible: true;


                        width: 106px; height: 94px;



                        background: root.c_border;



                        border-radius: 16px;



                        ThermometerIcon {



                            x: (parent.width - self.width) / 2;



                            y: 18px;



                            color: root.c_text;



                            width: 18px; height: 18px;



                        }



                        Text {



                            x: 0px; y: 46px;



                            width: parent.width;



                            text: !root.is_idle ? (root.is_ua ? "Редагувати" : "Edit") : (root.is_ua ? "Програми" : "Programs");



                            color: root.c_text;



                            font-family: "PT Sans";



                            font-size: 15px;



                            horizontal-alignment: center;



                            vertical-alignment: center;



                        }



                        TouchArea {



                width: parent.width; height: parent.height; clicked => {
                    if (!root.is_idle) {
                        root.open_running_editor();
                    } else {
                        root.open_library();
                    }
                } }



                    }



                }



            }



            }
        }


        // (touch debug bar removed)



// Schedules View



        if (root.view == View.Schedules) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                background: root.c_bg;



                Rectangle {
                    x: 0px; y: root.settings_title_y;
                    width: 480px; height: root.settings_header_h;
                    background: #00000000;

                    ThermometerIcon {
                        x: root.settings_side_gap;
                        y: (parent.height - root.settings_icon_size) / 2;
                        width: root.settings_icon_size; height: root.settings_icon_size;
                        color: #10B981;
                    }

                    Text {
                        x: root.settings_title_x;
                        y: 0px;
                        width: 300px; height: parent.height;
                        text: root.is_ua ? "Бібліотека" : "Library";
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px;
                        vertical-alignment: center;
                    }
                }



                Rectangle {
                    x: 480px - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    border-radius: root.settings_action_btn_radius;
                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.view = View.Dashboard; } }
                }



                ScrollView { // schedules-list
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: 480px - root.settings_side_gap * 2;
                    height: parent.height - root.settings_content_y - root.settings_side_gap;
                    viewport-width: self.width;
                    viewport-height: (root.schedules.length + 1) * (root.settings_list_row_h + 12px) + root.schedules.length * root.settings_grid_gap;
                    viewport-x: 0px;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;
                    VerticalBox {
                        width: 480px - root.settings_side_gap * 2;
                        spacing: root.settings_grid_gap;
                        for schedule[i] in root.schedules : Rectangle {
                            width: 480px - root.settings_side_gap * 4; height: root.settings_list_row_h + 12px;


                            background: schedule.selected ? #1F2937 : #0F0F0F;



                            border-color: schedule.selected ? #10B981 : #27272A;



                            border-width: 1px;



                            border-radius: 12px;



                            Text {
                                x: root.settings_inner_pad; y: root.settings_label_y;
                                text: schedule.name;
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 18px;
                                font-weight: 700;
                            }

                            Text {
                                x: root.settings_inner_pad; y: root.settings_label_y + 18px;
                                width: parent.width - 196px;
                                text: root.is_ua ? "\u{041a}\u{043e}\u{0440}\u{0438}\u{0441}\u{0442}\u{0443}\u{0432}\u{0430}\u{0446}\u{044c}\u{043a}\u{0430}" : "Custom";
                                color: #A1A1AA;
                                font-size: 14px;
                                horizontal-alignment: left;
                            }

                            Text {
                                x: root.settings_inner_pad; y: root.settings_label_y + 34px;
                                text: schedule.steps_count + " " + (root.is_ua ? "\u{043a}\u{0440}\u{043e}\u{043a}\u{0456}\u{0432}" : "segments");
                                color: #A1A1AA;
                                font-size: 14px;
                            }



                            Rectangle {
                                z: 2;
                                x: parent.width - root.settings_inner_pad - (root.settings_action_btn_h * 3 + root.settings_grid_gap * 2);
                                y: (parent.height - self.height) / 2;
                                width: root.settings_action_btn_h; height: root.settings_action_btn_h;
                                background: #1F2937;
                                border-radius: root.settings_action_btn_h / 2;

                                Rectangle { x: 14px; y: 32px; width: 24px; height: 2px; background: #FFFFFF; border-radius: 1px; }
                                Rectangle { x: 16px; y: 28px; width: 4px; height: 4px; background: #FFFFFF; border-radius: 2px; }
                                Rectangle { x: 24px; y: 24px; width: 4px; height: 4px; background: #FFFFFF; border-radius: 2px; }
                                Rectangle { x: 32px; y: 18px; width: 4px; height: 4px; background: #FFFFFF; border-radius: 2px; }
                                Rectangle { x: 20px; y: 26px; width: 6px; height: 2px; background: #FFFFFF; border-radius: 1px; }
                                Rectangle { x: 28px; y: 22px; width: 6px; height: 2px; background: #FFFFFF; border-radius: 1px; }

                                TouchArea {
                    width: parent.width; height: parent.height; clicked => { root.open_schedule_graph(i); } }
                            }

                            Rectangle {
                                z: 2;
                                x: parent.width - root.settings_inner_pad - (root.settings_action_btn_h * 2 + root.settings_grid_gap);
                                y: (parent.height - self.height) / 2;
                                width: root.settings_action_btn_h; height: root.settings_action_btn_h;
                                background: #3A1C1C;
                                border-radius: root.settings_action_btn_h / 2;

                                Text {
                                    x: 0px; y: 0px;
                                    width: parent.width; height: parent.height;
                                    text: "\u{e872}";
                                    color: #FFFFFF;
                                    font-family: "Material Icons";
                                    font-size: 24px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }

                                TouchArea {
                    width: parent.width; height: parent.height; clicked => { root.delete_confirm_index = i; root.delete_confirm_visible = true; } }
                            }

                            Rectangle {
                                z: 2;
                                x: parent.width - root.settings_inner_pad - root.settings_action_btn_h;
                                y: (parent.height - self.height) / 2;
                                width: root.settings_action_btn_h; height: root.settings_action_btn_h;


                                background: schedule.selected ? #10B981 : #27272A;



                                border-radius: root.settings_action_btn_h / 2;


                                PlayIcon {



                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;


                                    width: 22px; height: 22px;


                                    color: schedule.selected ? #000000 : #FFFFFF;



                                }



                                TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.select_schedule(i); } }



                            }



                            TouchArea {
                                width: parent.width - (root.settings_inner_pad + root.settings_action_btn_h * 3 + root.settings_grid_gap * 2);
                                height: parent.height;


                                x: 0px; y: 0px;
                                z: 1;
                                clicked => { root.edit_schedule(i); }
                            }


                        }



                        Rectangle {
                            width: 480px - root.settings_side_gap * 4; height: root.settings_list_row_h + 12px;


                            background: #000000;



                            border-color: #3F3F46;



                            border-width: 1px;



                            border-radius: 12px;



                            Text { text: root.is_ua ? "Нова програма" : "New Program"; color: #A1A1AA; font-family: "PT Sans"; font-size: 16px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }


                            TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.new_schedule(); } }



                        }



                    }
                }



        }


        if (root.view == View.ScheduleGraph) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: 280px;
                background: #000000;
                clip: true;

                Text {
                    x: root.settings_side_gap;
                    y: root.settings_title_y;
                    width: 480px - root.settings_side_gap * 2 - (root.settings_nav_btn_w * 2 + root.settings_nav_gap);
                    height: root.settings_header_h;
                    text: root.selected_schedule_name == ""
                        ? (root.is_ua ? "Графік програми" : "Program Graph")
                        : root.selected_schedule_name;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                UiButton {
                    x: 480px - root.settings_side_gap - root.settings_nav_btn_w * 2 - root.settings_nav_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #1F2937;
                    radius: root.settings_action_btn_radius;
                    label: "<";
                    text_size: 16px;
                    tapped => { root.view = root.schedule_graph_back_to_history ? View.Settings : View.Schedules; }
                }

                UiButton {
                    x: 480px - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    radius: root.settings_action_btn_radius;
                    label: "X";
                    text_size: 16px;
                    tapped => { root.view = View.Dashboard; }
                }

                Rectangle {
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.settings_content_width; height: root.settings_content_height;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px;
                    border-radius: 12px;
                    clip: true;

                    Text {
                        x: 12px; y: 6px; width: parent.width - 140px; height: 18px;
                        text: root.selected_steps_count + " " + (root.is_ua ? "кроків" : "steps");
                        color: #A1A1AA;
                        font-family: "PT Sans";
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                    }

                    Text {
                        x: parent.width - 120px; y: 6px; width: 108px; height: 18px;
                        text: root.schedule_graph_peak_temp + "" + root.temp_unit_label;
                        color: #A1A1AA;
                        font-family: "PT Sans";
                        font-size: 12px;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        x: 44px; y: 30px; width: root.schedule_graph_plot_w; height: root.schedule_graph_plot_h;
                        background: #0B0B10;
                        border-color: #1F2937;
                        border-width: 1px;
                        border-radius: 10px;
                        clip: false;

                        Text {
                            x: -44px; y: 8px; width: 40px; height: 14px;
                            text: root.schedule_graph_peak_temp + "" + root.temp_unit_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }

                        Text {
                            x: -44px; y: parent.height / 2 - 7px; width: 40px; height: 14px;
                            text: root.schedule_graph_mid_temp + "" + root.temp_unit_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }

                        Text {
                            x: -44px; y: parent.height - 18px; width: 40px; height: 14px;
                            text: "0";
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }

                        Text {
                            x: parent.width / 2 - 46px; y: parent.height + 6px; width: 92px; height: 14px;
                            text: root.schedule_graph_half_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Text {
                            x: parent.width - 92px; y: parent.height + 6px; width: 92px; height: 14px;
                            text: root.schedule_graph_total_label;
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 10px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        Rectangle {
                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                            background: #00000000;
                            clip: true;
                            // Plot area geometry aligned with Rust mapping:
                            // left 19, right 6, top 8, bottom 18.
                            Rectangle { x: 19px; y: 8px; width: 1px; height: parent.height - 26px; background: #27272A; }
                            Rectangle { x: 19px; y: parent.height - 18px; width: parent.width - 25px; height: 1px; background: #27272A; }
                            Rectangle { x: 19px + (parent.width - 25px) / 6; y: 8px; width: 1px; height: parent.height - 26px; background: #16161E; }
                            Rectangle { x: 19px + (parent.width - 25px) * 2 / 6; y: 8px; width: 1px; height: parent.height - 26px; background: #16161E; }
                            Rectangle { x: 19px + (parent.width - 25px) * 3 / 6; y: 8px; width: 1px; height: parent.height - 26px; background: #16161E; }
                            Rectangle { x: 19px + (parent.width - 25px) * 4 / 6; y: 8px; width: 1px; height: parent.height - 26px; background: #16161E; }
                            Rectangle { x: 19px + (parent.width - 25px) * 5 / 6; y: 8px; width: 1px; height: parent.height - 26px; background: #16161E; }
                            Rectangle { x: 19px; y: 8px + (parent.height - 26px) / 5; width: parent.width - 25px; height: 1px; background: #16161E; }
                            Rectangle { x: 19px; y: 8px + (parent.height - 26px) * 2 / 5; width: parent.width - 25px; height: 1px; background: #16161E; }
                            Rectangle { x: 19px; y: 8px + (parent.height - 26px) * 3 / 5; width: parent.width - 25px; height: 1px; background: #16161E; }
                            Rectangle { x: 19px; y: 8px + (parent.height - 26px) * 4 / 5; width: parent.width - 25px; height: 1px; background: #16161E; }
                            Rectangle { x: 19px; y: 8px + (parent.height - 26px) / 2; width: parent.width - 25px; height: 1px; background: #1F2937; }

                            for rect in root.schedule_graph_rects : Rectangle {
                                x: rect.x * 1px;
                                y: rect.y * 1px;
                                width: rect.width * 1px;
                                height: rect.height * 1px;
                                background: rect.color;
                                border-radius: 1px;
                            }

                            for marker in root.schedule_graph_markers : Rectangle {
                                x: marker.x * 1px - 3px;
                                y: marker.y * 1px - 3px;
                                width: 6px;
                                height: 6px;
                                background: marker.color;
                                border-radius: 3px;
                            }

                        for marker in root.schedule_graph_markers : Text {
                            x: marker.y * 1px > parent.height - 14px
                                ? (marker.x < 42 ? 2px : marker.x * 1px - 40px)
                                : (marker.x < 34 ? 2px : marker.x * 1px - 32px);
                            y: marker.y * 1px > parent.height - 14px
                                ? parent.height + 6px
                                : (marker.y < 26 ? 0px : (marker.y - 26) * 1px);
                            width: 80px; height: 14px;
                            text: marker.label;
                            color: marker.color;
                            font-family: "PT Sans";
                            font-size: 10px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        }

                        if (root.schedule_graph_rects.length == 0) : Text {
                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                            text: root.is_ua ? "У програмі ще немає кроків для графіка" : "This program has no steps to plot yet";
                            color: #71717A;
                            font-family: "PT Sans";
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

        }


        if (root.view == View.HistoryDetail) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: 280px;
                background: #000000;
                clip: true;

                Text {
                    x: root.settings_side_gap;
                    y: root.settings_title_y;
                    width: 480px - root.settings_side_gap * 2 - (root.settings_nav_btn_w * 2 + root.settings_nav_gap);
                    height: root.settings_header_h;
                    text: root.history_detail_title == ""
                        ? (root.is_ua ? "Деталі випалу" : "Firing Details")
                        : root.history_detail_title;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                UiButton {
                    x: 480px - root.settings_side_gap - root.settings_nav_btn_w * 2 - root.settings_nav_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #1F2937;
                    radius: root.settings_action_btn_radius;
                    label: "<";
                    text_size: 16px;
                    tapped => { root.view = View.Settings; root.settings_page = "history"; }
                }

                UiButton {
                    x: 480px - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    radius: root.settings_action_btn_radius;
                    label: "X";
                    text_size: 16px;
                    tapped => { root.view = View.Dashboard; }
                }

                ScrollView {
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.settings_content_width; height: root.settings_content_height;
                    viewport-width: self.width;
                    viewport-height: 430px;
                    viewport-x: 0px;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;

                    Rectangle {
                        x: 0px; y: 0px; width: root.settings_content_width; height: 430px; background: #00000000;

                        Rectangle {
                            x: 0px; y: 0px; width: parent.width; height: 124px;
                            background: #111118; border-color: #27272A; border-width: 1px; border-radius: 12px;
                            Text { x: 12px; y: 8px; width: parent.width - 24px; height: 18px; text: root.is_ua ? "Паспорт випалу" : "Firing Passport"; color: #FFFFFF; font-size: 13px; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px; y: 30px; width: 150px; height: 16px; text: root.is_ua ? "Назва програми" : "Program name"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 30px; width: parent.width - 180px; height: 16px; text: root.history_detail_program_name; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                            Text { x: 12px; y: 48px; width: 150px; height: 16px; text: root.is_ua ? "Початок" : "Start"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 48px; width: parent.width - 180px; height: 16px; text: root.history_detail_start_time; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                            Text { x: 12px; y: 66px; width: 150px; height: 16px; text: root.is_ua ? "Завершення" : "End"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 66px; width: parent.width - 180px; height: 16px; text: root.history_detail_end_time; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                            Text { x: 12px; y: 84px; width: 150px; height: 16px; text: root.is_ua ? "Тривалість" : "Duration"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 84px; width: parent.width - 180px; height: 16px; text: root.history_detail_duration; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                            Text { x: 12px; y: 102px; width: 150px; height: 16px; text: root.is_ua ? "Статус завершення" : "Completion"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 102px; width: parent.width - 180px; height: 16px; text: root.history_detail_status_verbose; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                        }

                        Rectangle {
                            x: 0px; y: 132px; width: parent.width; height: 96px;
                            background: #111118; border-color: #27272A; border-width: 1px; border-radius: 12px;
                            Text { x: 12px; y: 8px; width: parent.width - 24px; height: 18px; text: root.is_ua ? "Енергоспоживання" : "Energy"; color: #FFFFFF; font-size: 13px; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px; y: 30px; width: 150px; height: 16px; text: root.is_ua ? "Витрачено кВт·год" : "Consumed kWh"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 30px; width: parent.width - 180px; height: 16px; text: root.history_detail_energy; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                            Text { x: 12px; y: 48px; width: 150px; height: 16px; text: root.is_ua ? "Вартість випалу" : "Cycle cost"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 48px; width: parent.width - 180px; height: 16px; text: root.history_detail_energy_cost; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                            Text { x: 12px; y: 66px; width: 150px; height: 16px; text: root.is_ua ? "Макс. навантаження" : "Peak load"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 66px; width: parent.width - 180px; height: 16px; text: root.history_detail_max_load; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                        }

                        Rectangle {
                            x: 0px; y: 236px; width: parent.width; height: 78px;
                            background: #111118; border-color: #27272A; border-width: 1px; border-radius: 12px;
                            Text { x: 12px; y: 8px; width: parent.width - 24px; height: 18px; text: root.is_ua ? "Технологічні показники" : "Quality Metrics"; color: #FFFFFF; font-size: 13px; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px; y: 30px; width: 150px; height: 16px; text: root.is_ua ? "Макс. температура" : "Peak temperature"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 30px; width: parent.width - 180px; height: 16px; text: root.history_detail_peak_temp; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                            Text { x: 12px; y: 48px; width: 150px; height: 16px; text: root.is_ua ? "Стабільність напруги" : "Voltage stability"; color: #A1A1AA; font-size: 11px; }
                            Text { x: 168px; y: 48px; width: parent.width - 180px; height: 16px; text: root.history_detail_voltage_stability; color: #FFFFFF; font-size: 11px; horizontal-alignment: right; overflow: elide; }
                        }

                        Rectangle {
                            x: 0px; y: 322px; width: parent.width; height: 108px;
                            background: #111118; border-color: #27272A; border-width: 1px; border-radius: 12px;
                            Text { x: 12px; y: 8px; width: parent.width - 24px; height: 18px; text: root.is_ua ? "Кроки (план/факт)" : "Steps (plan/actual)"; color: #FFFFFF; font-size: 13px; font-weight: 700; vertical-alignment: center; }
                            Text { x: 12px; y: 28px; width: parent.width - 24px; height: 72px; text: root.history_detail_step_plan_actual; color: #FFFFFF; font-size: 11px; vertical-alignment: top; overflow: elide; }
                        }
                    }
                }
        }

        if (root.view == View.RunningEditor) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: 280px;
                background: #000000;

                HorizontalBox {
                    x: root.settings_side_gap; y: root.settings_title_y;
                    spacing: 6px;
                    ThermometerIcon { color: #10B981; }
                    Text {
                        text: root.is_ua ? "Редагування випалу" : "Firing Edit";
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px;
                        width: 260px;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle {
                    x: 420px; y: 8px; width: 40px; height: 28px;
                    background: #27272A;
                    border-radius: 10px;
                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_back(); } }
                }

                Rectangle {
                    x: 14px; y: 46px; width: 452px; height: 58px;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px;
                    border-radius: 12px;
                    Text { x: 14px; y: 8px; text: root.is_ua ? ("Швидкість нагріву (" + root.rate_unit_label_min + ")") : ("Ramp rate (" + root.rate_unit_label_min + ")"); color: #A1A1AA; font-size: 13px; }
                    Text { x: 14px; y: 28px; text: root.running_edit_rate; color: #FFFFFF; font-size: 18px; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_rate", -1, root.running_edit_rate); } }
                }

                Rectangle {
                    x: 14px; y: 112px; width: 452px; height: 58px;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px;
                    border-radius: 12px;
                    Text { x: 14px; y: 8px; text: root.is_ua ? ("Додати температуру (" + root.temp_unit_label + ")") : ("Add temperature (" + root.temp_unit_label + ")"); color: #A1A1AA; font-size: 13px; }
                    Text { x: 14px; y: 28px; text: root.running_edit_add_temp; color: #FFFFFF; font-size: 18px; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_temp", -1, root.running_edit_add_temp); } }
                }

                Rectangle {
                    x: 14px; y: 178px; width: 452px; height: 58px;
                    background: #111118;
                    border-color: #27272A;
                    border-width: 1px;
                    border-radius: 12px;
                    Text { x: 14px; y: 8px; text: root.is_ua ? "Додати час (хв)" : "Add hold time (min)"; color: #A1A1AA; font-size: 13px; }
                    Text { x: 14px; y: 28px; text: root.running_edit_add_time; color: #FFFFFF; font-size: 18px; font-weight: 700; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("run_time", -1, root.running_edit_add_time); } }
                }

                Rectangle {
                    x: 304px; y: 242px; width: 162px; height: 28px;
                    background: #10B981;
                    border-radius: 10px;
                    Text { text: root.is_ua ? "Зберегти" : "Apply"; color: #000000; font-family: "PT Sans"; font-size: 14px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_apply(); } }
                }
        }

        

        // Settings View
        if (root.view == View.Settings) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                background: root.c_bg;
                clip: true;

                if (root.settings_page == "wifi") : WifiIcon {
                    x: root.settings_side_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_icon_size) / 2;
                    width: root.settings_icon_size;
                    height: root.settings_icon_size;
                    color: root.wifi_ok ? #10B981 : #52525B;
                }

                if (root.settings_page != "wifi") : SettingsIcon {
                    x: root.settings_side_gap;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_icon_size) / 2;
                    width: root.settings_icon_size;
                    height: root.settings_icon_size;
                    color: #A1A1AA;
                }

                Text {
                    x: root.settings_title_x;
                    y: root.settings_title_y;
                    width: root.settings_title_width;
                    height: root.settings_header_h;
                    text: root.settings_page == "wifi" ? "Wi-Fi"
                        : root.settings_page == "clock" ? (root.is_ua ? "Час і дата" : "Time & Date")
                        : root.settings_page == "controller_info" ? (root.is_ua ? "Інфо контроллера" : "Controller Info")
                        : root.settings_page == "display" ? (root.is_ua ? "\u{0420}\u{0435}\u{0436}\u{0438}\u{043c}\u{0020}\u{0432}\u{0456}\u{0434}\u{043e}\u{0431}\u{0440}\u{0430}\u{0436}\u{0435}\u{043d}\u{043d}\u{044f}" : "Display mode")
                        : root.settings_page == "display_hw" ? (root.is_ua ? "\u{0414}\u{0438}\u{0441}\u{043f}\u{043b}\u{0435}\u{0439}" : "Display")
                        : root.settings_page == "fan" ? (root.is_ua ? "\u{0412}\u{0435}\u{043d}\u{0442}\u{0438}\u{043b}\u{044f}\u{0442}\u{043e}\u{0440}" : "Fan")
                        : root.settings_page == "autotune" ? (root.is_ua ? "Налаштування" : "Settings")
                        : root.settings_page == "fault" ? (root.is_ua ? "\u{041f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043a}\u{0438}" : "Faults")
                        : root.settings_page == "history" ? (root.is_ua ? "\u{0406}\u{0441}\u{0442}\u{043e}\u{0440}\u{0456}\u{044f}" : "History")
                        : root.settings_page == "fault_logs" ? (root.is_ua ? "\u{041b}\u{043e}\u{0433}\u{0438}\u{0020}\u{043f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043e}\u{043a}" : "Fault Logs")
                        : root.settings_page == "touch" ? (root.is_ua ? "\u{041a}\u{0430}\u{043b}\u{0456}\u{0431}\u{0440}\u{0443}\u{0432}\u{0430}\u{043d}\u{043d}\u{044f}\u{0020}\u{0442}\u{0430}\u{0447}" : "Touch Calibration")
                        : (root.is_ua ? "\u{041d}\u{0430}\u{043b}\u{0430}\u{0448}\u{0442}\u{0443}\u{0432}\u{0430}\u{043d}\u{043d}\u{044f}" : "Settings");
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 18px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }

                if (root.settings_page != "all" && root.settings_page != "wifi") : UiButton {
                    x: root.settings_back_btn_x;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #1F2937;
                    radius: 10px;
                    label: "<";
                    text_size: 16px;
                    tapped => { root.settings_page = "all"; }
                }

                UiButton {
                    x: root.settings_close_btn_x;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    radius: 10px;
                    label: "X";
                    text_size: 16px;
                    tapped => { root.view = View.Dashboard; }
                }

                if (root.settings_page != "display_hw") : Rectangle {
                    x: root.settings_panel_x; y: root.settings_panel_y;
                    width: root.settings_panel_w; height: root.settings_content_height;
                    background: #00000000;
                    clip: true;

                    Rectangle {
                        x: 0px;
                        width: root.settings_content_width;
                        height: 232px;
                        background: #00000000;

                        if (root.settings_page == "all") : Rectangle {
                            width: root.settings_content_width;
                            height: root.settings_card_h * 3 + root.settings_card_gap * 2;
                            background: #00000000;

                            Rectangle {
                                x: 0px; y: 0px;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{0420}\u{0435}\u{0436}\u{0438}\u{043c}\u{0020}\u{0432}\u{0456}\u{0434}\u{043e}\u{0431}\u{0440}\u{0430}\u{0436}\u{0435}\u{043d}\u{043d}\u{044f}" : "Display mode";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "display"; } }
                            }

                            Rectangle {
                                x: root.settings_col_width + root.settings_grid_gap; y: 0px;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "Налаштування" : "Settings";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "autotune"; } }
                            }

                            Rectangle {
                                x: 0px; y: root.settings_card_step;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{0414}\u{0438}\u{0441}\u{043f}\u{043b}\u{0435}\u{0439}" : "Display";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "display_hw"; } }
                            }

                            Rectangle {
                                x: root.settings_col_width + root.settings_grid_gap; y: root.settings_card_step;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{041f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043a}\u{0438}" : "Faults";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "fault"; } }
                            }

                            Rectangle {
                                x: 0px; y: root.settings_card_step * 2;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "\u{0406}\u{0441}\u{0442}\u{043e}\u{0440}\u{0456}\u{044f}" : "History";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.open_history(); } }
                            }

                            Rectangle {
                                x: root.settings_col_width + root.settings_grid_gap; y: root.settings_card_step * 2;
                                width: root.settings_col_width; height: root.settings_card_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                                    text: root.is_ua ? "Інфо контроллера" : "Controller Info";
                                    color: #FFFFFF;
                                    font-family: "PT Sans";
                                    font-size: 18px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                                TouchArea { width: parent.width; height: parent.height; clicked => { root.settings_page = "controller_info"; } }
                            }
                        }

                        if (root.settings_page == "controller_info") : ScrollView {
                            x: 0px; y: 0px;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: root.settings_display_row_h * 8 + root.settings_vertical_gap * 7;
                            viewport-x: 0px;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                            mouse-drag-pan-enabled: true;

                            Rectangle {
                                width: root.settings_content_width;
                                height: root.settings_display_row_h * 8 + root.settings_vertical_gap * 7;
                                background: #00000000;

                                for i in [0, 1, 2, 3, 4, 5, 6, 7] : Rectangle {
                                    y: i * root.settings_display_row_step;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;

                                    Text {
                                        x: 12px; y: 0px; width: 190px; height: parent.height;
                                        text: i == 0 ? (root.is_ua ? "Версія прошивки" : "Firmware")
                                            : i == 1 ? (root.is_ua ? "Пам'ять RAM" : "RAM Heap")
                                            : i == 2 ? (root.is_ua ? "Сховище програм" : "Program Storage")
                                            : i == 3 ? "Device ID"
                                            : i == 4 ? (root.is_ua ? "Час напрацювання" : "Uptime")
                                            : i == 5 ? (root.is_ua ? "Пробіг ТЕНів" : "Heating Hours")
                                            : i == 6 ? (root.is_ua ? "Температура чіпа" : "Chip Temp")
                                            : "PZEM-004T";
                                        color: #A1A1AA;
                                        font-family: "PT Sans";
                                        font-size: 14px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    Text {
                                        x: 206px; y: 0px; width: parent.width - 218px; height: parent.height;
                                        text: i == 0 ? root.controller_info_fw
                                            : i == 1 ? root.controller_info_heap
                                            : i == 2 ? root.controller_info_storage
                                            : i == 3 ? root.controller_info_device_id
                                            : i == 4 ? root.controller_info_uptime
                                            : i == 5 ? root.controller_info_heating_hours
                                            : i == 6 ? root.controller_info_chip_temp
                                            : root.controller_info_pzem;
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 14px;
                                        horizontal-alignment: right;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }

                        if (root.settings_page == "clock") : Rectangle {
                            x: 0px;
                            width: root.settings_content_width;
                            height: root.settings_display_row_h * 2 + root.settings_vertical_gap;
                            background: #00000000;

                            Rectangle {
                                y: 0px;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: root.c_border;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "Час" : "Time";
                                    color: root.c_muted;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 160px; y: root.settings_display_btn_y; width: 148px; height: root.settings_btn_height;
                                    background: #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: root.current_time; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("clock_time", -1, root.current_time); } }
                                }
                            }

                            Rectangle {
                                y: root.settings_display_row_step;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: root.c_border;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "Дата" : "Date";
                                    color: root.c_muted;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 200px; y: root.settings_display_btn_y; width: 188px; height: root.settings_btn_height;
                                    background: #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: root.current_date; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("clock_date", -1, root.current_date); } }
                                }
                            }
                        }

                        if (root.settings_page == "display") : Rectangle {
                            x: 0px;
                            width: root.settings_content_width;
                            height: root.settings_display_row_h * 3 + root.settings_vertical_gap * 2;
                            background: #00000000;

                            Rectangle {
                                y: 0px;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "\u{0422}\u{0435}\u{043c}\u{043f}\u{0435}\u{0440}\u{0430}\u{0442}\u{0443}\u{0440}\u{0430}" : "Temperature";
                                    color: #A1A1AA;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 154px; y: root.settings_display_btn_y; width: 68px; height: root.settings_btn_height;
                                    background: root.temp_unit == "C" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "C\u{00B0}"; color: root.temp_unit == "C" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.temp_unit = "C"; root.set_temp_unit("C"); } }
                                }
                                Rectangle {
                                    x: parent.width - 80px; y: root.settings_display_btn_y; width: 68px; height: root.settings_btn_height;
                                    background: root.temp_unit == "F" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "F\u{00B0}"; color: root.temp_unit == "F" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.temp_unit = "F"; root.set_temp_unit("F"); } }
                                }
                            }

                            Rectangle {
                                y: root.settings_display_row_step;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "\u{0427}\u{0430}\u{0441}" : "Time";
                                    color: #A1A1AA;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 154px; y: root.settings_display_btn_y; width: 68px; height: root.settings_btn_height;
                                    background: root.time_format == "24" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "24h"; color: root.time_format == "24" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.time_format = "24"; root.set_time_format("24"); } }
                                }
                                Rectangle {
                                    x: parent.width - 80px; y: root.settings_display_btn_y; width: 68px; height: root.settings_btn_height;
                                    background: root.time_format == "12" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "12h"; color: root.time_format == "12" ? #000000 : #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.time_format = "12"; root.set_time_format("12"); } }
                                }
                            }

                            Rectangle {
                                y: root.settings_display_row_step * 2;
                                width: parent.width; height: root.settings_display_row_h;
                                background: #111118;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 12px;
                                Text {
                                    x: 12px; y: 0px; width: 220px; height: parent.height;
                                    text: root.is_ua ? "\u{0414}\u{0430}\u{0442}\u{0430}" : "Date";
                                    color: #A1A1AA;
                                    font-size: 16px;
                                    vertical-alignment: center;
                                }
                                Rectangle {
                                    x: parent.width - 216px; y: root.settings_display_btn_y; width: 64px; height: root.settings_btn_height;
                                    background: root.date_format == "DMY" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "DD.MM"; color: root.date_format == "DMY" ? #000000 : #FFFFFF; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "DMY"; root.set_date_format("DMY"); } }
                                }
                                Rectangle {
                                    x: parent.width - 146px; y: root.settings_display_btn_y; width: 64px; height: root.settings_btn_height;
                                    background: root.date_format == "MDY" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "MM/DD"; color: root.date_format == "MDY" ? #000000 : #FFFFFF; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "MDY"; root.set_date_format("MDY"); } }
                                }
                                Rectangle {
                                    x: parent.width - 76px; y: root.settings_display_btn_y; width: 64px; height: root.settings_btn_height;
                                    background: root.date_format == "YMD" ? #10B981 : #27272A;
                                    border-radius: root.settings_btn_radius;
                                    Text { text: "YYYY"; color: root.date_format == "YMD" ? #000000 : #FFFFFF; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; }
                                    TouchArea { width: parent.width; height: parent.height; clicked => { root.date_format = "YMD"; root.set_date_format("YMD"); } }
                                }
                            }
                        }

                        if (root.settings_page == "fan") : Rectangle {
                        width: root.settings_content_width; height: root.settings_fan_card_h;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 12px;


                        Text {
                            x: root.settings_inner_pad; y: root.settings_label_y;
                            text: root.fan_manual
                                ? (root.is_ua ? "\u{0420}\u{0443}\u{0447}\u{043d}\u{0438}\u{0439}\u{0020}\u{0440}\u{0435}\u{0436}\u{0438}\u{043c}" : "Manual mode")
                                : (root.is_ua ? "\u{0412}\u{0438}\u{043c}\u{043a}\u{043d}\u{0435}\u{043d}\u{043e}" : "Off");
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px;
                        }

                        Rectangle {
                            x: parent.width - root.settings_inner_pad - root.settings_fan_toggle_w;
                            y: root.settings_label_y;
                            width: root.settings_fan_toggle_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #10B981 : #27272A;
                            border-radius: root.settings_btn_radius;
                            Text {
                                text: root.fan_manual ? (root.is_ua ? "\u{0412}\u{041a}\u{041b}" : "ON") : (root.is_ua ? "\u{0412}\u{0418}\u{041a}\u{041b}" : "OFF");
                                color: root.fan_manual ? #000000 : #FFFFFF;
                                font-family: "PT Sans";
                                font-size: root.settings_btn_text_size;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let new_manual = !root.fan_manual;
                                    root.fan_manual = new_manual;
                                    if (new_manual && root.fan_power == 0) { root.fan_power = 100; }
                                    if (!new_manual) { root.fan_power = 0; }
                                    root.fan_manual_changed(new_manual);
                                    root.fan_power_changed(root.fan_power);
                                }
                            }
                        }

                        Rectangle { // -
                            x: parent.width - root.settings_inner_pad - (root.settings_fan_minus_w + root.settings_fan_value_w + root.settings_fan_plus_w);
                            y: root.settings_fan_controls_y;
                            width: root.settings_fan_minus_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: "−"; color: #FFFFFF; font-family: "PT Sans"; font-size: 26px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        root.fan_power = max(root.fan_power - 10, 0);
                                        root.fan_power_changed(root.fan_power);
                                    }
                                }
                            }
                        }

                        Rectangle { // % (tap for keypad)
                            x: parent.width - root.settings_inner_pad - (root.settings_fan_value_w + root.settings_fan_plus_w);
                            y: root.settings_fan_controls_y;
                            width: root.settings_fan_value_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.fan_power + "%"; color: #FFFFFF; font-family: "PT Sans"; font-size: 18px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        if (!(root.kb_visible && root.kb_field == "fan" && root.kb_step_index == -1)) {
                                            root.kb_open("fan", -1, root.fan_power + "");
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle { // +
                            x: parent.width - root.settings_inner_pad - root.settings_fan_plus_w;
                            y: root.settings_fan_controls_y;
                            width: root.settings_fan_plus_w; height: root.settings_btn_height;
                            background: root.fan_manual ? #27272A : #18181B;
                            border-radius: root.settings_btn_radius;
                            Text { text: "+"; color: #FFFFFF; font-family: "PT Sans"; font-size: 24px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    if (root.fan_manual) {
                                        root.fan_power = min(root.fan_power + 10, 100);
                                        root.fan_power_changed(root.fan_power);
                                    }
                                }
                            }
                        }
                    }

                        if (root.settings_page == "autotune") : ScrollView {
                            x: 0px; y: 0px;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: root.settings_display_row_step * 4 + root.settings_autotune_action_h + 8px;
                            viewport-x: 0px;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                            mouse-drag-pan-enabled: true;

                            Rectangle {
                                x: 0px; y: 0px;
                                width: root.settings_content_width;
                                height: root.settings_display_row_step * 4 + root.settings_autotune_action_h + 8px;
                                background: #00000000;

                                Rectangle {
                                    y: 0px;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: 220px; height: parent.height;
                                        text: root.is_ua ? "Зміщення термопари" : "Thermocouple offset";
                                        color: #A1A1AA;
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - 156px; y: root.settings_display_btn_y; width: 144px; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.thermocouple_offset + root.temp_unit_label; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("thermocouple_offset", -1, root.thermocouple_offset + ""); } }
                                    }
                                }

                                Rectangle {
                                    y: root.settings_display_row_step;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: 220px; height: parent.height;
                                        text: root.is_ua ? "Потужність печі" : "Kiln power";
                                        color: #A1A1AA;
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - 156px; y: root.settings_display_btn_y; width: 144px; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.kiln_wattage + " W"; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("kiln_wattage", -1, root.kiln_wattage + ""); } }
                                    }
                                }

                                Rectangle {
                                    y: root.settings_display_row_step * 2;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: 220px; height: parent.height;
                                        text: root.is_ua ? "Макс. температура" : "Max temperature";
                                        color: #A1A1AA;
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - 156px; y: root.settings_display_btn_y; width: 144px; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.schedule_target_max_c + root.temp_unit_label; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.kb_open("max_temp", -1, root.schedule_target_max_c + ""); } }
                                    }
                                }

                                Rectangle {
                                    y: root.settings_display_row_step * 3;
                                    width: parent.width; height: root.settings_display_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    Text {
                                        x: 12px; y: 0px; width: 220px; height: parent.height;
                                        text: root.is_ua ? "Ціль автоналаштування" : "Autotune target";
                                        color: #A1A1AA;
                                        font-size: 16px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        x: parent.width - 156px; y: root.settings_display_btn_y; width: 144px; height: root.settings_btn_height;
                                        background: #27272A;
                                        border-radius: root.settings_btn_radius;
                                        Text { text: root.autotune_target_c + root.temp_unit_label; color: #FFFFFF; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "autotune" && root.kb_step_index == -1)) {
                                                    root.kb_open("autotune", -1, root.autotune_target_c + "");
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    x: root.settings_inner_pad;
                                    y: root.settings_display_row_step * 4;
                                    width: root.settings_content_width - root.settings_inner_pad * 2;
                                    height: root.settings_autotune_action_h;
                                    background: root.status_label == "TUNING" ? #7F1D1D : (root.fault_active ? #18181B : #14532D);
                                    border-radius: root.settings_btn_radius;
                                    Text {
                                        text: root.status_label == "TUNING"
                                            ? (root.is_ua ? "Зупинити автоналаштування" : "Stop autotune")
                                            : (root.is_ua ? "Запустити автоналаштування" : "Start autotune");
                                        color: root.status_label == "TUNING" ? #FFFFFF : (root.fault_active ? #71717A : #FFFFFF);
                                        font-family: "PT Sans";
                                        font-size: 14px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    TouchArea {
                                        width: parent.width; height: parent.height;
                                        clicked => {
                                            if (root.status_label == "TUNING") {
                                                root.autotune_stop();
                                            } else if (!root.fault_active) {
                                                root.autotune_start(root.autotune_target_c);
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if (root.settings_page == "touch") : UiButton {
                        x: root.settings_inner_pad;
                        width: root.settings_content_width - root.settings_inner_pad * 2; height: root.settings_action_btn_h;
                        background: #27272A;
                        radius: root.settings_action_btn_radius;
                        label: root.is_ua ? "Калібрування тач" : "Touch Calibration";
                        text_size: root.settings_btn_text_size;
                        tapped => { root.show_touch_confirm = true; }
                        }

                        if (root.settings_page == "history") : ScrollView {
                            x: 0px; y: 0px;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: (root.history_items.length + 1) * root.settings_list_step;
                            viewport-x: 0px;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            mouse-drag-pan-enabled: true;

                            VerticalBox {
                                width: root.settings_content_width;
                                spacing: root.settings_grid_gap;
                                for item[i] in root.history_items : Rectangle {
                                    width: root.settings_content_width; height: root.settings_list_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    clip: true;

                                    Text {
                                        x: 12px; y: 10px; width: parent.width - 220px; height: 24px;
                                        text: item.title;
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 16px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    if (item.status_code != "") : Rectangle {
                                        x: parent.width - 258px; y: 8px; width: 104px; height: 28px;
                                        background: item.status_code == "COMPLETE" ? #14532D
                                            : item.status_code == "STOPPED" ? #3F3F46
                                            : #7F1D1D;
                                        border-radius: 10px;

                                        Text {
                                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                                            text: item.status;
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 13px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }

                                    if (item.id != "") : UiButton {
                                        x: parent.width - 142px; y: 8px; width: 88px; height: 28px;
                                        background: #1F2937;
                                        radius: 10px;
                                        label: root.is_ua ? "Деталі" : "Details";
                                        text_size: 12px;
                                        tapped => { root.open_history_detail(i); }
                                    }

                                    if (item.id != "") : Rectangle {
                                        x: parent.width - 46px; y: 8px;
                                        width: 28px; height: 28px;
                                        background: #1F2937;
                                        border-radius: 14px;
                                        Rectangle { x: 7px; y: 18px; width: 14px; height: 1px; background: #FFFFFF; border-radius: 1px; }
                                        Rectangle { x: 7px; y: 14px; width: 3px; height: 3px; background: #FFFFFF; border-radius: 2px; }
                                        Rectangle { x: 12px; y: 11px; width: 3px; height: 3px; background: #FFFFFF; border-radius: 2px; }
                                        Rectangle { x: 17px; y: 8px; width: 3px; height: 3px; background: #FFFFFF; border-radius: 2px; }
                                        Rectangle { x: 8px; y: 13px; width: 5px; height: 1px; background: #FFFFFF; border-radius: 1px; }
                                        Rectangle { x: 13px; y: 10px; width: 5px; height: 1px; background: #FFFFFF; border-radius: 1px; }
                                        TouchArea { width: parent.width; height: parent.height; clicked => { root.open_history_graph(i); } }
                                    }

                                    Text {
                                        x: 12px; y: 38px; width: parent.width - 24px; height: 18px;
                                        text: item.subtitle;
                                        color: #A1A1AA;
                                        font-family: "PT Sans";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }

                        if (root.settings_page == "fault_logs") : ScrollView {
                            x: 0px; y: 0px;
                            width: root.settings_content_width; height: root.settings_content_height;
                            viewport-width: self.width;
                            viewport-height: (root.fault_log_items.length + 1) * root.settings_list_step;
                            viewport-x: 0px;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            mouse-drag-pan-enabled: true;

                            VerticalBox {
                                width: root.settings_content_width;
                                spacing: root.settings_grid_gap;
                                for item[i] in root.fault_log_items : Rectangle {
                                    width: root.settings_content_width; height: root.settings_list_row_h;
                                    background: #111118;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 12px;
                                    clip: true;

                                    Text {
                                        x: 12px; y: 10px; width: parent.width - 120px; height: 24px;
                                        text: item.title;
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 15px;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }

                                    if (item.status != "") : Rectangle {
                                        x: parent.width - 96px; y: 10px; width: 84px; height: 24px;
                                        background: item.status == "OK" ? #14532D : #7F1D1D;
                                        border-radius: 8px;

                                        Text {
                                            x: 0px; y: 0px; width: parent.width; height: parent.height;
                                            text: item.status;
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 12px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            overflow: elide;
                                        }
                                    }

                                    Text {
                                        x: 12px; y: 38px; width: parent.width - 24px; height: 18px;
                                        text: item.subtitle;
                                        color: #A1A1AA;
                                        font-family: "PT Sans";
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }

                        if (root.settings_page == "wifi") : Rectangle {
                            x: 0px; y: 0px;
                            width: root.settings_content_width; height: 146px;
                            background: #0F0F0F;
                            border-color: #27272A;
                            border-width: 1px;
                            border-radius: 12px;

                            Text {
                                x: 12px; y: 10px;
                                text: "Wi‑Fi";
                                color: #FFFFFF;
                                font-family: "PT Sans";
                                font-size: 16px;
                                font-weight: 700;
                            }

                            Rectangle {
                                x: parent.width - root.settings_inner_pad - 120px; y: 8px; width: 120px; height: 24px;
                                background: root.wifi_ok ? #073B2A : #2A2A2F;
                                border-radius: 8px;
                                Text {
                                    text: root.wifi_ok ? "Connected" : "Disconnected";
                                    color: root.wifi_ok ? #10B981 : #A1A1AA;
                                    font-family: "PT Sans";
                                    font-size: 13px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            Text {
                                x: 12px; y: 38px; width: parent.width - 24px;
                                text: root.wifi_selected_ssid == ""
                                    ? (root.is_ua ? "Оберіть мережу зі списку" : "Pick a network from list")
                                    : root.wifi_selected_ssid;
                                color: #A1A1AA;
                                font-family: "PT Sans";
                                font-size: 13px;
                                overflow: elide;
                            }

                            Rectangle {
                                x: root.settings_inner_pad; y: 58px; width: parent.width - root.settings_inner_pad * 2 - 134px; height: 36px;
                                background: #18181B;
                                border-color: #27272A;
                                border-width: 1px;
                                border-radius: 9px;
                                Text {
                                    x: 10px; y: 9px;
                                    width: parent.width - 20px;
                                    text: root.wifi_server_url;
                                    color: #60A5FA;
                                    font-family: "PT Sans";
                                    font-size: 12px;
                                    overflow: elide;
                                }
                            }

                            UiButton {
                                x: parent.width - root.settings_inner_pad - 126px; y: 56px; width: 126px; height: 40px;
                                background: #1F2937;
                                radius: 9px;
                                label: "QR";
                                bold: true;
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_qr_toggle(); }
                            }

                            UiButton {
                                x: root.settings_inner_pad; y: 104px; width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                                background: #27272A;
                                radius: 9px;
                                label: root.wifi_ok ? (root.is_ua ? "Змінити мережу" : "Change network")
                                                  : (root.is_ua ? "Пошук мережі" : "Search networks");
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_open_picker(); }
                            }

                            UiButton {
                                x: root.settings_inner_pad + root.settings_two_col_btn_w + root.settings_grid_gap; y: 104px; width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                                background: #7F1D1D;
                                radius: 9px;
                                label: root.is_ua ? "Відключити Wi‑Fi" : "Disconnect Wi‑Fi";
                                text_size: root.settings_btn_text_size;
                                tapped => { root.wifi_disconnect(); }
                            }
                        }


                    }
                }

                if (root.settings_page == "fault") : Rectangle {
                    x: root.settings_panel_x; y: root.settings_panel_y;
                    width: root.settings_panel_w; height: root.settings_display_row_h * 2 + root.settings_vertical_gap;
                    background: #00000000;

                    Rectangle {
                        y: 0px;
                        width: parent.width; height: root.settings_display_row_h;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 12px;

                        Text {
                            x: 12px; y: 0px; width: parent.width - 24px; height: parent.height;
                            text: root.fault_active
                                ? (root.fault_reason == "" ? (root.is_ua ? "\u{041f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043a}\u{0430}\u{0020}\u{0431}\u{0435}\u{0437}\u{0020}\u{043e}\u{043f}\u{0438}\u{0441}\u{0443}" : "Fault without details") : root.fault_reason)
                                : (root.is_ua ? "\u{041d}\u{0435}\u{043c}\u{0430}\u{0454}\u{0020}\u{0430}\u{043a}\u{0442}\u{0438}\u{0432}\u{043d}\u{043e}\u{0457}\u{0020}\u{043f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043a}\u{0438}" : "No active fault");
                            color: root.fault_active ? #FCA5A5 : #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px;
                            overflow: elide;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        y: root.settings_display_row_step;
                        width: parent.width; height: root.settings_display_row_h;
                        background: #00000000;

                        UiButton {
                            x: root.settings_inner_pad; y: root.settings_display_btn_y;
                            width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                            background: root.fault_active ? #7F1D1D : #18181B;
                            foreground: root.fault_active ? #FFFFFF : #71717A;
                            radius: root.settings_action_btn_radius;
                            label: root.is_ua ? "\u{0421}\u{043a}\u{0438}\u{043d}\u{0443}\u{0442}\u{0438}\u{0020}\u{043f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043a}\u{0443}" : "Clear Fault";
                            text_size: root.settings_btn_text_size;
                            tapped => {
                                if (root.fault_active) {
                                    root.clear_fault();
                                }
                            }
                        }

                        UiButton {
                            x: root.settings_inner_pad + root.settings_two_col_btn_w + root.settings_grid_gap; y: root.settings_display_btn_y;
                            width: root.settings_two_col_btn_w; height: root.settings_btn_height;
                            background: #1F2937;
                            radius: root.settings_action_btn_radius;
                            label: root.is_ua ? "\u{041b}\u{043e}\u{0433}\u{0438}\u{0020}\u{043f}\u{043e}\u{043c}\u{0438}\u{043b}\u{043e}\u{043a}" : "Fault Logs";
                            text_size: root.settings_btn_text_size;
                            tapped => { root.open_fault_logs(); }
                        }
                    }
                }

                // (scrollbar hidden)
                if (root.settings_page == "display_hw") : Rectangle {
                    x: root.settings_panel_x; y: root.settings_panel_y; width: root.settings_panel_w;
                    height: root.settings_display_hw_h;
                    background: #00000000;

                    Rectangle {
                        y: 0px;
                        width: root.settings_panel_w; height: root.settings_primary_card_h;
                        background: #111118;
                        border-color: #27272A;
                        border-width: 1px;
                        border-radius: 12px;
                        Text { x: root.settings_inner_pad; y: root.settings_label_y; text: root.is_ua ? "Яскравість" : "Brightness"; color: #A1A1AA; font-size: 13px; }
                        Rectangle {
                            x: root.settings_inner_pad; y: root.settings_display_hw_controls_y; width: root.settings_display_hw_step_w; height: root.settings_btn_height;
                            background: #27272A;
                            border-radius: root.settings_btn_radius;
                            Text { text: "-"; color: #FFFFFF; font-family: "PT Sans"; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let v = max(root.display_brightness - 10, 50);
                                    root.display_brightness = v;
                                    root.display_brightness_changed(v);
                                }
                            }
                        }
                        Rectangle {
                            x: root.settings_inner_pad + root.settings_display_hw_step_w + root.settings_grid_gap;
                            y: root.settings_display_hw_controls_y;
                            width: root.settings_display_hw_value_w; height: root.settings_btn_height;
                            background: #1F2937;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.display_brightness + "%"; color: #FFFFFF; font-family: "PT Sans"; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                        }
                        Rectangle {
                            x: root.settings_inner_pad + root.settings_display_hw_step_w + root.settings_grid_gap + root.settings_display_hw_value_w + root.settings_grid_gap;
                            y: root.settings_display_hw_controls_y;
                            width: root.settings_display_hw_step_w; height: root.settings_btn_height;
                            background: #27272A;
                            border-radius: root.settings_btn_radius;
                            Text { text: "+"; color: #FFFFFF; font-family: "PT Sans"; font-size: 22px; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    let v = min(root.display_brightness + 10, 100);
                                    root.display_brightness = v;
                                    root.display_brightness_changed(v);
                                }
                            }
                        }
                        Rectangle {
                            x: root.settings_inner_pad + root.settings_display_hw_step_w + root.settings_grid_gap + root.settings_display_hw_value_w + root.settings_grid_gap + root.settings_display_hw_step_w + root.settings_grid_gap;
                            y: root.settings_display_hw_controls_y;
                            width: root.settings_display_hw_max_w; height: root.settings_btn_height;
                            background: #10B981;
                            border-radius: root.settings_btn_radius;
                            Text { text: root.is_ua ? "Макс" : "Max"; color: #000000; font-family: "PT Sans"; font-size: root.settings_btn_text_size; horizontal-alignment: center; vertical-alignment: center; }
                            TouchArea {
                                width: parent.width; height: parent.height;
                                clicked => {
                                    root.display_brightness = 100;
                                    root.display_brightness_changed(100);
                                }
                            }
                        }
                    }

                    UiButton {
                        y: root.settings_secondary_row_y;
                        x: 0px;
                        width: root.settings_panel_w; height: root.settings_display_hw_calib_h;
                        background: #27272A;
                        radius: root.settings_action_btn_radius;
                        label: root.is_ua ? "Калібрування дисплею" : "Display calibration";
                        text_size: root.settings_btn_text_size;
                        tapped => { root.show_touch_confirm = true; }
                    }
                }

                if (root.wifi_qr_visible) : Rectangle {
                    x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                    background: #000000D0;
                    z: 2100;

                    Rectangle {
                        x: 80px; y: 14px; width: 320px; height: 252px;
                        background: #00000000;
                        border-width: 0px;
                        border-radius: 0px;

                        Image {
                            x: 76px; y: 22px; width: 168px; height: 168px;
                            source: root.wifi_qr_image;
                        }
                        Text {
                            x: 16px; y: 196px; width: 288px; height: 24px;
                            text: root.wifi_qr_hint;
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        UiButton {
                            x: 100px; y: 222px; width: 120px; height: 28px;
                            background: #27272A;
                            radius: 10px;
                            label: root.is_ua ? "Закрити" : "Close";
                            text_size: 16px;
                            tapped => { root.wifi_qr_toggle(); }
                        }
                    }
                }

                if (root.wifi_picker_visible) : Rectangle {
                    x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                    background: #000000CC;
                    z: 2000;

                    Rectangle {
                        x: 16px; y: 12px; width: 448px; height: 252px;
                        background: #00000000;
                        border-width: 0px;
                        border-radius: 0px;

                        Text {
                            x: 12px; y: 10px;
                            text: root.is_ua ? "Вибір Wi‑Fi мережі" : "Select Wi‑Fi network";
                            color: #FFFFFF;
                            font-family: "PT Sans";
                            font-size: 16px;
                        }

                        UiButton {
                            x: 398px; y: 8px; width: 38px; height: 28px;
                            background: #27272A;
                            radius: 8px;
                            label: "X";
                            text_size: 16px;
                            tapped => { root.wifi_picker_visible = false; }
                        }

                        if (root.wifi_scan_busy) : Text {
                            x: 12px; y: 44px;
                            text: root.is_ua ? "Пошук мереж..." : "Scanning networks...";
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px;
                        }

                        if (!root.wifi_scan_busy && root.wifi_networks.length == 0) : Text {
                            x: 12px; y: 44px;
                            text: root.is_ua ? "Мереж не знайдено" : "No networks found";
                            color: #A1A1AA;
                            font-family: "PT Sans";
                            font-size: 14px;
                        }

                        if (!root.wifi_scan_busy && root.wifi_networks.length > 0) : ScrollView {
                            x: 8px; y: 40px; width: 432px; height: 204px;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                            mouse-drag-pan-enabled: true;

                            VerticalBox {
                                spacing: 4px;
                                for net in root.wifi_networks : Rectangle {
                                    width: 430px; height: 38px;
                                    background: #18181B;
                                    border-color: #27272A;
                                    border-width: 1px;
                                    border-radius: 8px;

                                    Text {
                                        x: 8px; y: 9px;
                                        text: net.ssid + " (" + net.rssi + " dBm)";
                                        color: #FFFFFF;
                                        font-family: "PT Sans";
                                        font-size: 14px;
                                    }

                                    TouchArea {
                                        width: parent.width; height: parent.height;
                                        clicked => {
                                            root.wifi_selected_ssid = net.ssid;
                                            root.wifi_password = "";
                                            root.kb_open("wifi_pass", -1, "");
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
        }

        // Editor View


        if (root.view == View.Editor) : Rectangle {
                x: 0px; y: 0px; width: 480px; height: root.page_content_h;
                background: root.c_bg;



                Rectangle {
                    x: root.settings_side_gap; y: root.settings_title_y;
                    width: root.settings_editor_content_w;
                    height: root.settings_header_h;


                    background: #000000;



                    border-color: #27272A;



                    border-width: 1px;



                    border-radius: root.settings_btn_radius;



                    property <string> name_display: (root.kb_visible && root.kb_field == "name") ? root.kb_value : root.selected_schedule_name;

                    TextInput { visible: false;
                        x: 6px; y: 0px;
                        width: parent.width - 12px; height: parent.height;



                        text: parent.name_display;



                        color: #FFFFFF;



                        font-family: "PT Sans";



                        font-size: 18px;


                        input-type: InputType.text;



                    }

                    Text {
                        x: 6px; y: 0px;
                        width: parent.width - 12px; height: parent.height;
                        text: parent.name_display;
                        color: #FFFFFF;
                        font-family: "PT Sans";
                        font-size: 18px;
                        font-weight: 700;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                    }

                    if (self.name_display == "") : Text {
                        x: 8px; y: 0px;
                        height: parent.height;
                        text: root.is_ua ? "Назва програми" : "Program Name";



                        color: #71717A;



                        font-family: "PT Sans";



                        font-size: 14px;


                    }

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        clicked => {
                            if (!(root.kb_visible && root.kb_field == "name")) {
                                root.kb_open("name", -1, root.selected_schedule_name);
                            }
                        }
                    }



                }



                Rectangle {
                    x: 480px - root.settings_side_gap - root.settings_nav_btn_w - root.settings_nav_gap - 132px;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: 132px; height: root.settings_nav_btn_h;
                    background: #10B981;
                    border-radius: root.settings_action_btn_radius;



                    Text { text: root.is_ua ? "Зберегти" : "Save"; color: #000000; font-family: "PT Sans"; font-size: 16px; horizontal-alignment: center; vertical-alignment: center; }


                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.editor_save(); } }



                }



                Rectangle {
                    x: 480px - root.settings_side_gap - root.settings_nav_btn_w;
                    y: root.settings_title_y + (root.settings_header_h - root.settings_nav_btn_h) / 2;
                    width: root.settings_nav_btn_w; height: root.settings_nav_btn_h;
                    background: #27272A;
                    border-radius: root.settings_action_btn_radius;



                    Text { text: "X"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.editor_back(); } }



                }



                ScrollView {
                    x: root.settings_side_gap; y: root.settings_content_y;
                    width: root.settings_content_width;
                    height: parent.height - root.settings_content_y - root.settings_side_gap;
                    viewport-width: self.width;
                    viewport-height: root.editor_steps.length == 0
                        ? (root.settings_list_row_h + 44px + root.settings_grid_gap)
                        : (root.editor_steps.length * 92px + 44px + root.editor_steps.length * root.settings_grid_gap);
                    viewport-x: 0px;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    vertical-scrollbar-policy: ScrollBarPolicy.always-off;
                    mouse-drag-pan-enabled: true;
                    VerticalBox {
                        width: root.settings_content_width;
                        spacing: root.settings_grid_gap;
                        if (root.editor_steps.length == 0) : Rectangle {
                            width: 480px - root.settings_side_gap * 4; height: root.settings_list_row_h;



                            background: #000000;



                            border-color: #27272A;



                            border-width: 1px;



                            border-radius: 12px;



                            Text { text: root.is_ua ? "Ще не додано жодного кроку" : "No steps added yet"; color: #A1A1AA; horizontal-alignment: center; vertical-alignment: center; }



                        }



                        for step[i] in root.editor_steps : Rectangle {
                            width: 480px - root.settings_side_gap * 4; height: 92px;


                            background: #0F0F0F;



                            border-color: #27272A;



                            border-width: 1px;



                            border-radius: 10px;



                            property <length> segment_pad_left: 6px;
                            property <length> segment_index_w: 28px;
                            property <length> segment_delete_w: 30px;
                            property <length> segment_right_pad: 8px;
                            property <length> segment_fields_x: segment_pad_left + segment_index_w + 8px;
                            property <length> segment_field_w: (parent.width - segment_fields_x - segment_delete_w - segment_right_pad - root.settings_grid_gap * 2) / 3;

                            Rectangle {
                                x: segment_pad_left;
                                y: (parent.height - segment_index_w) / 2;
                                width: segment_index_w; height: segment_index_w;
                                background: (!root.is_idle && i == root.step_index) ? #10B981 : #27272A;
                                border-radius: segment_index_w / 2;
                                Text { text: (i + 1); color: (!root.is_idle && i == root.step_index) ? #000000 : #A1A1AA; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                            }



                            // Center the labels+values as a single block inside the segment row.
                            HorizontalBox {
                                x: segment_fields_x;
                                spacing: root.settings_grid_gap;



                                VerticalBox {



                                    width: segment_field_w;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? ("Швидк. (" + root.rate_unit_label + ")") : ("Rate (" + root.rate_unit_label + ")"); color: #71717A; font-size: 14px; }


                                    Rectangle {
                                        width: segment_field_w; height: 42px;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px;



                                        border-radius: 8px;


                                        TextInput { visible: false;
                                            x: 6px; y: 4px;


                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.rate + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px;



                                            input-type: InputType.number;



                                            edited => { root.editor_rate_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.rate + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "rate" && root.kb_step_index == i)) {
                                                    root.kb_open("rate", i, step.rate + "");
                                                }
                                            }
                                        }


                                    }



                                }



                                VerticalBox {



                                    width: segment_field_w;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? ("Темп. (" + root.temp_unit_label + ")") : ("Target (" + root.temp_unit_label + ")"); color: #71717A; font-size: 14px; }


                                    Rectangle {
                                        width: segment_field_w; height: 42px;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px;



                                        border-radius: 8px;


                                        TextInput { visible: false;


                                            x: 6px; y: 4px;



                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.target + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px;



                                            input-type: InputType.number;



                                            edited => { root.editor_target_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.target + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "target" && root.kb_step_index == i)) {
                                                    root.kb_open("target", i, step.target + "");
                                                }
                                            }
                                        }


                                    }



                                }



                                VerticalBox {



                                    width: segment_field_w;


                                    spacing: 4px;


                                    Text { text: root.is_ua ? "Витр. (хв)" : "Hold (min)"; color: #71717A; font-size: 14px; }


                                    Rectangle {
                                        width: segment_field_w; height: 42px;


                                        background: #000000;



                                        border-color: #3F3F46;



                                        border-width: 1px;



                                        border-radius: 8px;


                                        TextInput { visible: false;


                                            x: 6px; y: 4px;



                                            width: parent.width - 12px; height: parent.height - 8px;



                                            text: step.hold + "";



                                            color: #FFFFFF;



                                            font-family: "PT Sans";



                                            font-size: 14px;



                                            input-type: InputType.number;



                                            edited => { root.editor_hold_changed(i, self.text); }


                                        }

                                        Text {
                                            width: parent.width; height: parent.height;
                                            text: step.hold + "";
                                            color: #FFFFFF;
                                            font-family: "PT Sans";
                                            font-size: 18px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width; height: parent.height;
                                            clicked => {
                                                if (!(root.kb_visible && root.kb_field == "hold" && root.kb_step_index == i)) {
                                                    root.kb_open("hold", i, step.hold + "");
                                                }
                                            }
                                        }


                                    }



                                }



                            }



                            Rectangle {



                                x: parent.width - segment_delete_w - segment_right_pad;
                                y: 6px;
                                width: segment_delete_w; height: segment_delete_w;


                                background: #27272A;



                                border-radius: 8px;


                                Text { text: "X"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }



                                TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.editor_remove(i); } }



                            }



                        }



                        Rectangle {
                        width: 480px - root.settings_side_gap * 4; height: 44px;



                            background: #0F0F0F;



                            border-color: #27272A;



                            border-width: 1px;



                            border-radius: 10px;



                        Text { text: root.is_ua ? "+ Додати крок" : "+ Add Step"; color: #A1A1AA; font-size: 18px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }



                            TouchArea {



                    width: parent.width; height: parent.height; clicked => { root.editor_add_step(); } }



                        }



                    }
                }



            }



        }


    // Stop modal



    // Full-screen text keyboard (program name)
    if (root.kb_visible && ((root.kb_field == "name" && root.kb_mode == "alpha") || (root.kb_field == "wifi_pass" && root.kb_mode == "alpha"))) : Rectangle {
        x: 0px;
        y: 0px;
        width: 480px;
        height: 320px;
        z: 5000;

        background: #000000;

        property <[string]> ua_r1_uc: ["Й","Ц","У","К","Е","Н","Г","Ш","Щ","З","Х","Ї"];
        property <[string]> ua_r2_uc: ["Ф","І","В","А","П","Р","О","Л","Д","Ж","Є"];
        property <[string]> ua_r3_uc: ["Я","Ч","С","М","И","Т","Ь","Б","Ю","Ґ"];
        property <[string]> ua_r1_lc: ["й","ц","у","к","е","н","г","ш","щ","з","х","ї"];
        property <[string]> ua_r2_lc: ["ф","і","в","а","п","р","о","л","д","ж","є"];
        property <[string]> ua_r3_lc: ["я","ч","с","м","и","т","ь","б","ю","ґ"];

        property <[string]> en_r1_uc: ["Q","W","E","R","T","Y","U","I","O","P"];
        property <[string]> en_r2_uc: ["A","S","D","F","G","H","J","K","L"];
        property <[string]> en_r3_uc: ["Z","X","C","V","B","N","M"];
        property <[string]> en_r1_lc: ["q","w","e","r","t","y","u","i","o","p"];
        property <[string]> en_r2_lc: ["a","s","d","f","g","h","j","k","l"];
        property <[string]> en_r3_lc: ["z","x","c","v","b","n","m"];

        Rectangle {
            x: 0px; y: 0px; width: parent.width; height: 70px;
            background: #111118;
            border-color: #27272A;
            border-width: 1px;

            KbKeyButton { x: 10px; y: 13px; width: 72px; height: 44px; background: #7F1D1D; label: root.is_ua ? "Скас." : "Cancel"; font_size: 14px;
                pressed(v) => { root.kb_key("CANCEL"); }
            }
            KbKeyButton { x: 398px; y: 13px; width: 72px; height: 44px; background: #10B981; text_color: #000000; label: "OK"; font_size: 18px;
                pressed(v) => { root.kb_key("OK"); }
            }

            Rectangle {
                x: 90px; y: 10px; width: 300px; height: 50px;
                background: #0B0B0B;
                border-color: #27272A;
                border-width: 1px;
                border-radius: 10px;
                clip: true;

                Text {
                    x: 10px; y: 6px;
                    text: root.kb_field == "name"
                        ? (root.is_ua ? "Назва програми" : "Program Name")
                        : (root.is_ua ? "Пароль Wi‑Fi" : "Wi‑Fi Password");
                    color: #A1A1AA;
                    font-family: "PT Sans";
                    font-size: 12px;
                }

                Text {
                    x: 10px; y: 22px;
                    width: parent.width - 20px;
                    text: root.kb_value;
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px;
                    font-weight: 700;
                    wrap: no-wrap;
                    vertical-alignment: center;
                }
            }
        }

        KbKeyRow {
            row_y: -78px;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r1_uc : parent.ua_r1_lc)
                : (root.kb_caps ? parent.en_r1_uc : parent.en_r1_lc);
            key_width: root.is_ua ? 38px : 46px;
            key_height: 44px;
            gap: 2px;
            start_x: -238px;
            font_size: 20px;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyRow {
            row_y: -30px;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r2_uc : parent.ua_r2_lc)
                : (root.kb_caps ? parent.en_r2_uc : parent.en_r2_lc);
            key_width: root.is_ua ? 40px : 48px;
            key_height: 44px;
            gap: 2px;
            start_x: root.is_ua ? -230px : -222px;
            font_size: 20px;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyRow {
            row_y: 18px;
            keys: root.is_ua
                ? (root.kb_caps ? parent.ua_r3_uc : parent.ua_r3_lc)
                : (root.kb_caps ? parent.en_r3_uc : parent.en_r3_lc);
            key_width: root.is_ua ? 46px : 66px;
            key_height: 44px;
            gap: 2px;
            start_x: -238px;
            font_size: 20px;
            key_pressed(v) => { root.kb_key(v); }
        }

        KbKeyButton { x: 10px; y: 238px; width: 60px; height: 60px; background: #3F3F46; label: "123"; font_size: 16px;
            pressed(v) => { root.kb_mode = "num"; }
        }
        KbKeyButton { x: 72px; y: 238px; width: 50px; height: 60px; background: #3F3F46; label: root.is_ua ? "UA" : "EN"; font_size: 14px;
            pressed(v) => { root.is_ua = !root.is_ua; }
        }
        KbKeyButton { x: 124px; y: 238px; width: 50px; height: 60px; background: root.kb_caps ? #10B981 : #3F3F46; label: "⇧"; font_size: 20px;
            pressed(v) => { root.kb_caps = !root.kb_caps; }
        }
        KbKeyButton { x: 176px; y: 238px; width: 134px; height: 60px; background: #27272A; label: root.is_ua ? "Пробіл" : "Space"; font_size: 18px;
            pressed(v) => { root.kb_key("SPACE"); }
        }
        KbKeyButton { x: 318px; y: 238px; width: 72px; height: 60px; background: #3F3F46; label: "←"; font_size: 22px;
            pressed(v) => { root.kb_key("BS"); }
        }
        KbKeyButton { x: 398px; y: 238px; width: 72px; height: 60px; background: #3F3F46; label: root.is_ua ? "Очист." : "Clear"; font_size: 14px;
            pressed(v) => { root.kb_key("CLR"); }
        }
    }

    // Bottom numeric keyboard overlay (Editor)
    if (root.kb_visible && ((root.kb_field == "name" && (root.kb_mode == "num" || root.kb_mode == "sym")) || (root.kb_field == "wifi_pass" && (root.kb_mode == "num" || root.kb_mode == "sym")) || (root.kb_field != "name" && root.kb_field != "wifi_pass"))) : Rectangle {
        x: 0px;
        y: 0px;
        width: 480px;
        height: 320px;
        z: 5000;

        background: #000000;

        Text {
            x: 12px; y: 14px;
            text: root.kb_field == "rate"
                ? (root.is_ua ? "Швидкість" : "Rate")
                : root.kb_field == "target"
                    ? (root.is_ua ? "Температура" : "Target")
                    : root.kb_field == "hold"
                        ? (root.is_ua ? "Витримка" : "Hold")
                        : root.kb_field == "fan"
                            ? (root.is_ua ? "Вентилятор %" : "Fan %")
                            : root.kb_field == "autotune"
                                ? (root.is_ua ? "Автоналаштування" : "Autotune")
                                : root.kb_field == "run_rate"
                                    ? (root.is_ua ? "Нова швидкість" : "New rate")
                                    : root.kb_field == "run_temp"
                                        ? (root.is_ua ? ("Додати температуру (" + root.temp_unit_label + ")") : ("Add temperature (" + root.temp_unit_label + ")"))
                                        : root.kb_field == "run_time"
                                            ? (root.is_ua ? "Додати час" : "Add time")
                                : root.kb_field == "name"
                                    ? (root.is_ua ? "Назва програми" : "Program name")
                                    : root.kb_field == "wifi_pass"
                                        ? (root.is_ua ? "Пароль Wi‑Fi" : "Wi-Fi password")
                                        : "";
            color: #A1A1AA;
            font-family: "PT Sans";
                        font-size: 14px;
                        vertical-alignment: center;
        }

        Text {
            x: 12px; y: 38px;
            text: root.kb_value;
            color: #FFFFFF;
            font-family: "PT Sans";
            font-size: 30px;
            font-weight: 700;
        }

        if (root.kb_field == "wifi_pass" || root.kb_field == "name") : KbKeyButton { x: 388px; y: 8px; width: 80px; height: 32px; background: #27272A; label: "ABC"; font_size: 12px;
            pressed(v) => { root.kb_mode = "alpha"; }
        }
        if (root.kb_field == "wifi_pass" || root.kb_field == "name") : KbKeyButton { x: 300px; y: 8px; width: 80px; height: 32px; background: #27272A; label: root.kb_mode == "sym" ? "123" : "SYM"; font_size: 12px;
            pressed(v) => { root.kb_mode = root.kb_mode == "sym" ? "num" : "sym"; }
        }

        property <length> kx: 25px;
    property <length> ky: 76px;
        property <length> kw: 140px;
        property <length> kh: 42px;
        property <length> kg: 10px;

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "!" : "1"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "!" : "1"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "@" : "2"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "@" : "2"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 0 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "#" : "3"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "#" : "3"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "$" : "4"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "$" : "4"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "%" : "5"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "%" : "5"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 1 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "&" : "6"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "&" : "6"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "*" : "7"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "*" : "7"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "-" : "8"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "-" : "8"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 2 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "_" : "9"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "_" : "9"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + 6px); width: parent.kw; height: parent.kh; background: #3F3F46; label: root.is_ua ? "Очист." : "Clear"; font_size: 14px; pressed(v) => { root.kb_key("CLR"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + 6px); width: parent.kw; height: parent.kh; label: root.kb_mode == "sym" ? "." : "0"; font_size: 22px; pressed(v) => { root.kb_key(root.kb_mode == "sym" ? "." : "0"); } }
        KbKeyButton { x: parent.kx + 2 * (parent.kw + parent.kg); y: parent.ky + 3 * (parent.kh + 6px); width: parent.kw; height: parent.kh; background: #3F3F46; label: "←"; font_size: 22px; pressed(v) => { root.kb_key("BS"); } }

        KbKeyButton { x: parent.kx + 0 * (parent.kw + parent.kg); y: parent.ky + 4 * (parent.kh + 6px); width: parent.kw; height: parent.kh; background: #7F1D1D; label: root.is_ua ? "Скас." : "Cancel"; font_size: 14px; pressed(v) => { root.kb_key("CANCEL"); } }
        KbKeyButton { x: parent.kx + 1 * (parent.kw + parent.kg); y: parent.ky + 4 * (parent.kh + 6px); width: parent.kw + parent.kg + parent.kw; height: parent.kh; background: #10B981; text_color: #000000; label: "OK"; font_size: 20px; pressed(v) => { root.kb_key("OK"); } }
    }

    if (root.show_touch_confirm) : Rectangle {
        x: 0px; y: 0px; width: 480px; height: 320px;
        background: #000000B3;
        z: 5090;
        Rectangle {
            x: 60px; y: 78px; width: 360px; height: 164px;
            background: #0B0B0B;
            border-color: #3F3F46;
            border-width: 1px;
            border-radius: 16px;
            Text {
                x: 20px; y: 20px; width: parent.width - 40px; height: 48px;
                text: root.is_ua ? "Почати калібрування екрана?" : "Start screen calibration?";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 20px;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: word-wrap;
            }
            Text {
                x: 20px; y: 68px; width: parent.width - 40px; height: 32px;
                text: root.is_ua ? "Після підтвердження відкриється режим калібрування." : "Calibration mode will open after confirmation.";
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
                wrap: word-wrap;
            }
            Rectangle {
                x: 24px; y: 112px; width: 150px; height: 40px;
                background: #27272A; border-radius: 10px;
                Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.show_touch_confirm = false; } }
            }
            Rectangle {
                x: 186px; y: 112px; width: 150px; height: 40px;
                background: #10B981; border-radius: 10px;
                Text { text: root.is_ua ? "Почати" : "Start"; color: #000000; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea {
                    width: parent.width; height: parent.height;
                    clicked => {
                        root.show_touch_confirm = false;
                        root.view = View.Calibration;
                        root.start_touch_calibration();
                    }
                }
            }
        }
    }

    if (root.delete_confirm_visible) : Rectangle {
        x: 0px; y: 0px; width: 480px; height: 320px;
        background: #000000B3;
        z: 5100;
        Rectangle {
            x: 60px; y: 70px; width: 360px; height: 180px;
            background: #0B0B0B;
            border-color: #3F3F46;
            border-width: 1px;
            border-radius: 16px;
            Text {
                x: 0px; y: 22px; width: parent.width;
                text: root.is_ua ? "Видалити програму?" : "Delete program?";
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 20px;
                horizontal-alignment: center;
            }
            Text {
                x: 20px; y: 60px; width: parent.width - 40px;
                text: root.is_ua ? "Цю дію неможливо скасувати." : "This action cannot be undone.";
                color: #A1A1AA;
                font-size: 12px;
                horizontal-alignment: center;
            }
            Rectangle {
                x: 24px; y: 120px; width: 150px; height: 44px;
                background: #27272A; border-radius: 10px;
                Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea { width: parent.width; height: parent.height; clicked => { root.delete_confirm_visible = false; } }
            }
            Rectangle {
                x: 186px; y: 120px; width: 150px; height: 44px;
                background: #7F1D1D; border-radius: 10px;
                Text { text: root.is_ua ? "Видалити" : "Delete"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                TouchArea {
                    width: parent.width; height: parent.height;
                    clicked => {
                        if (root.delete_confirm_index >= 0) { root.delete_schedule(root.delete_confirm_index); }
                        root.delete_confirm_visible = false;
                    }
                }
            }
        }
    }

    if (root.show_skip_confirm) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #000000B3;
            z: 5100;
            Rectangle {
                x: 72px; y: 72px; width: 336px; height: 168px;
                background: #0B0B0B;
                border-color: #3F3F46;
                border-width: 1px;
                border-radius: 16px;
                Text {
                    x: 0px; y: 24px; width: parent.width;
                    text: root.is_ua ? "Пропустити крок?" : "Skip step?";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px;
                    horizontal-alignment: center;
                }
                Rectangle {
                    x: 18px; y: 104px; width: 140px; height: 44px;
                    background: #27272A; border-radius: 10px;
                    Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_cancel(); } }
                }
                Rectangle {
                    x: 178px; y: 104px; width: 140px; height: 44px;
                    background: root.c_danger; border-radius: 10px;
                    Text { text: root.is_ua ? "Підтвердити" : "Confirm"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.skip_confirm(); } }
                }
            }
    }

    if (root.show_running_edit_confirm) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #000000B3;
            z: 5100;
            Rectangle {
                x: 58px; y: 54px; width: 364px; height: 212px;
                background: #0B0B0B;
                border-color: #3F3F46;
                border-width: 1px;
                border-radius: 16px;
                Text {
                    x: 0px; y: 24px; width: parent.width;
                    text: root.is_ua ? "Застосувати зміни?" : "Apply changes?";
                    color: #FFFFFF;
                    font-family: "PT Sans";
                    font-size: 20px;
                    horizontal-alignment: center;
                }
                VerticalBox {
                    x: 18px; y: 58px; width: parent.width - 36px;
                    spacing: 4px;
                    alignment: start;
                    Text {
                        text: root.is_ua
                            ? ("Швидкість: " + root.running_edit_rate + " " + root.rate_unit_label_min)
                            : ("Rate: " + root.running_edit_rate + " " + root.rate_unit_label_min);
                        color: #A1A1AA;
                        font-size: 12px;
                        horizontal-alignment: left;
                    }
                    if (root.running_edit_add_temp != 0) : Text {
                        text: root.is_ua
                            ? ("Додати температуру: " + root.running_edit_add_temp + root.temp_unit_label)
                            : ("Add temperature: " + root.running_edit_add_temp + root.temp_unit_label);
                        color: #A1A1AA;
                        font-size: 12px;
                        horizontal-alignment: left;
                    }
                    if (root.running_edit_add_time != 0) : Text {
                        text: root.is_ua
                            ? ("Додати час: " + root.running_edit_add_time + " хв")
                            : ("Add time: " + root.running_edit_add_time + " min");
                        color: #A1A1AA;
                        font-size: 12px;
                        horizontal-alignment: left;
                    }
                }
                Rectangle {
                    x: 22px; y: 156px; width: 152px; height: 44px;
                    background: #27272A; border-radius: 10px;
                    Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_cancel(); } }
                }
                Rectangle {
                    x: 190px; y: 156px; width: 152px; height: 44px;
                    background: #10B981; border-radius: 10px;
                    Text { text: root.is_ua ? "Зберегти" : "Save"; color: #000000; horizontal-alignment: center; vertical-alignment: center; }
                    TouchArea { width: parent.width; height: parent.height; clicked => { root.running_edit_confirm(); } }
                }
            }
    }

    if (root.standby_visible && !root.boot_splash_visible) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #05070B;
            z: 5150;

            Rectangle {
                x: 0px; y: 12px; width: 480px; height: 52px;
                background: #00000000;
                Text {
                    x: 0px; y: 1px; width: parent.width; height: 50px;
                    text: "KILN PRO";
                    color: Theme.color_accent;
                    opacity: 0.28;
                    font-family: "PT Sans";
                    font-size: 38px;
                    font-weight: 700;
                    letter-spacing: 2.0px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Text {
                    x: 0px; y: 0px; width: parent.width; height: 50px;
                    text: "KILN PRO";
                    color: Theme.color_text;
                    font-family: "PT Sans";
                    font-size: 36px;
                    font-weight: 700;
                    letter-spacing: 2.0px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 0px; y: 84px; width: 480px; height: 114px;
                text: root.temp_label + root.temp_unit_label;
                color: #FFFFFF;
                font-family: "PT Sans";
                font-size: 104px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 0px; y: 204px; width: 480px; height: 28px;
                text: root.is_ua
                    ? ("Ціль: " + (root.display_target_value > 0 ? (root.display_target_value + root.temp_unit_label) : "--"))
                    : ("Target: " + (root.display_target_value > 0 ? (root.display_target_value + root.temp_unit_label) : "--"));
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 22px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 0px; y: 236px; width: 480px; height: 24px;
                text: root.pzem_phase_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 18px; y: 278px; width: 146px; height: 24px;
                text: root.pzem_power_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            Text {
                x: 168px; y: 278px; width: 144px; height: 24px;
                text: root.pzem_current_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Text {
                x: 318px; y: 278px; width: 146px; height: 24px;
                text: root.pzem_voltage_label;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            Rectangle {
                x: root.is_ua
                    ? (root.status_label == "IDLE" ? 176px
                       : root.status_label == "COOL" ? 176px
                       : root.status_label == "COMPLETE" ? 180px
                       : root.status_label == "ERROR" ? 186px
                       : 188px)
                    : (root.status_label == "ERROR" ? 190px : 194px);
                y: 272px;
                width: root.is_ua
                    ? (root.status_label == "IDLE" ? 128px
                       : root.status_label == "COOL" ? 128px
                       : root.status_label == "COMPLETE" ? 120px
                       : root.status_label == "ERROR" ? 108px
                       : 104px)
                    : (root.status_label == "ERROR" ? 98px : 90px);
                height: 34px;
                background: root.status_bg;
                border-color: root.status_fg;
                border-width: root.status_label == "ERROR" ? 2px : 1px;
                border-radius: 17px;

                Text {
                    text: root.status_text;
                    color: root.status_fg;
                    font-family: "PT Sans";
                    font-size: root.is_ua ? 14px : 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 314px; y: 278px; width: 148px; height: 28px;
                text: root.time_remaining;
                color: #A1A1AA;
                font-family: "PT Sans";
                font-size: 20px;
                font-weight: 700;
                horizontal-alignment: right;
                vertical-alignment: center;
            }

            TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => { root.standby_visible = false; }
            }
    }

    if (root.boot_splash_visible) : Rectangle {
            x: 0px; y: 0px; width: 480px; height: 320px;
            background: #05070B;
            z: 5200;

            Rectangle {
                x: 40px; y: 96px; width: 400px; height: 128px;
                background: #00000000;
                Text {
                    x: 0px; y: 10px; width: parent.width; height: 96px;
                    text: "KILN PRO";
                    color: Theme.color_accent;
                    opacity: 0.30;
                    font-family: "PT Sans";
                    font-size: 68px;
                    font-weight: 700;
                    letter-spacing: 2.2px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                Text {
                    x: 0px; y: 8px; width: parent.width; height: 96px;
                    text: "KILN PRO";
                    color: Theme.color_text;
                    font-family: "PT Sans";
                    font-size: 64px;
                    font-weight: 700;
                    letter-spacing: 2.2px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
    }
    if (root.show_stop_confirm) : Rectangle {


            x: 0px; y: 0px; width: 480px; height: 320px;



            background: #000000B3;



            Rectangle {



                x: 60px; y: 50px; width: 360px; height: 220px;



                background: #0B0B0B;



                border-color: #3F3F46;



                border-width: 1px;



                border-radius: 18px;



                Rectangle {



                    x: 148px; y: 16px; width: 64px; height: 64px;



                    background: #7F1D1D;



                    border-radius: 32px;



                    Text { text: "!"; color: #EF4444; font-size: 28px; horizontal-alignment: center; vertical-alignment: center; }



                }



                Text {



                    x: 0px; y: 86px; width: 360px;



                    text: root.is_ua ? "Зупинити?" : "Stop Firing?";



                    color: #FFFFFF;



                    font-family: "PT Sans";



                    font-size: 20px;



                    horizontal-alignment: center;



                }



                Text {



                    x: 0px; y: 120px; width: 360px;



                    text: root.is_ua ? "Ви впевнені, що хочете перервати процес?" : "Are you sure you want to abort the process?";



                    color: #A1A1AA;



                    font-size: 12px;



                    horizontal-alignment: center;



                }



                Rectangle {



                    x: 20px; y: 156px; width: 150px; height: 52px;



                    background: #27272A;



                    border-radius: 12px;



                    Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.stop_cancel(); } }



                }



                Rectangle {



                    x: 190px; y: 156px; width: 150px; height: 52px;



                    background: #DC2626;



                    border-radius: 12px;



                    Text { text: root.is_ua ? "ЗУПИНИТИ" : "STOP"; color: #FFFFFF; font-family: "PT Sans"; horizontal-alignment: center; vertical-alignment: center; }



                    TouchArea {



                width: parent.width; height: parent.height; clicked => { root.stop_confirm(); } }



                }



            }












    }












    // Software dimming overlay (avoid PWM artifacts)
    Rectangle {
        x: 0px; y: 0px; width: 480px; height: 320px;
        background: #000000;
        opacity: root.ui_dim;
        visible: root.ui_dim > 0.001 && root.view != View.Calibration;
        z: 900;
    }


    // Touch calibration
    if (root.view == View.Calibration) : Rectangle {
        x: 0px; y: 0px; width: 480px; height: 320px;
        z: 6000;
        background: #000000;

        Text {
            x: 12px; y: 300px; width: 456px;
            text: root.calib_hint;
            color: #A1A1AA;
            font-family: "PT Sans";
            font-size: 12px;
            horizontal-alignment: center;
        }

        // target dot
        Rectangle {
            x: root.calib_target_x * 1px - 14px;
            y: root.calib_target_y * 1px - 14px;
            width: 28px; height: 28px;
            background: #00000000;
            border-color: #10B981;
            border-width: 2px;
            border-radius: 14px;
        }
        Rectangle {
            x: root.calib_target_x * 1px - 1px;
            y: root.calib_target_y * 1px - 10px;
            width: 2px; height: 20px;
            background: #10B981;
        }
        Rectangle {
            x: root.calib_target_x * 1px - 10px;
            y: root.calib_target_y * 1px - 1px;
            width: 20px; height: 2px;
            background: #10B981;
        }

        Rectangle {
            x: 360px; y: 282px; width: 100px; height: 28px;
            background: #27272A;
            border-radius: 10px;
            Text { text: root.is_ua ? "Скасувати" : "Cancel"; color: #FFFFFF; font-family: "PT Sans"; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
            TouchArea { width: parent.width; height: parent.height; clicked => { root.cancel_touch_calibration(); } }
        }
    }

}
